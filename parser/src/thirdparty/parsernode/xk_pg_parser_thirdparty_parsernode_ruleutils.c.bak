#define nodeTag(nodeptr) (((const xk_pg_parser_Node*)(nodeptr))->type)

#define innerPlanState(node) (((xk_pg_parser_PlanState *)(node))->righttree)
#define outerPlanState(node) (((xk_pg_parser_PlanState *)(node))->lefttree)

#define xk_pg_parser_rt_fetch(rangetable_index, rangetable) \
    ((xk_pg_parser_RangeTblEntry *) xk_pg_parser_list_nth(rangetable, (rangetable_index)-1))

#define xk_pg_parser_deparse_columns_fetch(rangetable_index, dpns) \
    ((xk_pg_parser_deparse_columns *) xk_pg_parser_list_nth((dpns)->rtable_columns, (rangetable_index)-1))

#define IsA(nodeptr,_type_) (nodeTag(nodeptr) == T_ ## _type_)

#define intVal(v)        (((xk_pg_parser_Value *)(v))->val.ival)
#define floatVal(v)        atof(((xk_pg_parser_Value *)(v))->val.str)
#define strVal(v)        (((xk_pg_parser_Value *)(v))->val.str)

#define    INNER_VAR        65000    /* reference to inner subplan */
#define    OUTER_VAR        65001    /* reference to outer subplan */
#define    INDEX_VAR        65002    /* reference to index column */

static void pop_child_plan(xk_pg_parser_deparse_namespace *dpns,
                           xk_pg_parser_deparse_namespace *save_dpns);
static bool isSimpleNode(xk_pg_parser_Node *node, xk_pg_parser_Node *parentNode, int prettyFlags);

static xk_pg_parser_TargetEntry *get_tle_by_resno(xk_pg_parser_List *tlist,
                                                  xk_pg_parser_AttrNumber resno)
{
    xk_pg_parser_ListCell   *l;

    xk_pg_parser_foreach(l, tlist)
    {
        xk_pg_parser_TargetEntry *tle = (xk_pg_parser_TargetEntry *) xk_pg_parser_lfirst(l);

        if (tle->resno == resno)
            return tle;
    }
    return NULL;
}

static void set_deparse_planstate(xk_pg_parser_deparse_namespace *dpns, xk_pg_parser_PlanState *ps)
{
    dpns->planstate = ps;

    /*
     * We special-case Append and MergeAppend to pretend that the first child
     * plan is the OUTER referent; we have to interpret OUTER Vars in their
     * tlists according to one of the children, and the first one is the most
     * natural choice.  Likewise special-case ModifyTable to pretend that the
     * first child plan is the OUTER referent; this is to support RETURNING
     * lists containing references to non-target relations.
     */
    if (IsA(ps, xk_pg_parser_AppendState))
        dpns->outer_planstate = ((xk_pg_parser_AppendState *) ps)->appendplans[0];
    else if (IsA(ps, xk_pg_parser_MergeAppendState))
        dpns->outer_planstate = ((xk_pg_parser_MergeAppendState *) ps)->mergeplans[0];
    else if (IsA(ps, xk_pg_parser_ModifyTableState))
        dpns->outer_planstate = ((xk_pg_parser_ModifyTableState *) ps)->mt_plans[0];
    else
        dpns->outer_planstate = outerPlanState(ps);

    if (dpns->outer_planstate)
        dpns->outer_tlist = dpns->outer_planstate->plan->targetlist;
    else
        dpns->outer_tlist = NIL;

    /*
     * For a SubqueryScan, pretend the subplan is INNER referent.  (We don't
     * use OUTER because that could someday conflict with the normal meaning.)
     * Likewise, for a CteScan, pretend the subquery's plan is INNER referent.
     * For ON CONFLICT .. UPDATE we just need the inner tlist to point to the
     * excluded expression's tlist. (Similar to the SubqueryScan we don't want
     * to reuse OUTER, it's used for RETURNING in some modify table cases,
     * although not INSERT .. CONFLICT).
     */
    if (IsA(ps, xk_pg_parser_SubqueryScanState))
        dpns->inner_planstate = ((xk_pg_parser_SubqueryScanState *) ps)->subplan;
    else if (IsA(ps, xk_pg_parser_CteScanState))
        dpns->inner_planstate = ((xk_pg_parser_CteScanState *) ps)->cteplanstate;
    else if (IsA(ps, xk_pg_parser_ModifyTableState))
        dpns->inner_planstate = ps;
    else
        dpns->inner_planstate = innerPlanState(ps);

    if (IsA(ps, xk_pg_parser_ModifyTableState))
        dpns->inner_tlist = ((xk_pg_parser_ModifyTableState *) ps)->mt_excludedtlist;
    else if (dpns->inner_planstate)
        dpns->inner_tlist = dpns->inner_planstate->plan->targetlist;
    else
        dpns->inner_tlist = NIL;

    /* Set up referent for INDEX_VAR Vars, if needed */
    if (IsA(ps->plan, xk_pg_parser_IndexOnlyScan))
        dpns->index_tlist = ((xk_pg_parser_IndexOnlyScan *) ps->plan)->indextlist;
    else if (IsA(ps->plan, xk_pg_parser_ForeignScan))
        dpns->index_tlist = ((xk_pg_parser_ForeignScan *) ps->plan)->fdw_scan_tlist;
    else if (IsA(ps->plan, xk_pg_parser_CustomScan))
        dpns->index_tlist = ((xk_pg_parser_CustomScan *) ps->plan)->custom_scan_tlist;
    else
        dpns->index_tlist = NIL;
}

static void push_child_plan(xk_pg_parser_deparse_namespace *dpns,
                            xk_pg_parser_PlanState *ps,
                            xk_pg_parser_deparse_namespace *save_dpns)
{
    /* Save state for restoration later */
    *save_dpns = *dpns;

    /* Link current plan node into ancestors list */
    dpns->ancestors = xk_pg_parser_lcons(dpns->planstate, dpns->ancestors);

    /* Set attention on selected child */
    set_deparse_planstate(dpns, ps);
}

static void pop_child_plan(xk_pg_parser_deparse_namespace *dpns,
                           xk_pg_parser_deparse_namespace *save_dpns)
{
    xk_pg_parser_List       *ancestors;

    /* Get rid of ancestors list cell added by push_child_plan */
    ancestors = xk_pg_parser_list_delete_first(dpns->ancestors);

    /* Restore fields changed by push_child_plan */
    *dpns = *save_dpns;

    /* Make sure dpns->ancestors is right (may be unnecessary) */
    dpns->ancestors = ancestors;
}

static bool resolve_special_varno(xk_pg_parser_Node *node, xk_pg_parser_deparse_context *context, void *private,
                      void (*callback) (xk_pg_parser_Node *, xk_pg_parser_deparse_context *, void *))
{
    xk_pg_parser_Var           *var;
    xk_pg_parser_deparse_namespace *dpns;

    /* If it's not a Var, invoke the callback. */
    if (!IsA(node, xk_pg_parser_Var))
    {
        callback(node, context, private);
        return;
    }

    /* Find appropriate nesting depth */
    var = (xk_pg_parser_Var *) node;
    dpns = (xk_pg_parser_deparse_namespace *) xk_pg_parser_list_nth(context->namespaces,
                                          var->varlevelsup);

    /*
     * It's a special RTE, so recurse.
     */
    if (var->varno == OUTER_VAR && dpns->outer_tlist)
    {
        xk_pg_parser_TargetEntry *tle;
        xk_pg_parser_deparse_namespace save_dpns;

        tle = get_tle_by_resno(dpns->outer_tlist, var->varattno);
        if (!tle)
        {
            printf("ERROR: bogus varattno for OUTER_VAR var: %d\n", var->varattno);
        }

        push_child_plan(dpns, dpns->outer_planstate, &save_dpns);
        if (!resolve_special_varno((xk_pg_parser_Node *) tle->expr, context, private, callback));
            return false;
        pop_child_plan(dpns, &save_dpns);
        return;
    }
    else if (var->varno == INNER_VAR && dpns->inner_tlist)
    {
        xk_pg_parser_TargetEntry *tle;
        xk_pg_parser_deparse_namespace save_dpns;

        tle = get_tle_by_resno(dpns->inner_tlist, var->varattno);
        if (!tle)
            printf("ERROR, bogus varattno for INNER_VAR var: %d\n", var->varattno);

        push_child_plan(dpns, dpns->inner_planstate, &save_dpns);
        resolve_special_varno((xk_pg_parser_Node *) tle->expr, context, private, callback);
        pop_child_plan(dpns, &save_dpns);
        return;
    }
    else if (var->varno == INDEX_VAR && dpns->index_tlist)
    {
        xk_pg_parser_TargetEntry *tle;

        tle = get_tle_by_resno(dpns->index_tlist, var->varattno);
        if (!tle)
            printf("ERROR, bogus varattno for INDEX_VAR var: %d\n", var->varattno);

        resolve_special_varno((xk_pg_parser_Node *) tle->expr, context, private, callback);
        return;
    }
    else if (var->varno < 1 || var->varno > xk_pg_parser_list_length(dpns->rtable))
         printf("ERROR, bogus varno: %d\n", var->varno);

    /* Not special.  Just invoke the callback. */
    callback(node, context, private);
}

static void get_special_variable(xk_pg_parser_Node *node, xk_pg_parser_deparse_context *context, void *private)
{
    xk_pg_parser_StringInfo    buf = context->buf;

    /*
     * Force parentheses because our caller probably assumed a Var is a simple
     * expression.
     */
    if (!IsA(node, xk_pg_parser_Var))
        xk_pg_parser_appendStringInfoChar(buf, '(');
    get_rule_expr(node, context, true);
    if (!IsA(node, xk_pg_parser_Var))
        xk_pg_parser_appendStringInfoChar(buf, ')');
}

static const char *GetScanKeyword(int n,
                                  const xk_pg_parser_ScanKeywordList *keywords)
{
    return keywords->kw_string + keywords->kw_offsets[n];
}

static int ScanKeywordLookup(const char *str,
                      const xk_pg_parser_ScanKeywordList *keywords)
{
    size_t        len;
    int            h;
    const char *kw;

    /*
     * Reject immediately if too long to be any keyword.  This saves useless
     * hashing and downcasing work on long strings.
     */
    len = strlen(str);
    if (len > keywords->max_kw_len)
        return -1;

    /*
     * Compute the hash function.  We assume it was generated to produce
     * case-insensitive results.  Since it's a perfect hash, we need only
     * match to the specific keyword it identifies.
     */
    h = keywords->hash(str, len);

    /* An out-of-range result implies no match */
    if (h < 0 || h >= keywords->num_keywords)
        return -1;

    /*
     * Compare character-by-character to see if we have a match, applying an
     * ASCII-only downcasing to the input characters.  We must not use
     * tolower() since it may produce the wrong translation in some locales
     * (eg, Turkish).
     */
    kw = GetScanKeyword(h, keywords);
    while (*str != '\0')
    {
        char        ch = *str++;

        if (ch >= 'A' && ch <= 'Z')
            ch += 'a' - 'A';
        if (ch != *kw++)
            return -1;
    }
    if (*kw != '\0')
        return -1;

    /* Success! */
    return h;
}

const char *quote_identifier(const char *ident)
{
    /*
     * Can avoid quoting if ident starts with a lowercase letter or underscore
     * and contains only lowercase letters, digits, and underscores, *and* is
     * not any SQL keyword.  Otherwise, supply quotes.
     */
    int            nquotes = 0;
    bool        safe;
    const char *ptr;
    char       *result;
    char       *optr;

    /*
     * would like to use <ctype.h> macros here, but they might yield unwanted
     * locale-specific results...
     */
    safe = ((ident[0] >= 'a' && ident[0] <= 'z') || ident[0] == '_');

    for (ptr = ident; *ptr; ptr++)
    {
        char        ch = *ptr;

        if ((ch >= 'a' && ch <= 'z') ||
            (ch >= '0' && ch <= '9') ||
            (ch == '_'))
        {
            /* okay */
        }
        else
        {
            safe = false;
            if (ch == '"')
                nquotes++;
        }
    }

    if (safe)
    {
        /*
         * Check for keyword.  We quote keywords except for unreserved ones.
         * (In some cases we could avoid quoting a col_name or type_func_name
         * keyword, but it seems much harder than it's worth to tell that.)
         *
         * Note: ScanKeywordLookup() does case-insensitive comparison, but
         * that's fine, since we already know we have all-lower-case.
         */
        int            kwnum = ScanKeywordLookup(ident, &xk_pg_parser_ScanKeywords);

        if (kwnum >= 0 && xk_pg_parser_ScanKeywordCategories[kwnum] != UNRESERVED_KEYWORD)
            safe = false;
    }

    if (safe)
        return ident;            /* no change needed */
    xk_pg_parser_mcxt_malloc(XK_NODE_MCXT, (void**)&result, strlen(ident) + nquotes + 2 + 1);

    optr = result;
    *optr++ = '"';
    for (ptr = ident; *ptr; ptr++)
    {
        char        ch = *ptr;

        if (ch == '"')
            *optr++ = '"';
        *optr++ = ch;
    }
    *optr++ = '"';
    *optr = '\0';

    return result;
}

static char *get_rte_attribute_name(xk_pg_parser_RangeTblEntry *rte, xk_pg_parser_AttrNumber attnum)
{
    if (attnum == xk_pg_parser_InvalidAttrNumber)
        return "*";

    /*
     * If there is a user-written column alias, use it.
     */
    if (rte->alias &&
        attnum > 0 && attnum <= xk_pg_parser_list_length(rte->alias->colnames))
        return strVal(xk_pg_parser_list_nth(rte->alias->colnames, attnum - 1));

    /*
     * If the RTE is a relation, go to the system catalogs not the
     * eref->colnames list.  This is a little slower but it will give the
     * right answer if the column has been renamed since the eref list was
     * built (which can easily happen for rules).
     */
    /* fix: 这里我们选择仍从rte->eref->colnames获取名称 */
    #if 0
    if (rte->rtekind == RTE_RELATION)
        return get_attname(rte->relid, attnum, false);
    #endif
    /*
     * Otherwise use the column name from eref.  There should always be one.
     */
    if (attnum > 0 && attnum <= xk_pg_parser_list_length(rte->eref->colnames))
        return strVal(xk_pg_parser_list_nth(rte->eref->colnames, attnum - 1));

    /* else caller gave us a bogus attnum */
    printf("ERROR, invalid attnum %d for rangetable entry %s\n",
         attnum, rte->eref->aliasname);
    return NULL;                /* keep compiler quiet */
}

#define FORMAT_TYPE_TYPEMOD_GIVEN 0x01  /* typemod defined by caller */
#define FORMAT_TYPE_ALLOW_INVALID 0x02  /* allow invalid types */
#define FORMAT_TYPE_FORCE_QUALIFY 0x04  /* force qualification of type */

static uint32_t check_type_have_elem(uint32_t typid)
{
    uint32_t result = xk_pg_parser_InvalidOid;
    switch(typid)
    {
        case BOOLARRAYOID:
            result = BOOLOID;
            break;
        case BYTEAARRAYOID:
            result = BYTEAOID;
            break;
        case CHARARRAYOID:
            result = BOOLOID;
            break;
        case INT8ARRAYOID:
            result = INT8OID;
            break;
        case INT2ARRAYOID:
            result = INT2OID;
            break;
        case INT4ARRAYOID:
            result = INT4OID;
            break;
        case FLOAT4ARRAYOID:
            result = FLOAT4OID;
            break;
        case FLOAT8ARRAYOID:
            result = FLOAT8OID;
            break;
        case BPCHARARRAYOID:
            result = BPCHAROID;
            break;
        case VARCHARARRAYOID:
            result = VARCHAROID;
            break;
        case DATEARRAYOID:
            result = DATEOID;
            break;
        case TIMEARRAYOID:
            result = TIMEOID;
            break;
        case TIMESTAMPARRAYOID:
            result = TIMESTAMPOID;
            break;
        case TIMESTAMPTZARRAYOID:
            result = TIMESTAMPOID;
            break;
        case INTERVALARRAYOID:
            result = INTERVALOID;
            break;
        case TIMETZARRAYOID:
            result = TIMETZOID;
            break;
        case BITARRAYOID:
            result = BITOID;
            break;
        case VARBITARRAYOID:
            result = VARBITOID;
            break;
        case NUMERICARRAYOID:
            result = NUMERICOID;
            break;
        default:
            break;
    }
    return result;
}

