static char *printTypmod(const char *typname, int32_t typmod, char *typmodout)
{
    char       res[1024];

    if (!typmodout)
    {
        /* Default behavior: just print the integer typmod with parens */
        sprintf(res, "%s(%d)", typname, (int) typmod);
    }
    else
    {
        /* Use the type-specific typmodout procedure */
        sprintf(res,"%s%s", typname, typmodout);
    }

    return xk_pg_parser_mcxt_strdup(res);
}

static char *quote_qualified_identifier(const char *qualifier,
                                        const char *ident)
{
    xk_pg_parser_StringInfoData buf;

    xk_pg_parser_initStringInfo(&buf);
    if (qualifier)
        xk_pg_parser_appendStringInfo(&buf, "%s.", quote_identifier(qualifier));
    xk_pg_parser_appendStringInfoString(&buf, quote_identifier(ident));
    return buf.data;
}

static char *format_type_extended(uint32_t type_oid, int32_t typemod, uint16_t flags)
{
    uint32_t            array_base_type;
    bool        is_array;
    char       *buf;
    bool        with_typemod;

    if (type_oid == xk_pg_parser_InvalidOid && (flags & FORMAT_TYPE_ALLOW_INVALID) != 0)
        return xk_pg_parser_mcxt_strdup("-");

    /*
     * Check if it's a regular (variable length) array type.  Fixed-length
     * array types such as "name" shouldn't get deconstructed.  As of Postgres
     * 8.1, rather than checking typlen we check the toast property, and don't
     * deconstruct "plain storage" array types --- this is because we don't
     * want to show oidvector as oid[].
     */
    array_base_type = check_type_have_elem(type_oid);

    if (array_base_type != xk_pg_parser_InvalidOid)
    {
        type_oid = array_base_type;
        is_array = true;
    }
    else
        is_array = false;

    with_typemod = (flags & FORMAT_TYPE_TYPEMOD_GIVEN) != 0 && (typemod >= 0);

    /*
     * See if we want to special-case the output for certain built-in types.
     * Note that these special cases should all correspond to special
     * productions in gram.y, to ensure that the type name will be taken as a
     * system type, not a user type of the same name.
     *
     * If we do not provide a special-case output here, the type name will be
     * handled the same way as a user type name --- in particular, it will be
     * double-quoted if it matches any lexer keyword.  This behavior is
     * essential for some cases, such as types "bit" and "char".
     */
    buf = NULL;                    /* flag for no special case */

    switch (type_oid)
    {
        case BITOID:
            if (with_typemod)
                buf = printTypmod("bit", typemod, "bit_out");
            else if ((flags & FORMAT_TYPE_TYPEMOD_GIVEN) != 0)
            {
                /*
                 * bit with typmod -1 is not the same as BIT, which means
                 * BIT(1) per SQL spec.  Report it as the quoted typename so
                 * that parser will not assign a bogus typmod.
                 */
            }
            else
                buf = xk_pg_parser_mcxt_strdup("bit");
            break;

        case BOOLOID:
            buf = xk_pg_parser_mcxt_strdup("boolean");
            break;

        case BPCHAROID:
            if (with_typemod)
                buf = printTypmod("character", typemod, "bpcharout");
            else if ((flags & FORMAT_TYPE_TYPEMOD_GIVEN) != 0)
            {
                /*
                 * bpchar with typmod -1 is not the same as CHARACTER, which
                 * means CHARACTER(1) per SQL spec.  Report it as bpchar so
                 * that parser will not assign a bogus typmod.
                 */
            }
            else
                buf = xk_pg_parser_mcxt_strdup("character");
            break;

        case FLOAT4OID:
            buf = xk_pg_parser_mcxt_strdup("real");
            break;

        case FLOAT8OID:
            buf = xk_pg_parser_mcxt_strdup("double precision");
            break;

        case INT2OID:
            buf = xk_pg_parser_mcxt_strdup("smallint");
            break;

        case INT4OID:
            buf = xk_pg_parser_mcxt_strdup("integer");
            break;

        case INT8OID:
            buf = xk_pg_parser_mcxt_strdup("bigint");
            break;

        case NUMERICOID:
            if (with_typemod)
                buf = printTypmod("numeric", typemod, "numeric_out");
            else
                buf = xk_pg_parser_mcxt_strdup("numeric");
            break;

        case INTERVALOID:
            if (with_typemod)
                buf = printTypmod("interval", typemod, "interval_out");
            else
                buf = xk_pg_parser_mcxt_strdup("interval");
            break;

        case TIMEOID:
            if (with_typemod)
                buf = printTypmod("time", typemod, "time_out");
            else
                buf = xk_pg_parser_mcxt_strdup("time without time zone");
            break;

        case TIMETZOID:
            if (with_typemod)
                buf = printTypmod("time", typemod, "timetz_out");
            else
                buf = xk_pg_parser_mcxt_strdup("time with time zone");
            break;

        case TIMESTAMPOID:
            if (with_typemod)
                buf = printTypmod("timestamp", typemod, "timestamp_out");
            else
                buf = xk_pg_parser_mcxt_strdup("timestamp without time zone");
            break;

        case TIMESTAMPTZOID:
            if (with_typemod)
                buf = printTypmod("timestamp", typemod, "timestamptz_out");
            else
                buf = xk_pg_parser_mcxt_strdup("timestamp with time zone");
            break;

        case VARBITOID:
            if (with_typemod)
                buf = printTypmod("bit varying", typemod, "varbit_out");
            else
                buf = xk_pg_parser_mcxt_strdup("bit varying");
            break;

        case VARCHAROID:
            if (with_typemod)
                buf = printTypmod("character varying", typemod, "varcharout");
            else
                buf = xk_pg_parser_mcxt_strdup("character varying");
            break;
    }

    if (buf == NULL)
    {
        /*
         * Default handling: report the name as it appears in the catalog.
         * Here, we must qualify the name if it is not visible in the search
         * path or if caller requests it; and we must double-quote it if it's
         * not a standard identifier or if it matches any keyword.
         */
        char       *nspname = NULL;
        char       *typname = NULL;

        typname = get_typname(type_oid);
        if (typname)
        {
            nspname = "public";
            buf = quote_qualified_identifier(nspname, typname);
            xk_pg_parser_mcxt_free(XK_NODE_MCXT, typname);
        }
        else
        {
            typname = "UNKNOWN_TYPE";
            buf = quote_qualified_identifier(nspname, typname);
        }

        if (with_typemod)
            buf = printTypmod(buf, typemod, NULL);
    }

    if (is_array)
    {
        xk_pg_parser_mcxt_realloc(XK_NODE_MCXT, (void **)&buf, strlen(buf) + 3);
        buf = sprintf("%s[]", buf);
    }

    return buf;
}

static char *format_type_with_typemod(uint32_t type_oid, int32_t typemod)
{
    return format_type_extended(type_oid, typemod, FORMAT_TYPE_TYPEMOD_GIVEN);
}


/* 
 * 这里的最终目的是获取列的名称, 但我们无法查表获取
 * 因此在这里只是简单的获取列的排序号,
 * 后续的组装处理在DDL解析中完成, 最后由前端进行解析
 */
static char *get_variable(xk_pg_parser_Var *var,
                          int32_t levelsup,
                          bool istoplevel,
                          xk_pg_parser_deparse_context *context)
{

    

#if 0
    xk_pg_parser_StringInfo    buf = context->buf;
    xk_pg_parser_RangeTblEntry *rte;
    xk_pg_parser_AttrNumber    attnum;
    int32_t            netlevelsup;
    xk_pg_parser_deparse_namespace *dpns;
    xk_pg_parser_deparse_columns *colinfo;
    char       *refname;
    char       *attname;

    /* Find appropriate nesting depth */
    netlevelsup = var->varlevelsup + levelsup;
    if (netlevelsup >= xk_pg_parser_list_length(context->namespaces))
    {
        printf("ERROR: bogus varlevelsup: %d offset %d",
             var->varlevelsup, levelsup);
        return NULL;
    }

    dpns = (xk_pg_parser_deparse_namespace *) xk_pg_parser_list_nth(context->namespaces,
                                          netlevelsup);

    /*
     * Try to find the relevant RTE in this rtable.  In a plan tree, it's
     * likely that varno is OUTER_VAR or INNER_VAR, in which case we must dig
     * down into the subplans, or INDEX_VAR, which is resolved similarly. Also
     * find the aliases previously assigned for this RTE.
     */
    if (var->varno >= 1 && var->varno <= xk_pg_parser_list_length(dpns->rtable))
    {
        rte = xk_pg_parser_rt_fetch(var->varno, dpns->rtable);
        refname = (char *) xk_pg_parser_list_nth(dpns->rtable_names, var->varno - 1);
        colinfo = xk_pg_parser_deparse_columns_fetch(var->varno, dpns);
        attnum = var->varattno;
    }
    else
    {
        resolve_special_varno((xk_pg_parser_Node *) var, context, NULL,
                              get_special_variable);
        return NULL;
    }

    /*
     * The planner will sometimes emit Vars referencing resjunk elements of a
     * subquery's target list (this is currently only possible if it chooses
     * to generate a "physical tlist" for a SubqueryScan or CteScan node).
     * Although we prefer to print subquery-referencing Vars using the
     * subquery's alias, that's not possible for resjunk items since they have
     * no alias.  So in that case, drill down to the subplan and print the
     * contents of the referenced tlist item.  This works because in a plan
     * tree, such Vars can only occur in a SubqueryScan or CteScan node, and
     * we'll have set dpns->inner_planstate to reference the child plan node.
     */
    if ((rte->rtekind == RTE_SUBQUERY || rte->rtekind == RTE_CTE) &&
        attnum > xk_pg_parser_list_length(rte->eref->colnames) &&
        dpns->inner_planstate)
    {
        xk_pg_parser_TargetEntry *tle;
        xk_pg_parser_deparse_namespace save_dpns;

        tle = get_tle_by_resno(dpns->inner_tlist, var->varattno);
        if (!tle)
            printf("ERROR, invalid attnum %d for relation \"%s\"\n",
                 var->varattno, rte->eref->aliasname);

        push_child_plan(dpns, dpns->inner_planstate, &save_dpns);

        /*
         * Force parentheses because our caller probably assumed a Var is a
         * simple expression.
         */
        if (!IsA(tle->expr, xk_pg_parser_Var))
            xk_pg_parser_appendStringInfoChar(buf, '(');
        get_rule_expr((xk_pg_parser_Node *) tle->expr, context, true);
        if (!IsA(tle->expr, xk_pg_parser_Var))
            xk_pg_parser_appendStringInfoChar(buf, ')');

        pop_child_plan(dpns, &save_dpns);
        return NULL;
    }

    /*
     * If it's an unnamed join, look at the expansion of the alias variable.
     * If it's a simple reference to one of the input vars, then recursively
     * print the name of that var instead.  When it's not a simple reference,
     * we have to just print the unqualified join column name.  (This can only
     * happen with "dangerous" merged columns in a JOIN USING; we took pains
     * previously to make the unqualified column name unique in such cases.)
     *
     * This wouldn't work in decompiling plan trees, because we don't store
     * joinaliasvars lists after planning; but a plan tree should never
     * contain a join alias variable.
     */
    if (rte->rtekind == RTE_JOIN && rte->alias == NULL)
    {
        if (rte->joinaliasvars == NIL)
            printf("ERROR, cannot decompile join alias var in plan tree\n");
        if (attnum > 0)
        {
            xk_pg_parser_Var           *aliasvar;

            aliasvar = (xk_pg_parser_Var *) xk_pg_parser_list_nth(rte->joinaliasvars, attnum - 1);
            /* we intentionally don't strip implicit coercions here */
            if (aliasvar && IsA(aliasvar, xk_pg_parser_Var))
            {
                return get_variable(aliasvar, var->varlevelsup + levelsup,
                                    istoplevel, context);
            }
        }

        /*
         * Unnamed join has no refname.  (Note: since it's unnamed, there is
         * no way the user could have referenced it to create a whole-row Var
         * for it.  So we don't have to cover that case below.)
         */
    }

    if (attnum == xk_pg_parser_InvalidAttrNumber)
        attname = NULL;
    else if (attnum > 0)
    {
        /* Get column name to use from the colinfo struct */
        if (attnum > colinfo->num_cols)
            printf("ERROR, invalid attnum %d for relation \"%s\"\n",
                 attnum, rte->eref->aliasname);
        attname = colinfo->colnames[attnum - 1];
        if (attname == NULL)    /* dropped column? */
            printf("ERROR, invalid attnum %d for relation \"%s\"\n",
                 attnum, rte->eref->aliasname);
    }
    else
    {
        /* System column - name is fixed, get it from the catalog */
        attname = get_rte_attribute_name(rte, attnum);
    }

    if (refname && (context->varprefix || attname == NULL))
    {
        xk_pg_parser_appendStringInfoString(buf, quote_identifier(refname));
        xk_pg_parser_appendStringInfoChar(buf, '.');
    }
    if (attname)
        xk_pg_parser_appendStringInfoString(buf, quote_identifier(attname));
    else
    {
        xk_pg_parser_appendStringInfoChar(buf, '*');
        if (istoplevel)
            xk_pg_parser_appendStringInfo(buf, "::%s",
                             format_type_with_typemod(var->vartype,
                                                      var->vartypmod));
    }

    return attname;
#endif
}

#define OidIsValid(objectId)  ((bool) ((objectId) != xk_pg_parser_InvalidOid))

/* 暂时不获取collation相关信息 */
#if 0
static void get_const_collation(xk_pg_parser_Const *constval, xk_pg_parser_deparse_context *context)
{
    xk_pg_parser_StringInfo    buf = context->buf;

    if (OidIsValid(constval->constcollid))
    {
        uint32_t typcollation = get_typcollation(constval->consttype);

        if (constval->constcollid != typcollation)
        {
            appendStringInfo(buf, " COLLATE %s",
                             generate_collation_name(constval->constcollid));
        }
    }
}
#endif
#define SQL_STR_DOUBLE(ch, escape_backslash)    \
    ((ch) == '\'' || ((ch) == '\\' && (escape_backslash)))
static void simple_quote_literal(xk_pg_parser_StringInfo buf, const char *val)
{
    const char *valptr;

    /*
     * We form the string literal according to the prevailing setting of
     * standard_conforming_strings; we never use E''. User is responsible for
     * making sure result is used correctly.
     */
    xk_pg_parser_appendStringInfoChar(buf, '\'');
    for (valptr = val; *valptr; valptr++)
    {
        char        ch = *valptr;

        if (SQL_STR_DOUBLE(ch, false))
            xk_pg_parser_appendStringInfoChar(buf, ch);
        xk_pg_parser_appendStringInfoChar(buf, ch);
    }
    xk_pg_parser_appendStringInfoChar(buf, '\'');
}

static void get_const_expr(xk_pg_parser_Const *constval,
                           xk_pg_parser_deparse_context *context,
                           int showtype)
{
    xk_pg_parser_StringInfo    buf = context->buf;
    char       *typoutput = NULL;
    bool        typIsVarlena;
    char       *extval;
    bool        needlabel = false;

    if (constval->constisnull)
    {
        /*
         * Always label the type of a NULL constant to prevent misdecisions
         * about type when reparsing.
         */
        xk_pg_parser_appendStringInfoString(buf, "NULL");
        if (showtype >= 0)
        {
            xk_pg_parser_appendStringInfo(buf, "::%s",
                             format_type_with_typemod(constval->consttype,
                                                      constval->consttypmod));
            //get_const_collation(constval, context);
        }
        return;
    }

    typoutput = get_local_typoutput_by_oid(constval->consttype);

    extval = xk_pg_parser_convert_attr_to_str_by_typid_typoptput(constval->constvalue,
                                                             constval->consttype,
                                                             typoutput,
                                                             context->zicinfo);
    if (!extval)
    {
        //todo errcode
    }
    switch (constval->consttype)
    {
        case INT4OID:

            /*
             * INT4 can be printed without any decoration, unless it is
             * negative; in that case print it as '-nnn'::integer to ensure
             * that the output will re-parse as a constant, not as a constant
             * plus operator.  In most cases we could get away with printing
             * (-nnn) instead, because of the way that gram.y handles negative
             * literals; but that doesn't work for INT_MIN, and it doesn't
             * seem that much prettier anyway.
             */
            if (extval[0] != '-')
                xk_pg_parser_appendStringInfoString(buf, extval);
            else
            {
                xk_pg_parser_appendStringInfo(buf, "'%s'", extval);
                needlabel = true;    /* we must attach a cast */
            }
            break;

        case NUMERICOID:

            /*
             * NUMERIC can be printed without quotes if it looks like a float
             * constant (not an integer, and not Infinity or NaN) and doesn't
             * have a leading sign (for the same reason as for INT4).
             */
            if (isdigit((unsigned char) extval[0]) &&
                strcspn(extval, "eE.") != strlen(extval))
            {
                xk_pg_parser_appendStringInfoString(buf, extval);
            }
            else
            {
                xk_pg_parser_appendStringInfo(buf, "'%s'", extval);
                needlabel = true;    /* we must attach a cast */
            }
            break;

        case BOOLOID:
            if (strcmp(extval, "t") == 0)
                xk_pg_parser_appendStringInfoString(buf, "true");
            else
                xk_pg_parser_appendStringInfoString(buf, "false");
            break;

        default:
            simple_quote_literal(buf, extval);
            break;
    }

    xk_pg_parser_mcxt_free(XK_NODE_MCXT, extval);

    if (showtype < 0)
        return;

    /*
     * For showtype == 0, append ::typename unless the constant will be
     * implicitly typed as the right type when it is read in.
     *
     * XXX this code has to be kept in sync with the behavior of the parser,
     * especially make_const.
     */
    switch (constval->consttype)
    {
        case BOOLOID:
        case UNKNOWNOID:
            /* These types can be left unlabeled */
            needlabel = false;
            break;
        case INT4OID:
            /* We determined above whether a label is needed */
            break;
        case NUMERICOID:

            /*
             * Float-looking constants will be typed as numeric, which we
             * checked above; but if there's a nondefault typmod we need to
             * show it.
             */
            needlabel |= (constval->consttypmod >= 0);
            break;
        default:
            needlabel = true;
            break;
    }
    if (needlabel || showtype > 0)
        xk_pg_parser_appendStringInfo(buf, "::%s",
                         format_type_with_typemod(constval->consttype,
                                                  constval->consttypmod));

    //get_const_collation(constval, context);
}

#define PRETTYFLAG_PAREN        0x0001
#define PRETTYFLAG_INDENT       0x0002
#define PRETTYFLAG_SCHEMA       0x0004

#define PRETTY_PAREN(context)     ((context)->prettyFlags & PRETTYFLAG_PAREN)
#define PRETTY_INDENT(context)    ((context)->prettyFlags & PRETTYFLAG_INDENT)
#define PRETTY_SCHEMA(context)    ((context)->prettyFlags & PRETTYFLAG_SCHEMA)

static const char *get_simple_binary_op_name(xk_pg_parser_OpExpr *expr)
{
    xk_pg_parser_List       *args = expr->args;

    if (list_length(args) == 2)
    {
        /* binary operator */
        xk_pg_parser_Node       *arg1 = (xk_pg_parser_Node *) xk_pg_parser_linitial(args);
        xk_pg_parser_Node       *arg2 = (xk_pg_parser_Node *) xk_pg_parser_lsecond(args);
        const char *op;

        op = generate_operator_name(expr->opno, exprType(arg1), exprType(arg2));
        if (strlen(op) == 1)
            return op;
    }
    return NULL;
}

static bool isSimpleNode(xk_pg_parser_Node *node, xk_pg_parser_Node *parentNode, int prettyFlags)
{
    if (!node)
        return false;

    switch (nodeTag(node))
    {
        case T_xk_pg_parser_Var:
        case T_xk_pg_parser_Const:
        case T_xk_pg_parser_Param:
        case T_xk_pg_parser_CoerceToDomainValue:
        case T_xk_pg_parser_SetToDefault:
        case T_xk_pg_parser_CurrentOfExpr:
            /* single words: always simple */
            return true;

        case T_xk_pg_parser_SubscriptingRef:
        case T_xk_pg_parser_ArrayExpr:
        case T_xk_pg_parser_RowExpr:
        case T_xk_pg_parser_CoalesceExpr:
        case T_xk_pg_parser_MinMaxExpr:
        case T_xk_pg_parser_SQLValueFunction:
        case T_xk_pg_parser_XmlExpr:
        case T_xk_pg_parser_NextValueExpr:
        case T_xk_pg_parser_NullIfExpr:
        case T_xk_pg_parser_Aggref:
        case T_xk_pg_parser_WindowFunc:
        case T_xk_pg_parser_FuncExpr:
            /* function-like: name(..) or name[..] */
            return true;

            /* CASE keywords act as parentheses */
        case T_xk_pg_parser_CaseExpr:
            return true;

        case T_xk_pg_parser_FieldSelect:

            /*
             * appears simple since . has top precedence, unless parent is
             * T_FieldSelect itself!
             */
            return (IsA(parentNode, xk_pg_parser_FieldSelect) ? false : true);

        case T_xk_pg_parser_FieldStore:

            /*
             * treat like FieldSelect (probably doesn't matter)
             */
            return (IsA(parentNode, xk_pg_parser_FieldStore) ? false : true);

        case T_xk_pg_parser_CoerceToDomain:
            /* maybe simple, check args */
            return isSimpleNode((xk_pg_parser_Node *) ((xk_pg_parser_CoerceToDomain *) node)->arg,
                                node, prettyFlags);
        case T_xk_pg_parser_RelabelType:
            return isSimpleNode((xk_pg_parser_Node *) ((xk_pg_parser_RelabelType *) node)->arg,
                                node, prettyFlags);
        case T_xk_pg_parser_CoerceViaIO:
            return isSimpleNode((xk_pg_parser_Node *) ((xk_pg_parser_CoerceViaIO *) node)->arg,
                                node, prettyFlags);
        case T_xk_pg_parser_ArrayCoerceExpr:
            return isSimpleNode((xk_pg_parser_Node *) ((xk_pg_parser_ArrayCoerceExpr *) node)->arg,
                                node, prettyFlags);
        case T_xk_pg_parser_ConvertRowtypeExpr:
            return isSimpleNode((xk_pg_parser_Node *) ((xk_pg_parser_ConvertRowtypeExpr *) node)->arg,
                                node, prettyFlags);

        case T_xk_pg_parser_OpExpr:
            {
                /* depends on parent node type; needs further checking */
                if (prettyFlags & PRETTYFLAG_PAREN && IsA(parentNode, xk_pg_parser_OpExpr))
                {
                    const char *op;
                    const char *parentOp;
                    bool        is_lopriop;
                    bool        is_hipriop;
                    bool        is_lopriparent;
                    bool        is_hipriparent;

                    op = get_simple_binary_op_name((xk_pg_parser_OpExpr *) node);
                    if (!op)
                        return false;

                    /* We know only the basic operators + - and * / % */
                    is_lopriop = (strchr("+-", *op) != NULL);
                    is_hipriop = (strchr("*/%", *op) != NULL);
                    if (!(is_lopriop || is_hipriop))
                        return false;

                    parentOp = get_simple_binary_op_name((xk_pg_parser_OpExpr *) parentNode);
                    if (!parentOp)
                        return false;

                    is_lopriparent = (strchr("+-", *parentOp) != NULL);
                    is_hipriparent = (strchr("*/%", *parentOp) != NULL);
                    if (!(is_lopriparent || is_hipriparent))
                        return false;

                    if (is_hipriop && is_lopriparent)
                        return true;    /* op binds tighter than parent */

                    if (is_lopriop && is_hipriparent)
                        return false;

                    /*
                     * Operators are same priority --- can skip parens only if
                     * we have (a - b) - c, not a - (b - c).
                     */
                    if (node == (xk_pg_parser_Node *) xk_pg_parser_linitial(((xk_pg_parser_OpExpr *) parentNode)->args))
                        return true;

                    return false;
                }
                /* else do the same stuff as for T_SubLink et al. */
            }
            /* FALLTHROUGH */

        case T_xk_pg_parser_SubLink:
        case T_xk_pg_parser_NullTest:
        case T_xk_pg_parser_BooleanTest:
        case T_xk_pg_parser_DistinctExpr:
            switch (nodeTag(parentNode))
            {
                case T_xk_pg_parser_FuncExpr:
                    {
                        /* special handling for casts */
                        xk_pg_parser_CoercionForm type = ((xk_pg_parser_FuncExpr *) parentNode)->funcformat;

                        if (type == COERCE_EXPLICIT_CAST ||
                            type == COERCE_IMPLICIT_CAST)
                            return false;
                        return true;    /* own parentheses */
                    }
                case T_xk_pg_parser_BoolExpr:    /* lower precedence */
                case T_xk_pg_parser_SubscriptingRef: /* other separators */
                case T_xk_pg_parser_ArrayExpr:    /* other separators */
                case T_xk_pg_parser_RowExpr: /* other separators */
                case T_xk_pg_parser_CoalesceExpr:    /* own parentheses */
                case T_xk_pg_parser_MinMaxExpr:    /* own parentheses */
                case T_xk_pg_parser_XmlExpr: /* own parentheses */
                case T_xk_pg_parser_NullIfExpr:    /* other separators */
                case T_xk_pg_parser_Aggref:    /* own parentheses */
                case T_xk_pg_parser_WindowFunc:    /* own parentheses */
                case T_xk_pg_parser_CaseExpr:    /* other separators */
                    return true;
                default:
                    return false;
            }

        case T_xk_pg_parser_BoolExpr:
            switch (nodeTag(parentNode))
            {
                case T_xk_pg_parser_BoolExpr:
                    if (prettyFlags & PRETTYFLAG_PAREN)
                    {
                        xk_pg_parser_BoolExprType type;
                        xk_pg_parser_BoolExprType parentType;

                        type = ((xk_pg_parser_BoolExpr *) node)->boolop;
                        parentType = ((xk_pg_parser_BoolExpr *) parentNode)->boolop;
                        switch (type)
                        {
                            case NOT_EXPR:
                            case AND_EXPR:
                                if (parentType == AND_EXPR || parentType == OR_EXPR)
                                    return true;
                                break;
                            case OR_EXPR:
                                if (parentType == OR_EXPR)
                                    return true;
                                break;
                        }
                    }
                    return false;
                case T_xk_pg_parser_FuncExpr:
                    {
                        /* special handling for casts */
                        xk_pg_parser_CoercionForm type = ((xk_pg_parser_FuncExpr *) parentNode)->funcformat;

                        if (type == COERCE_EXPLICIT_CAST ||
                            type == COERCE_IMPLICIT_CAST)
                            return false;
                        return true;    /* own parentheses */
                    }
                case T_xk_pg_parser_SubscriptingRef: /* other separators */
                case T_xk_pg_parser_ArrayExpr:    /* other separators */
                case T_xk_pg_parser_RowExpr: /* other separators */
                case T_xk_pg_parser_CoalesceExpr:    /* own parentheses */
                case T_xk_pg_parser_MinMaxExpr:    /* own parentheses */
                case T_xk_pg_parser_XmlExpr: /* own parentheses */
                case T_xk_pg_parser_NullIfExpr:    /* other separators */
                case T_xk_pg_parser_Aggref:    /* own parentheses */
                case T_xk_pg_parser_WindowFunc:    /* own parentheses */
                case T_xk_pg_parser_CaseExpr:    /* other separators */
                    return true;
                default:
                    return false;
            }

        default:
            break;
    }
    /* those we don't know: in dubio complexo */
    return false;
}

static void get_rule_expr_paren(xk_pg_parser_Node *node, xk_pg_parser_deparse_context *context,
                    bool showimplicit, xk_pg_parser_Node *parentNode)
{
    bool        need_paren;

    need_paren = PRETTY_PAREN(context) &&
        !isSimpleNode(node, parentNode, context->prettyFlags);

    if (need_paren)
        xk_pg_parser_appendStringInfoChar(context->buf, '(');

    get_rule_expr(node, context, showimplicit);

    if (need_paren)
        xk_pg_parser_appendStringInfoChar(context->buf, ')');
}

#define FUNC_MAX_ARGS 100

static void get_func_expr(xk_pg_parser_FuncExpr *expr, xk_pg_parser_deparse_context *context,
              bool showimplicit)
{
    xk_pg_parser_StringInfo    buf = context->buf;
    uint32_t            funcoid = expr->funcid;
    uint32_t            argtypes[FUNC_MAX_ARGS];
    int            nargs;
    xk_pg_parser_List       *argnames;
    bool        use_variadic;
    xk_pg_parser_ListCell   *l;

    /*
     * If the function call came from an implicit coercion, then just show the
     * first argument --- unless caller wants to see implicit coercions.
     */
    if (expr->funcformat == COERCE_IMPLICIT_CAST && !showimplicit)
    {
        get_rule_expr_paren((xk_pg_parser_Node *) xk_pg_parser_linitial(expr->args), context,
                            false, (xk_pg_parser_Node *) expr);
        return;
    }

    /*
     * If the function call came from a cast, then show the first argument
     * plus an explicit cast operation.
     */
    if (expr->funcformat == COERCE_EXPLICIT_CAST ||
        expr->funcformat == COERCE_IMPLICIT_CAST)
    {
        xk_pg_parser_Node       *arg = xk_pg_parser_linitial(expr->args);
        uint32_t            rettype = expr->funcresulttype;
        int32_t        coercedTypmod;

        /* Get the typmod if this is a length-coercion function */
        (void) exprIsLengthCoercion((xk_pg_parser_Node *) expr, &coercedTypmod);

        get_coercion_expr(arg, context,
                          rettype, coercedTypmod,
                          (xk_pg_parser_Node *) expr);

        return;
    }

    /*
     * Normal function: display as proname(args).  First we need to extract
     * the argument datatypes.
     */
    if (xk_pg_parser_list_length(expr->args) > FUNC_MAX_ARGS)
    {
        //todo errcoede
        printf("ERROR, too many arguments\n");
    }
    nargs = 0;
    argnames = NIL;
    xk_pg_parser_foreach(l, expr->args)
    {
        xk_pg_parser_Node       *arg = (xk_pg_parser_Node *) xk_pg_parser_lfirst(l);

        if (IsA(arg, xk_pg_parser_NamedArgExpr))
            argnames = xk_pg_parser_list_lappend(argnames, ((xk_pg_parser_NamedArgExpr *) arg)->name);
        argtypes[nargs] = exprType(arg);
        nargs++;
    }

    xk_pg_parser_appendStringInfo(buf, "%s(",
                     generate_function_name(funcoid, nargs,
                                            argnames, argtypes,
                                            expr->funcvariadic,
                                            &use_variadic,
                                            context->special_exprkind));
    nargs = 0;
    xk_pg_parser_foreach(l, expr->args)
    {
        if (nargs++ > 0)
            xk_pg_parser_appendStringInfoString(buf, ", ");
        if (use_variadic && lnext(l) == NULL)
            xk_pg_parser_appendStringInfoString(buf, "VARIADIC ");
        get_rule_expr((xk_pg_parser_Node *) xk_pg_parser_lfirst(l), context, true);
    }
    xk_pg_parser_appendStringInfoChar(buf, ')');
}

void get_rule_expr(xk_pg_parser_Node *node,
                   xk_pg_parser_deparse_context *context,
                   bool showimplicit)
{
    xk_pg_parser_StringInfo    buf = context->buf;

    if (node == NULL)
        return;

    /* Guard against excessively long or deeply-nested queries */
    /* 忽略中断和深层嵌套检查 */
    #if 0
    CHECK_FOR_INTERRUPTS();
    check_stack_depth();
    #endif
    /*
     * Each level of get_rule_expr must emit an indivisible term
     * (parenthesized if necessary) to ensure result is reparsed into the same
     * expression tree.  The only exception is that when the input is a List,
     * we emit the component items comma-separated with no surrounding
     * decoration; this is convenient for most callers.
     */
    switch (nodeTag(node))
    {
        case T_xk_pg_parser_Var:
            (void) get_variable((xk_pg_parser_Var *) node, 0, false, context);
            break;

        case T_xk_pg_parser_Const:
            get_const_expr((xk_pg_parser_Const *) node, context, 0);
            break;

        case T_xk_pg_parser_FuncExpr:
            get_func_expr((xk_pg_parser_FuncExpr *) node, context, showimplicit);
            break;

        case T_xk_pg_parser_OpExpr:
            get_oper_expr((xk_pg_parser_OpExpr *) node, context);
            break;

        case T_xk_pg_parser_BoolExpr:
            {
                xk_pg_parser_BoolExpr   *expr = (xk_pg_parser_BoolExpr *) node;
                xk_pg_parser_Node       *first_arg = xk_pg_parser_linitial(expr->args);
                xk_pg_parser_ListCell   *arg = xk_pg_parser_lnext(xk_pg_parser_list_head(expr->args));

                switch (expr->boolop)
                {
                    case AND_EXPR:
                        if (!PRETTY_PAREN(context))
                            xk_pg_parser_appendStringInfoChar(buf, '(');
                        get_rule_expr_paren(first_arg, context,
                                            false, node);
                        while (arg)
                        {
                            xk_pg_parser_appendStringInfoString(buf, " AND ");
                            get_rule_expr_paren((xk_pg_parser_Node *) xk_pg_parser_lfirst(arg), context,
                                                false, node);
                            arg = xk_pg_parser_lnext(arg);
                        }
                        if (!PRETTY_PAREN(context))
                            xk_pg_parser_appendStringInfoChar(buf, ')');
                        break;

                    case OR_EXPR:
                        if (!PRETTY_PAREN(context))
                            xk_pg_parser_appendStringInfoChar(buf, '(');
                        get_rule_expr_paren(first_arg, context,
                                            false, node);
                        while (arg)
                        {
                            xk_pg_parser_appendStringInfoString(buf, " OR ");
                            get_rule_expr_paren((xk_pg_parser_Node *) xk_pg_parser_lfirst(arg), context,
                                                false, node);
                            arg = lnext(arg);
                        }
                        if (!PRETTY_PAREN(context))
                            xk_pg_parser_appendStringInfoChar(buf, ')');
                        break;

                    case NOT_EXPR:
                        if (!PRETTY_PAREN(context))
                            xk_pg_parser_appendStringInfoChar(buf, '(');
                        xk_pg_parser_appendStringInfoString(buf, "NOT ");
                        get_rule_expr_paren(first_arg, context,
                                            false, node);
                        if (!PRETTY_PAREN(context))
                            xk_pg_parser_appendStringInfoChar(buf, ')');
                        break;

                    default:
                        printf("ERROR, unrecognized boolop: %d\n",
                             (int32_t) expr->boolop);
                }
            }
            break;
        default:
            printf("ERROR, unrecognized node type: %d\n", (int32_t) nodeTag(node));
            break;
    }
}
