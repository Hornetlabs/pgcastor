    xk_pg_parser_AttrNumber *partattrs;        /* attribute numbers of columns in the
                                 * partition key or 0 if it's an expr */
    xk_pg_parser_List       *partexprs;        /* list of expressions in the partitioning
                                 * key, one for each zero-valued partattrs */

    uint32_t           *partopfamily;    /* OIDs of operator families */
