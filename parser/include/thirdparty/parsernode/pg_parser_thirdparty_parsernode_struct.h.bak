typedef struct xk_pg_parser_FdwRoutine
{
    xk_pg_parser_NodeTag        type;

    /* Functions for scanning foreign tables */
    xk_pg_parser_GetForeignRelSize_function GetForeignRelSize;
    xk_pg_parser_GetForeignPaths_function GetForeignPaths;
    xk_pg_parser_GetForeignPlan_function GetForeignPlan;
    xk_pg_parser_BeginForeignScan_function BeginForeignScan;
    xk_pg_parser_IterateForeignScan_function IterateForeignScan;
    xk_pg_parser_ReScanForeignScan_function ReScanForeignScan;
    xk_pg_parser_EndForeignScan_function EndForeignScan;

    /*
     * Remaining functions are optional.  Set the pointer to NULL for any that
     * are not provided.
     */

    /* Functions for remote-join planning */
    xk_pg_parser_GetForeignJoinPaths_function GetForeignJoinPaths;

    /* Functions for remote upper-relation (post scan/join) planning */
    xk_pg_parser_GetForeignUpperPaths_function GetForeignUpperPaths;

    /* Functions for updating foreign tables */
    xk_pg_parser_AddForeignUpdateTargets_function AddForeignUpdateTargets;
    xk_pg_parser_PlanForeignModify_function PlanForeignModify;
    xk_pg_parser_BeginForeignModify_function BeginForeignModify;
    xk_pg_parser_ExecForeignInsert_function ExecForeignInsert;
    xk_pg_parser_ExecForeignUpdate_function ExecForeignUpdate;
    xk_pg_parser_ExecForeignDelete_function ExecForeignDelete;
    xk_pg_parser_EndForeignModify_function EndForeignModify;
    xk_pg_parser_BeginForeignInsert_function BeginForeignInsert;
    xk_pg_parser_EndForeignInsert_function EndForeignInsert;
    xk_pg_parser_IsForeignRelUpdatable_function IsForeignRelUpdatable;
    xk_pg_parser_PlanDirectModify_function PlanDirectModify;
    xk_pg_parser_BeginDirectModify_function BeginDirectModify;
    xk_pg_parser_IterateDirectModify_function IterateDirectModify;
    xk_pg_parser_EndDirectModify_function EndDirectModify;

    /* Functions for SELECT FOR UPDATE/SHARE row locking */
    xk_pg_parser_GetForeignRowMarkType_function GetForeignRowMarkType;
    xk_pg_parser_RefetchForeignRow_function RefetchForeignRow;
    xk_pg_parser_RecheckForeignScan_function RecheckForeignScan;

    /* Support functions for EXPLAIN */
    xk_pg_parser_ExplainForeignScan_function ExplainForeignScan;
    xk_pg_parser_ExplainForeignModify_function ExplainForeignModify;
    xk_pg_parser_ExplainDirectModify_function ExplainDirectModify;

    /* Support functions for ANALYZE */
    xk_pg_parser_AnalyzeForeignTable_function AnalyzeForeignTable;

    /* Support functions for IMPORT FOREIGN SCHEMA */
    xk_pg_parser_ImportForeignSchema_function ImportForeignSchema;

    /* Support functions for parallelism under Gather node */
    xk_pg_parser_IsForeignScanParallelSafe_function IsForeignScanParallelSafe;
    xk_pg_parser_EstimateDSMForeignScan_function EstimateDSMForeignScan;
    xk_pg_parser_InitializeDSMForeignScan_function InitializeDSMForeignScan;
    xk_pg_parser_ReInitializeDSMForeignScan_function ReInitializeDSMForeignScan;
    xk_pg_parser_InitializeWorkerForeignScan_function InitializeWorkerForeignScan;
    xk_pg_parser_ShutdownForeignScan_function ShutdownForeignScan;

    /* Support functions for path reparameterization. */
    xk_pg_parser_ReparameterizeForeignPathByChild_function ReparameterizeForeignPathByChild;
} xk_pg_parser_FdwRoutine;
#endif

typedef struct xk_pg_parser_FdwRoutine xk_pg_parser_FdwRoutine;

typedef struct xk_pg_parser_RelationData
{
    uint32_t rd_node;        /* relation physical identifier */
    /* use "struct" here to avoid needing to include smgr.h: */
    struct xk_pg_parser_SMgrRelationData *rd_smgr;    /* cached file handle, or NULL */
    int32_t            rd_refcnt;        /* reference count */
    int32_t    rd_backend;        /* owning backend id, if temporary relation */
    bool        rd_islocaltemp; /* rel is a temp rel of this session */
    bool        rd_isnailed;    /* rel is nailed in cache */
    bool        rd_isvalid;        /* relcache entry is valid */
    bool        rd_indexvalid;    /* is rd_indexlist valid? (also rd_pkindex and
                                 * rd_replidindex) */
    bool        rd_statvalid;    /* is rd_statlist valid? */

    /*----------
     * rd_createSubid is the ID of the highest subtransaction the rel has
     * survived into; or zero if the rel was not created in the current top
     * transaction.  This can be now be relied on, whereas previously it could
     * be "forgotten" in earlier releases. Likewise, rd_newRelfilenodeSubid is
     * the ID of the highest subtransaction the relfilenode change has
     * survived into, or zero if not changed in the current transaction (or we
     * have forgotten changing it). rd_newRelfilenodeSubid can be forgotten
     * when a relation has multiple new relfilenodes within a single
     * transaction, with one of them occurring in a subsequently aborted
     * subtransaction, e.g.
     *        BEGIN;
     *        TRUNCATE t;
     *        SAVEPOINT save;
     *        TRUNCATE t;
     *        ROLLBACK TO save;
     *        -- rd_newRelfilenodeSubid is now forgotten
     */
    uint32_t rd_createSubid;    /* rel was created in current xact */
    uint32_t rd_newRelfilenodeSubid;    /* new relfilenode assigned in
                                                 * current xact */

    xk_pg_parser_FormData_pg_class rd_rel;        /* RELATION tuple */
    xk_pg_parser_TupleDesc    rd_att;            /* tuple descriptor */
    uint32_t            rd_id;            /* relation's object id */
    xk_pg_parser_LockInfoData rd_lockInfo;    /* lock mgr's info for locking relation */
    xk_pg_parser_RuleLock   *rd_rules;        /* rewrite rules */
    xk_pg_parser_MemoryContext rd_rulescxt;    /* private memory cxt for rd_rules, if any */
    xk_pg_parser_TriggerDesc *trigdesc;        /* Trigger info, or NULL if rel has none */
    /* use "struct" here to avoid needing to include rowsecurity.h: */
    struct xk_pg_parser_RowSecurityDesc *rd_rsdesc;    /* row security policies, or NULL */

    /* data managed by RelationGetFKeyList: */
    xk_pg_parser_List       *rd_fkeylist;    /* list of ForeignKeyCacheInfo (see below) */
    bool        rd_fkeyvalid;    /* true if list has been computed */

    struct xk_pg_parser_PartitionKeyData *rd_partkey;    /* partition key, or NULL */
    xk_pg_parser_MemoryContext rd_partkeycxt;    /* private context for rd_partkey, if any */
    struct xk_pg_parser_PartitionDescData *rd_partdesc;    /* partitions, or NULL */
    xk_pg_parser_MemoryContext rd_pdcxt;        /* private context for rd_partdesc, if any */
    xk_pg_parser_List       *rd_partcheck;    /* partition CHECK quals */
    bool        rd_partcheckvalid;    /* true if list has been computed */
    xk_pg_parser_MemoryContext rd_partcheckcxt;    /* private cxt for rd_partcheck, if any */

    /* data managed by RelationGetIndexList: */
    xk_pg_parser_List       *rd_indexlist;    /* list of OIDs of indexes on relation */
    uint32_t            rd_pkindex;        /* OID of primary key, if any */
    uint32_t            rd_replidindex; /* OID of replica identity index, if any */

    /* data managed by RelationGetStatExtList: */
    xk_pg_parser_List       *rd_statlist;    /* list of OIDs of extended stats */

    /* data managed by RelationGetIndexAttrBitmap: */
    xk_pg_parser_Bitmapset  *rd_indexattr;    /* identifies columns used in indexes */
    xk_pg_parser_Bitmapset  *rd_keyattr;        /* cols that can be ref'd by foreign keys */
    xk_pg_parser_Bitmapset  *rd_pkattr;        /* cols included in primary key */
    xk_pg_parser_Bitmapset  *rd_idattr;        /* included in replica identity index */

    xk_pg_parser_PublicationActions *rd_pubactions;    /* publication actions */

    /*
     * rd_options is set whenever rd_rel is loaded into the relcache entry.
     * Note that you can NOT look into rd_rel for this data.  NULL means "use
     * defaults".
     */
    xk_pg_parser_bytea       *rd_options;        /* parsed pg_class.reloptions */

    /*
     * Oid of the handler for this relation. For an index this is a function
     * returning IndexAmRoutine, for table like relations a function returning
     * TableAmRoutine.  This is stored separately from rd_indam, rd_tableam as
     * its lookup requires syscache access, but during relcache bootstrap we
     * need to be able to initialize rd_tableam without syscache lookups.
     */
    uint32_t            rd_amhandler;    /* OID of index AM's handler function */

    /*
     * Table access method.
     */
    const struct xk_pg_parser_TableAmRoutine *rd_tableam;

    /* These are non-NULL only for an index relation: */
    xk_pg_parser_FormData_pg_index rd_index;        /* pg_index tuple describing this index */
    /* use "struct" here to avoid needing to include htup.h: */
    struct xk_pg_parser_HeapTupleData *rd_indextuple;    /* all of pg_index tuple */

    /*
     * index access support info (used only for an index relation)
     *
     * Note: only default support procs for each opclass are cached, namely
     * those with lefttype and righttype equal to the opclass's opcintype. The
     * arrays are indexed by support function number, which is a sufficient
     * identifier given that restriction.
     */
    xk_pg_parser_MemoryContext rd_indexcxt;    /* private memory cxt for this stuff */
    /* use "struct" here to avoid needing to include amapi.h: */
    struct IndexAmRoutine *rd_indam;    /* index AM's API struct */
    uint32_t           *rd_opfamily;    /* OIDs of op families for each index col */
    uint32_t           *rd_opcintype;    /* OIDs of opclass declared input data types */
    xk_pg_parser_uint32_tedure *rd_support;    /* OIDs of support procedures */
    xk_pg_parser_FmgrInfo   *rd_supportinfo; /* lookup info for support procedures */
    int16_t       *rd_indoption;    /* per-column AM-specific flags */
    xk_pg_parser_List       *rd_indexprs;    /* index expression trees, if any */
    xk_pg_parser_List       *rd_indpred;        /* index predicate tree, if any */
    uint32_t           *rd_exclops;        /* OIDs of exclusion operators, if any */
    uint32_t           *rd_exclprocs;    /* OIDs of exclusion ops' procs, if any */
    uint16_t       *rd_exclstrats;    /* exclusion ops' strategy numbers, if any */
    uint32_t           *rd_indcollation;    /* OIDs of index collations */

    /*
     * rd_amcache is available for index and table AMs to cache private data
     * about the relation.  This must be just a cache since it may get reset
     * at any time (in particular, it will get reset by a relcache inval
     * message for the relation).  If used, it must point to a single memory
     * chunk palloc'd in CacheMemoryContext, or in rd_indexcxt for an index
     * relation.  A relcache reset will include freeing that chunk and setting
     * rd_amcache = NULL.
     */
    void       *rd_amcache;        /* available for use by index/table AM */

    /*
     * foreign-table support
     *
     * rd_fdwroutine must point to a single memory chunk palloc'd in
     * CacheMemoryContext.  It will be freed and reset to NULL on a relcache
     * reset.
     */

    /* use "struct" here to avoid needing to include fdwapi.h: */
    struct xk_pg_parser_FdwRoutine *rd_fdwroutine;    /* cached function pointers, or NULL */

    /*
     * Hack for CLUSTER, rewriting ALTER TABLE, etc: when writing a new
     * version of a table, we need to make any toast pointers inserted into it
     * have the existing toast table's OID, not the OID of the transient toast
     * table.  If rd_toastoid isn't InvalidOid, it is the OID to place in
     * toast pointers inserted into this rel.  (Note it's set on the new
     * version of the main heap, not the toast table itself.)  This also
     * causes toast_save_datum() to try to preserve toast value OIDs.
     */
    uint32_t            rd_toastoid;    /* Real TOAST table's OID, or InvalidOid */

    /* use "struct" here to avoid needing to include pgstat.h: */
    struct xk_pg_parser_PgStat_TableStatus *pgstat_info; /* statistics collection area */
} xk_pg_parser_RelationData;

typedef struct xk_pg_parser_ExecRowMark
{
    xk_pg_parser_Relation    relation;        /* opened and suitably locked relation */
    uint32_t            relid;            /* its OID (or InvalidOid, if subquery) */
    xk_pg_parser_Index        rti;            /* its range table index */
    xk_pg_parser_Index        prti;            /* parent range table index, if child */
    xk_pg_parser_Index        rowmarkId;        /* unique identifier for resjunk columns */
    xk_pg_parser_RowMarkType markType;        /* see enum in nodes/plannodes.h */
    xk_pg_parser_LockClauseStrength strength;    /* LockingClause's strength, or LCS_NONE */
    xk_pg_parser_LockWaitPolicy waitPolicy;    /* NOWAIT and SKIP LOCKED */
    bool        ermActive;        /* is this mark relevant for current tuple? */
    xk_pg_parser_ItemPointerData curCtid;    /* ctid of currently locked tuple, if any */
    void       *ermExtra;        /* available for use by relation source node */
} xk_pg_parser_ExecRowMark;

typedef struct xk_pg_parser_PartitionRoutingInfo
{
    /*
     * Map for converting tuples in root partitioned table format into
     * partition format, or NULL if no conversion is required.
     */
    xk_pg_parser_TupleConversionMap *pi_RootToPartitionMap;

    /*
     * Map for converting tuples in partition format into the root partitioned
     * table format, or NULL if no conversion is required.
     */
    xk_pg_parser_TupleConversionMap *pi_PartitionToRootMap;

    /*
     * Slot to store tuples in partition format, or NULL when no translation
     * is required between root and partition.
     */
    xk_pg_parser_TupleTableSlot *pi_PartitionTupleSlot;
} xk_pg_parser_PartitionRoutingInfo;

#define XK_PG_PARSER_MAX_BUFFERED_TUPLES 1000

typedef struct xk_pg_parser_BulkInsertStateData
{
    xk_pg_parser_BufferAccessStrategy strategy;    /* our BULKWRITE strategy object */
    xk_pg_parser_Buffer        current_buf;    /* current insertion target page */
} xk_pg_parser_BulkInsertStateData;

typedef struct xk_pg_parser_BulkInsertStateData *xk_pg_parser_BulkInsertState;

typedef struct xk_pg_parser_CopyMultiInsertBuffer
{
    xk_pg_parser_TupleTableSlot *slots[XK_PG_PARSER_MAX_BUFFERED_TUPLES]; /* Array to store tuples */
    xk_pg_parser_ResultRelInfo *resultRelInfo;    /* ResultRelInfo for 'relid' */
    xk_pg_parser_BulkInsertState bistate;    /* BulkInsertState for this rel */
    int32_t            nused;            /* number of 'slots' containing tuples */
    uint64_t        linenos[XK_PG_PARSER_MAX_BUFFERED_TUPLES];    /* Line # of tuple in copy
                                                 * stream */
} xk_pg_parser_CopyMultiInsertBuffer;

typedef xk_pg_parser_Relation *xk_pg_parser_RelationPtr;
typedef struct timespec xk_pg_parser_instr_time;

typedef struct xk_pg_parser_BufferUsage
{
    long        shared_blks_hit;    /* # of shared buffer hits */
    long        shared_blks_read;    /* # of shared disk blocks read */
    long        shared_blks_dirtied;    /* # of shared blocks dirtied */
    long        shared_blks_written;    /* # of shared disk blocks written */
    long        local_blks_hit; /* # of local buffer hits */
    long        local_blks_read;    /* # of local disk blocks read */
    long        local_blks_dirtied; /* # of shared blocks dirtied */
    long        local_blks_written; /* # of local disk blocks written */
    long        temp_blks_read; /* # of temp blocks read */
    long        temp_blks_written;    /* # of temp blocks written */
    xk_pg_parser_instr_time    blk_read_time;    /* time spent reading */
    xk_pg_parser_instr_time    blk_write_time; /* time spent writing */
} xk_pg_parser_BufferUsage;

typedef struct xk_pg_parser_Instrumentation
{
    /* Parameters set at node creation: */
    bool        need_timer;        /* true if we need timer data */
    bool        need_bufusage;    /* true if we need buffer usage data */
    /* Info about current plan cycle: */
    bool        running;        /* true if we've completed first tuple */
    xk_pg_parser_instr_time    starttime;        /* Start time of current iteration of node */
    xk_pg_parser_instr_time    counter;        /* Accumulated runtime for this node */
    double        firsttuple;        /* Time for first tuple of this cycle */
    double        tuplecount;        /* Tuples emitted so far this cycle */
    xk_pg_parser_BufferUsage bufusage_start; /* Buffer usage at start */
    /* Accumulated statistics across all completed cycles: */
    double        startup;        /* Total startup time (in seconds) */
    double        total;            /* Total total time (in seconds) */
    double        ntuples;        /* Total tuples produced */
    double        ntuples2;        /* Secondary node-specific tuple counter */
    double        nloops;            /* # of run cycles for this node */
    double        nfiltered1;        /* # tuples removed by scanqual or joinqual */
    double        nfiltered2;        /* # tuples removed by "other" quals */
    xk_pg_parser_BufferUsage bufusage;        /* Total buffer usage */
} xk_pg_parser_Instrumentation;

typedef struct xk_pg_parser_OnConflictSetState
{
    xk_pg_parser_NodeTag        type;

    xk_pg_parser_TupleTableSlot *oc_Existing;    /* slot to store existing target tuple in */
    xk_pg_parser_TupleTableSlot *oc_ProjSlot;    /* CONFLICT ... SET ... projection target */
    xk_pg_parser_ProjectionInfo *oc_ProjInfo;    /* for ON CONFLICT DO UPDATE SET */
    xk_pg_parser_ExprState  *oc_WhereClause; /* state for the WHERE clause */
} xk_pg_parser_OnConflictSetState;

typedef struct xk_pg_parser_ResultRelInfo
{
    xk_pg_parser_NodeTag        type;

    /* result relation's range table index, or 0 if not in range table */
    xk_pg_parser_Index        ri_RangeTableIndex;

    /* relation descriptor for result relation */
    xk_pg_parser_Relation    ri_RelationDesc;

    /* # of indices existing on result relation */
    int32_t            ri_NumIndices;

    /* array of relation descriptors for indices */
    xk_pg_parser_RelationPtr ri_IndexRelationDescs;

    /* array of key/attr info for indices */
    xk_pg_parser_IndexInfo **ri_IndexRelationInfo;

    /* triggers to be fired, if any */
    xk_pg_parser_TriggerDesc *ri_TrigDesc;

    /* cached lookup info for trigger functions */
    xk_pg_parser_FmgrInfo   *ri_TrigFunctions;

    /* array of trigger WHEN expr states */
    xk_pg_parser_ExprState **ri_TrigWhenExprs;

    /* optional runtime measurements for triggers */
    xk_pg_parser_Instrumentation *ri_TrigInstrument;

    /* On-demand created slots for triggers / returning processing */
    xk_pg_parser_TupleTableSlot *ri_ReturningSlot;    /* for trigger output tuples */
    xk_pg_parser_TupleTableSlot *ri_TrigOldSlot; /* for a trigger's old tuple */
    xk_pg_parser_TupleTableSlot *ri_TrigNewSlot; /* for a trigger's new tuple */

    /* FDW callback functions, if foreign table */
    struct xk_pg_parser_FdwRoutine *ri_FdwRoutine;

    /* available to save private state of FDW */
    void       *ri_FdwState;

    /* true when modifying foreign table directly */
    bool        ri_usesFdwDirectModify;

    /* list of WithCheckOption's to be checked */
    xk_pg_parser_List       *ri_WithCheckOptions;

    /* list of WithCheckOption expr states */
    xk_pg_parser_List       *ri_WithCheckOptionExprs;

    /* array of constraint-checking expr states */
    xk_pg_parser_ExprState **ri_ConstraintExprs;

    /* array of stored generated columns expr states */
    xk_pg_parser_ExprState **ri_GeneratedExprs;

    /* for removing junk attributes from tuples */
    xk_pg_parser_JunkFilter *ri_junkFilter;

    /* list of RETURNING expressions */
    xk_pg_parser_List       *ri_returningList;

    /* for computing a RETURNING list */
    xk_pg_parser_ProjectionInfo *ri_projectReturning;

    /* list of arbiter indexes to use to check conflicts */
    xk_pg_parser_List       *ri_onConflictArbiterIndexes;

    /* ON CONFLICT evaluation state */
    xk_pg_parser_OnConflictSetState *ri_onConflict;

    /* partition check expression */
    xk_pg_parser_List       *ri_PartitionCheck;

    /* partition check expression state */
    xk_pg_parser_ExprState  *ri_PartitionCheckExpr;

    /*
     * RootResultRelInfo gives the target relation mentioned in the query, if
     * it's a partitioned table. It is not set if the target relation
     * mentioned in the query is an inherited table, nor when tuple routing is
     * not needed.
     */
    struct xk_pg_parser_ResultRelInfo *ri_RootResultRelInfo;

    /* Additional information specific to partition tuple routing */
    struct xk_pg_parser_PartitionRoutingInfo *ri_PartitionInfo;

    /* For use by copy.c when performing multi-inserts */
    struct xk_pg_parser_CopyMultiInsertBuffer *ri_CopyMultiInsertBuffer;
} xk_pg_parser_ResultRelInfo;

typedef struct xk_pg_parser_HASHELEMENT
{
    struct xk_pg_parser_HASHELEMENT *link;    /* link to next entry in same bucket */
    uint32_t        hashvalue;        /* hash function result for this entry */
} xk_pg_parser_HASHELEMENT;

typedef struct xk_pg_parser_FreeListData
{
    xk_pg_parser_slock_t        mutex;            /* spinlock for this freelist */
    long        nentries;        /* number of entries in associated buckets */
    xk_pg_parser_HASHELEMENT *freeList;        /* chain of free elements */
} xk_pg_parser_FreeListData;

#define XK_PG_PARSER_NUM_FREELISTS 32

typedef struct xk_pg_parser_HASHHDR
{
    /*
     * The freelist can become a point of contention in high-concurrency hash
     * tables, so we use an array of freelists, each with its own mutex and
     * nentries count, instead of just a single one.  Although the freelists
     * normally operate independently, we will scavenge entries from freelists
     * other than a hashcode's default freelist when necessary.
     *
     * If the hash table is not partitioned, only freeList[0] is used and its
     * spinlock is not used at all; callers' locking is assumed sufficient.
     */
    xk_pg_parser_FreeListData freeList[XK_PG_PARSER_NUM_FREELISTS];

    /* These fields can change, but not in a partitioned table */
    /* Also, dsize can't change in a shared table, even if unpartitioned */
    long        dsize;            /* directory size */
    long        nsegs;            /* number of allocated segments (<= dsize) */
    uint32_t        max_bucket;        /* ID of maximum bucket in use */
    uint32_t        high_mask;        /* mask to modulo into entire table */
    uint32_t        low_mask;        /* mask to modulo into lower half of table */

    /* These fields are fixed at hashtable creation */
    size_t        keysize;        /* hash key length in bytes */
    size_t        entrysize;        /* total user element size in bytes */
    long        num_partitions; /* # partitions (must be power of 2), or 0 */
    long        ffactor;        /* target fill factor */
    long        max_dsize;        /* 'dsize' limit if directory is fixed size */
    long        ssize;            /* segment size --- must be power of 2 */
    int32_t            sshift;            /* segment shift = log2(ssize) */
    int32_t            nelem_alloc;    /* number of entries to allocate at once */
}xk_pg_parser_HASHHDR;

typedef xk_pg_parser_HASHELEMENT *xk_pg_parser_HASHBUCKET;

typedef xk_pg_parser_HASHBUCKET *xk_pg_parser_HASHSEGMENT;

typedef uint32_t (*xk_pg_parser_HashValueFunc) (const void *key, size_t keysize);

typedef int32_t (*xk_pg_parser_HashCompareFunc) (const void *key1, const void *key2,
                                size_t keysize);

typedef void *(*xk_pg_parser_HashCopyFunc) (void *dest, const void *src, size_t keysize);

typedef void *(*xk_pg_parser_HashAllocFunc) (size_t request);

typedef struct xk_pg_parser_HTAB
{
    xk_pg_parser_HASHHDR    *hctl;            /* => shared control information */
    xk_pg_parser_HASHSEGMENT *dir;            /* directory of segment starts */
    xk_pg_parser_HashValueFunc hash;            /* hash function */
    xk_pg_parser_HashCompareFunc match;        /* key comparison function */
    xk_pg_parser_HashCopyFunc keycopy;        /* key copying function */
    xk_pg_parser_HashAllocFunc alloc;        /* memory allocator */
    xk_pg_parser_MemoryContext hcxt;            /* memory context if default allocator used */
    char       *tabname;        /* table name (for error messages) */
    bool        isshared;        /* true if table is in shared memory */
    bool        isfixed;        /* if true, don't enlarge */

    /* freezing a shared table isn't allowed, so we can keep state here */
    bool        frozen;            /* true = no more inserts allowed */

    /* We keep local copies of these fixed values to reduce contention */
    size_t        keysize;        /* hash key length in bytes */
    long        ssize;            /* segment size --- must be power of 2 */
    int32_t            sshift;            /* segment shift = log2(ssize) */
}xk_pg_parser_HTAB;

typedef struct xk_pg_parser_PartitionDirectoryData
{
    xk_pg_parser_MemoryContext pdir_mcxt;
    xk_pg_parser_HTAB       *pdir_hash;
}xk_pg_parser_PartitionDirectoryData;

typedef struct xk_pg_parser_PartitionDirectoryData *xk_pg_parser_PartitionDirectory;

typedef struct xk_pg_parser_ExecAuxRowMark
{
    xk_pg_parser_ExecRowMark *rowmark;        /* related entry in es_rowmarks */
    xk_pg_parser_AttrNumber    ctidAttNo;        /* resno of ctid junk attribute, if any */
    xk_pg_parser_AttrNumber    toidAttNo;        /* resno of tableoid junk attribute, if any */
    xk_pg_parser_AttrNumber    wholeAttNo;        /* resno of whole-row junk attribute, if any */
} xk_pg_parser_ExecAuxRowMark;

typedef struct xk_pg_parser_EPQState
{
    /* Initialized at EvalPlanQualInit() time: */

    xk_pg_parser_EState       *parentestate;    /* main query's EState */
    int32_t            epqParam;        /* ID of Param to force scan node re-eval */

    /*
     * Tuples to be substituted by scan nodes. They need to set up, before
     * calling EvalPlanQual()/EvalPlanQualNext(), into the slot returned by
     * EvalPlanQualSlot(scanrelid). The array is indexed by scanrelid - 1.
     */
    xk_pg_parser_List       *tuple_table;    /* tuple table for relsubs_slot */
    xk_pg_parser_TupleTableSlot **relsubs_slot;

    /*
     * Initialized by EvalPlanQualInit(), may be changed later with
     * EvalPlanQualSetPlan():
     */

    xk_pg_parser_Plan       *plan;            /* plan tree to be executed */
    xk_pg_parser_List       *arowMarks;        /* ExecAuxRowMarks (non-locking only) */


    /*
     * The original output tuple to be rechecked.  Set by
     * EvalPlanQualSetSlot(), before EvalPlanQualNext() or EvalPlanQual() may
     * be called.
     */
    xk_pg_parser_TupleTableSlot *origslot;


    /* Initialized or reset by EvalPlanQualBegin(): */

    xk_pg_parser_EState       *recheckestate;    /* EState for EPQ execution, see above */

    /*
     * Rowmarks that can be fetched on-demand using
     * EvalPlanQualFetchRowMark(), indexed by scanrelid - 1. Only non-locking
     * rowmarks.
     */
    xk_pg_parser_ExecAuxRowMark **relsubs_rowmark;

    /*
     * True if a relation's EPQ tuple has been fetched for relation, indexed
     * by scanrelid - 1.
     */
    bool       *relsubs_done;

    struct xk_pg_parser_PlanState  *recheckplanstate;    /* EPQ specific exec nodes, for ->plan */
} xk_pg_parser_EPQState;

typedef size_t xk_pg_parser_dsa_segment_index;

typedef struct xk_pg_parser_dsa_segment_header
{
    /* Sanity check magic value. */
    uint32_t        magic;
    /* Total number of pages in this segment (excluding metadata area). */
    size_t        usable_pages;
    /* Total size of this segment in bytes. */
    size_t        size;

    /*
     * Index of the segment that precedes this one in the same segment bin, or
     * DSA_SEGMENT_INDEX_NONE if this is the first one.
     */
    xk_pg_parser_dsa_segment_index prev;

    /*
     * Index of the segment that follows this one in the same segment bin, or
     * DSA_SEGMENT_INDEX_NONE if this is the last one.
     */
    xk_pg_parser_dsa_segment_index next;
    /* The index of the bin that contains this segment. */
    size_t        bin;

    /*
     * A flag raised to indicate that this segment is being returned to the
     * operating system and has been unpinned.
     */
    bool        freed;
} xk_pg_parser_dsa_segment_header;

typedef uint32_t xk_pg_parser_dsm_handle;

typedef xk_pg_parser_dsm_handle xk_pg_parser_dsa_handle;

#define XK_PG_PARSER_SIZEOF_DSA_POINTER 8
#define XK_PG_PARSER_DSA_OFFSET_WIDTH 40

#define XK_PG_PARSER_DSA_MAX_SEGMENTS \
    Min(1024, (1 << ((XK_PG_PARSER_SIZEOF_DSA_POINTER * 8) - XK_PG_PARSER_DSA_OFFSET_WIDTH)))
#define XK_PG_PARSER_DSA_NUM_SEGMENT_BINS 16

typedef uint64_t xk_pg_parser_dsa_pointer;

typedef struct xk_pg_parser_dsa_area_span
{
    xk_pg_parser_dsa_pointer pool;            /* Containing pool. */
    xk_pg_parser_dsa_pointer prevspan;        /* Previous span. */
    xk_pg_parser_dsa_pointer nextspan;        /* Next span. */
    xk_pg_parser_dsa_pointer start;            /* Starting address. */
    size_t        npages;            /* Length of span in pages. */
    uint16_t        size_class;        /* Size class. */
    uint16_t        ninitialized;    /* Maximum number of objects ever allocated. */
    uint16_t        nallocatable;    /* Number of objects currently allocatable. */
    uint16_t        firstfree;        /* First object on free list. */
    uint16_t        nmax;            /* Maximum number of objects ever possible. */
    uint16_t        fclass;            /* Current fullness class. */
} xk_pg_parser_dsa_area_span;

static const uint16_t dsa_size_classes[] = {
    sizeof(xk_pg_parser_dsa_area_span), 0,    /* special size classes */
    8, 16, 24, 32, 40, 48, 56, 64,    /* 8 classes separated by 8 bytes */
    80, 96, 112, 128,            /* 4 classes separated by 16 bytes */
    160, 192, 224, 256,            /* 4 classes separated by 32 bytes */
    320, 384, 448, 512,            /* 4 classes separated by 64 bytes */
    640, 768, 896, 1024,        /* 4 classes separated by 128 bytes */
    1280, 1560, 1816, 2048,        /* 4 classes separated by ~256 bytes */
    2616, 3120, 3640, 4096,        /* 4 classes separated by ~512 bytes */
    5456, 6552, 7280, 8192        /* 4 classes separated by ~1024 bytes */
};
#define xk_pg_parser_lengthof(array) (sizeof (array) / sizeof ((array)[0]))
#define XK_PG_PARSER_DSA_NUM_SIZE_CLASSES                xk_pg_parser_lengthof(dsa_size_classes)
#define XK_PG_PARSER_DSA_FULLNESS_CLASSES        4

typedef struct xk_pg_parser_dsa_area_pool
{
    /* A lock protecting access to this pool. */
    xk_pg_parser_LWLock        lock;
    /* A set of linked lists of spans, arranged by fullness. */
    xk_pg_parser_dsa_pointer spans[XK_PG_PARSER_DSA_FULLNESS_CLASSES];
    /* Should we pad this out to a cacheline boundary? */
} xk_pg_parser_dsa_area_pool;

typedef struct xk_pg_parser_dsa_area_control
{
    /* The segment header for the first segment. */
    xk_pg_parser_dsa_segment_header segment_header;
    /* The handle for this area. */
    xk_pg_parser_dsa_handle    handle;
    /* The handles of the segments owned by this area. */
    xk_pg_parser_dsm_handle    segment_handles[XK_PG_PARSER_DSA_MAX_SEGMENTS];
    /* Lists of segments, binned by maximum contiguous run of free pages. */
    xk_pg_parser_dsa_segment_index segment_bins[XK_PG_PARSER_DSA_NUM_SEGMENT_BINS];
    /* The object pools for each size class. */
    xk_pg_parser_dsa_area_pool pools[XK_PG_PARSER_DSA_NUM_SIZE_CLASSES];
    /* The total size of all active segments. */
    size_t        total_segment_size;
    /* The maximum total size of backing storage we are allowed. */
    size_t        max_total_segment_size;
    /* Highest used segment index in the history of this area. */
    xk_pg_parser_dsa_segment_index high_segment_index;
    /* The reference count for this area. */
    int32_t            refcnt;
    /* A flag indicating that this area has been pinned. */
    bool        pinned;
    /* The number of times that segments have been freed. */
    size_t        freed_segment_counter;
    /* The LWLock tranche ID. */
    int32_t            lwlock_tranche_id;
    /* The general lock (protects everything except object pools). */
    xk_pg_parser_LWLock        lock;
} xk_pg_parser_dsa_area_control;

typedef struct xk_pg_parser_slist_head
{
    xk_pg_parser_slist_node    head;
} xk_pg_parser_slist_head;

typedef struct xk_pg_parser_dsm_segment
{
    xk_pg_parser_dlist_node    node;            /* List link in dsm_segment_list. */
    xk_pg_parser_ResourceOwner resowner;        /* Resource owner. */
    xk_pg_parser_dsm_handle    handle;            /* Segment name. */
    uint32_t        control_slot;    /* Slot in control segment. */
    void       *impl_private;    /* Implementation-specific private data. */
    void       *mapped_address; /* Mapping address, or NULL if unmapped. */
    size_t        mapped_size;    /* Size of our mapping. */
    xk_pg_parser_slist_head    on_detach;        /* On-detach callbacks. */
}xk_pg_parser_dsm_segment;

#if 0
#define xk_pg_parser_relptr(type) union { type *relptr_type; size_t relptr_off; }
#define xk_pg_parser_relptr_declare(type, relptrtype) \
    typedef xk_pg_parser_relptr(type) relptrtype

struct xk_pg_parser_FreePageBtree
{
    FreePageBtreeHeader hdr;
    union
    {
        FreePageBtreeInternalKey internal_key[FPM_ITEMS_PER_INTERNAL_PAGE];
        FreePageBtreeLeafKey leaf_key[FPM_ITEMS_PER_LEAF_PAGE];
    }            u;
};

xk_pg_parser_relptr_declare(xk_pg_parser_FreePageBtree, RelptrFreePageBtree);
xk_pg_parser_relptr_declare(xk_pg_parser_FreePageManager, RelptrFreePageManager);
xk_pg_parser_relptr_declare(xk_pg_parser_FreePageSpanLeader, RelptrFreePageSpanLeader);

struct xk_pg_parser_FreePageManager
{
    xk_pg_parser_RelptrFreePageManager self;
    xk_pg_parser_RelptrFreePageBtree btree_root;
    xk_pg_parser_RelptrFreePageSpanLeader btree_recycle;
    unsigned    btree_depth;
    unsigned    btree_recycle_count;
    size_t        singleton_first_page;
    size_t        singleton_npages;
    size_t        contiguous_pages;
    bool        contiguous_pages_dirty;
    xk_pg_parser_RelptrFreePageSpanLeader freelist[xk_pg_parser_FPM_NUM_FREELISTS];
};
#endif

typedef struct xk_pg_parser_FreePageManager xk_pg_parser_FreePageManager;
typedef struct xk_pg_parser_dsa_segment_map
{
    xk_pg_parser_dsm_segment *segment;        /* DSM segment */
    char       *mapped_address; /* Address at which segment is mapped */
    xk_pg_parser_dsa_segment_header *header; /* Header (same as mapped_address) */
    xk_pg_parser_FreePageManager *fpm;        /* Free page manager within segment. */
    xk_pg_parser_dsa_pointer *pagemap;        /* Page map within segment. */
} xk_pg_parser_dsa_segment_map;


typedef struct xk_pg_parser_dsa_area
{
    /* Pointer to the control object in shared memory. */
    xk_pg_parser_dsa_area_control *control;

    /* Has the mapping been pinned? */
    bool        mapping_pinned;

    /*
     * This backend's array of segment maps, ordered by segment index
     * corresponding to control->segment_handles.  Some of the area's segments
     * may not be mapped in this backend yet, and some slots may have been
     * freed and need to be detached; these operations happen on demand.
     */
    xk_pg_parser_dsa_segment_map segment_maps[XK_PG_PARSER_DSA_MAX_SEGMENTS];

    /* The highest segment index this backend has ever mapped. */
    xk_pg_parser_dsa_segment_index high_segment_index;

    /* The last observed freed_segment_counter. */
    size_t        freed_segment_counter;
}xk_pg_parser_dsa_area;

typedef struct xk_pg_parser_JitContext xk_pg_parser_JitContext;
typedef struct xk_pg_parser_JitInstrumentation xk_pg_parser_JitInstrumentation;

typedef struct xk_pg_parser_EState
{
    xk_pg_parser_NodeTag        type;

    /* Basic state for all query types: */
    xk_pg_parser_ScanDirection es_direction; /* current scan direction */
    xk_pg_parser_Snapshot    es_snapshot;    /* time qual to use */
    xk_pg_parser_Snapshot    es_crosscheck_snapshot; /* crosscheck time qual for RI */
    xk_pg_parser_List       *es_range_table; /* List of RangeTblEntry */
    struct xk_pg_parser_RangeTblEntry **es_range_table_array;    /* equivalent array */
    xk_pg_parser_Index        es_range_table_size;    /* size of the range table arrays */
    xk_pg_parser_Relation   *es_relations;    /* Array of per-range-table-entry Relation
                                 * pointers, or NULL if not yet opened */
    struct xk_pg_parser_ExecRowMark **es_rowmarks;    /* Array of per-range-table-entry
                                         * ExecRowMarks, or NULL if none */
    xk_pg_parser_PlannedStmt *es_plannedstmt;    /* link to top of plan tree */
    const char *es_sourceText;    /* Source text from QueryDesc */

    xk_pg_parser_JunkFilter *es_junkFilter;    /* top-level junk filter, if any */

    /* If query can insert/delete tuples, the command ID to mark them with */
    xk_pg_parser_CommandId    es_output_cid;

    /* Info about target table(s) for insert/update/delete queries: */
    xk_pg_parser_ResultRelInfo *es_result_relations; /* array of ResultRelInfos */
    int32_t            es_num_result_relations;    /* length of array */
    xk_pg_parser_ResultRelInfo *es_result_relation_info; /* currently active array elt */

    /*
     * Info about the partition root table(s) for insert/update/delete queries
     * targeting partitioned tables.  Only leaf partitions are mentioned in
     * es_result_relations, but we need access to the roots for firing
     * triggers and for runtime tuple routing.
     */
    xk_pg_parser_ResultRelInfo *es_root_result_relations;    /* array of ResultRelInfos */
    int32_t            es_num_root_result_relations;    /* length of the array */
    xk_pg_parser_PartitionDirectory es_partition_directory;    /* for PartitionDesc lookup */

    /*
     * The following list contains ResultRelInfos created by the tuple routing
     * code for partitions that don't already have one.
     */
    xk_pg_parser_List       *es_tuple_routing_result_relations;

    /* Stuff used for firing triggers: */
    xk_pg_parser_List       *es_trig_target_relations;    /* trigger-only ResultRelInfos */

    /* Parameter info: */
    xk_pg_parser_ParamListInfo es_param_list_info;    /* values of external params */
    xk_pg_parser_ParamExecData *es_param_exec_vals;    /* values of internal params */

    xk_pg_parser_QueryEnvironment *es_queryEnv;    /* query environment */

    /* Other working state: */
    xk_pg_parser_MemoryContext es_query_cxt; /* per-query context in which EState lives */

    xk_pg_parser_List       *es_tupleTable;    /* List of TupleTableSlots */

    uint64_t        es_processed;    /* # of tuples processed */

    int32_t            es_top_eflags;    /* eflags passed to ExecutorStart */
    int32_t            es_instrument;    /* OR of InstrumentOption flags */
    bool        es_finished;    /* true when ExecutorFinish is done */

    xk_pg_parser_List       *es_exprcontexts;    /* List of ExprContexts within EState */

    xk_pg_parser_List       *es_subplanstates;    /* List of PlanState for SubPlans */

    xk_pg_parser_List       *es_auxmodifytables; /* List of secondary ModifyTableStates */

    /*
     * this ExprContext is for per-output-tuple operations, such as constraint
     * checks and index-value computations.  It will be reset for each output
     * tuple.  Note that it will be created only if needed.
     */
    xk_pg_parser_ExprContext *es_per_tuple_exprcontext;

    /*
     * If not NULL, this is an EPQState's EState. This is a field in EState
     * both to allow EvalPlanQual aware executor nodes to detect that they
     * need to perform EPQ related work, and to provide necessary information
     * to do so.
     */
    struct xk_pg_parser_EPQState *es_epq_active;

    bool        es_use_parallel_mode;    /* can we use parallel workers? */

    /* The per-query shared memory area to use for parallel execution. */
    struct xk_pg_parser_dsa_area *es_query_dsa;

    /*
     * JIT information. es_jit_flags indicates whether JIT should be performed
     * and with which options.  es_jit is created on-demand when JITing is
     * performed.
     *
     * es_jit_combined_instr is the combined, on demand allocated,
     * instrumentation from all workers. The leader's instrumentation is kept
     * separate, and is combined on demand by ExplainPrintJITSummary().
     */
    int32_t            es_jit_flags;
    struct xk_pg_parser_JitContext *es_jit;
    struct xk_pg_parser_JitInstrumentation *es_jit_worker_instr;
} xk_pg_parser_EState;

typedef xk_pg_parser_TupleTableSlot *(*xk_pg_parser_ExecProcNodeMtd) (struct xk_pg_parser_PlanState *pstate);

typedef struct xk_pg_parser_WorkerInstrumentation
{
    int32_t            num_workers;    /* # of structures that follow */
    xk_pg_parser_Instrumentation instrument[FLEXIBLE_ARRAY_MEMBER];
} xk_pg_parser_WorkerInstrumentation;

typedef struct xk_pg_parser_PlanState
{
    xk_pg_parser_NodeTag        type;

    xk_pg_parser_Plan       *plan;            /* associated Plan node */

    xk_pg_parser_EState       *state;            /* at execution time, states of individual
                                 * nodes point to one EState for the whole
                                 * top-level plan */

    xk_pg_parser_ExecProcNodeMtd ExecProcNode;    /* function to return next tuple */
    xk_pg_parser_ExecProcNodeMtd ExecProcNodeReal;    /* actual function, if above is a
                                         * wrapper */

    xk_pg_parser_Instrumentation *instrument;    /* Optional runtime stats for this node */
    xk_pg_parser_WorkerInstrumentation *worker_instrument;    /* per-worker instrumentation */

    /* Per-worker JIT instrumentation */
    struct SharedJitInstrumentation *worker_jit_instrument;

    /*
     * Common structural data for all Plan types.  These links to subsidiary
     * state trees parallel links in the associated plan tree (except for the
     * subPlan list, which does not exist in the plan tree).
     */
    xk_pg_parser_ExprState  *qual;            /* boolean qual condition */
    struct xk_pg_parser_PlanState *lefttree; /* input plan tree(s) */
    struct xk_pg_parser_PlanState *righttree;

    xk_pg_parser_List       *initPlan;        /* Init SubPlanState nodes (un-correlated expr
                                 * subselects) */
    xk_pg_parser_List       *subPlan;        /* SubPlanState nodes in my expressions */

    /*
     * State for management of parameter-change-driven rescanning
     */
    xk_pg_parser_Bitmapset  *chgParam;        /* set of IDs of changed Params */

    /*
     * Other run-time state needed by most if not all node types.
     */
    xk_pg_parser_TupleDesc    ps_ResultTupleDesc; /* node's return type */
    xk_pg_parser_TupleTableSlot *ps_ResultTupleSlot; /* slot for my result tuples */
    xk_pg_parser_ExprContext *ps_ExprContext;    /* node's expression-evaluation context */
    xk_pg_parser_ProjectionInfo *ps_ProjInfo;    /* info for doing tuple projection */

    /*
     * Scanslot's descriptor if known. This is a bit of a hack, but otherwise
     * it's hard for expression compilation to optimize based on the
     * descriptor, without encoding knowledge about all executor nodes.
     */
    xk_pg_parser_TupleDesc    scandesc;

    /*
     * Define the slot types for inner, outer and scanslots for expression
     * contexts with this state as a parent.  If *opsset is set, then
     * *opsfixed indicates whether *ops is guaranteed to be the type of slot
     * used. That means that every slot in the corresponding
     * ExprContext.ecxt_*tuple will point to a slot of that type, while
     * evaluating the expression.  If *opsfixed is false, but *ops is set,
     * that indicates the most likely type of slot.
     *
     * The scan* fields are set by ExecInitScanTupleSlot(). If that's not
     * called, nodes can initialize the fields themselves.
     *
     * If outer/inneropsset is false, the information is inferred on-demand
     * using ExecGetResultSlotOps() on ->righttree/lefttree, using the
     * corresponding node's resultops* fields.
     *
     * The result* fields are automatically set when ExecInitResultSlot is
     * used (be it directly or when the slot is created by
     * ExecAssignScanProjectionInfo() /
     * ExecConditionalAssignProjectionInfo()).  If no projection is necessary
     * ExecConditionalAssignProjectionInfo() defaults those fields to the scan
     * operations.
     */
    const xk_pg_parser_TupleTableSlotOps *scanops;
    const xk_pg_parser_TupleTableSlotOps *outerops;
    const xk_pg_parser_TupleTableSlotOps *innerops;
    const xk_pg_parser_TupleTableSlotOps *resultops;
    bool        scanopsfixed;
    bool        outeropsfixed;
    bool        inneropsfixed;
    bool        resultopsfixed;
    bool        scanopsset;
    bool        outeropsset;
    bool        inneropsset;
    bool        resultopsset;
} xk_pg_parser_PlanState;

typedef struct xk_pg_parser_deparse_namespace
{
    xk_pg_parser_List       *rtable;            /* List of RangeTblEntry nodes */
    xk_pg_parser_List       *rtable_names;    /* Parallel list of names for RTEs */
    xk_pg_parser_List       *rtable_columns; /* Parallel list of deparse_columns structs */
    xk_pg_parser_List       *ctes;            /* List of CommonTableExpr nodes */
    /* Workspace for column alias assignment: */
    bool        unique_using;    /* Are we making USING names globally unique */
    xk_pg_parser_List       *using_names;    /* List of assigned names for USING columns */
    /* Remaining fields are used only when deparsing a Plan tree: */
    xk_pg_parser_PlanState  *planstate;        /* immediate parent of current expression */
    xk_pg_parser_List       *ancestors;        /* ancestors of planstate */
    xk_pg_parser_PlanState  *outer_planstate;    /* outer subplan state, or NULL if none */
    xk_pg_parser_PlanState  *inner_planstate;    /* inner subplan state, or NULL if none */
    xk_pg_parser_List       *outer_tlist;    /* referent for OUTER_VAR Vars */
    xk_pg_parser_List       *inner_tlist;    /* referent for INNER_VAR Vars */
    xk_pg_parser_List       *index_tlist;    /* referent for INDEX_VAR Vars */
} xk_pg_parser_deparse_namespace;

typedef struct xk_pg_parser_deparse_columns
{
    /*
     * colnames is an array containing column aliases to use for columns that
     * existed when the query was parsed.  Dropped columns have NULL entries.
     * This array can be directly indexed by varattno to get a Var's name.
     *
     * Non-NULL entries are guaranteed unique within the RTE, *except* when
     * this is for an unnamed JOIN RTE.  In that case we merely copy up names
     * from the two input RTEs.
     *
     * During the recursive descent in set_using_names(), forcible assignment
     * of a child RTE's column name is represented by pre-setting that element
     * of the child's colnames array.  So at that stage, NULL entries in this
     * array just mean that no name has been preassigned, not necessarily that
     * the column is dropped.
     */
    int32_t            num_cols;        /* length of colnames[] array */
    char      **colnames;        /* array of C strings and NULLs */

    /*
     * new_colnames is an array containing column aliases to use for columns
     * that would exist if the query was re-parsed against the current
     * definitions of its base tables.  This is what to print as the column
     * alias list for the RTE.  This array does not include dropped columns,
     * but it will include columns added since original parsing.  Indexes in
     * it therefore have little to do with current varattno values.  As above,
     * entries are unique unless this is for an unnamed JOIN RTE.  (In such an
     * RTE, we never actually print this array, but we must compute it anyway
     * for possible use in computing column names of upper joins.) The
     * parallel array is_new_col marks which of these columns are new since
     * original parsing.  Entries with is_new_col false must match the
     * non-NULL colnames entries one-for-one.
     */
    int32_t            num_new_cols;    /* length of new_colnames[] array */
    char      **new_colnames;    /* array of C strings */
    bool       *is_new_col;        /* array of bool flags */

    /* This flag tells whether we should actually print a column alias list */
    bool        printaliases;

    /* This list has all names used as USING names in joins above this RTE */
    xk_pg_parser_List       *parentUsing;    /* names assigned to parent merged columns */

    /*
     * If this struct is for a JOIN RTE, we fill these fields during the
     * set_using_names() pass to describe its relationship to its child RTEs.
     *
     * leftattnos and rightattnos are arrays with one entry per existing
     * output column of the join (hence, indexable by join varattno).  For a
     * simple reference to a column of the left child, leftattnos[i] is the
     * child RTE's attno and rightattnos[i] is zero; and conversely for a
     * column of the right child.  But for merged columns produced by JOIN
     * USING/NATURAL JOIN, both leftattnos[i] and rightattnos[i] are nonzero.
     * Also, if the column has been dropped, both are zero.
     *
     * If it's a JOIN USING, usingNames holds the alias names selected for the
     * merged columns (these might be different from the original USING list,
     * if we had to modify names to achieve uniqueness).
     */
    int32_t            leftrti;        /* rangetable index of left child */
    int32_t            rightrti;        /* rangetable index of right child */
    int32_t           *leftattnos;        /* left-child varattnos of join cols, or 0 */
    int32_t           *rightattnos;    /* right-child varattnos of join cols, or 0 */
    xk_pg_parser_List       *usingNames;        /* names assigned to merged columns */
} xk_pg_parser_deparse_columns;

typedef struct xk_pg_parser_ParallelAppendState
{
    xk_pg_parser_LWLock        pa_lock;        /* mutual exclusion to choose next subplan */
    int32_t            pa_next_plan;    /* next plan to choose by any worker */

    /*
     * pa_finished[i] should be true if no more workers should select subplan
     * i.  for a non-partial plan, this should be set to true as soon as a
     * worker selects the plan; for a partial plan, it remains false until
     * some worker executes the plan to completion.
     */
    bool        pa_finished[FLEXIBLE_ARRAY_MEMBER];
}xk_pg_parser_ParallelAppendState;

