    xk_pg_parser_SortSupport ms_sortkeys;    /* array of length ms_nkeys */
    xk_pg_parser_TupleTableSlot **ms_slots;    /* array of length ms_nplans */
    struct xk_pg_parser_binaryheap *ms_heap; /* binary heap of slot indices */
    bool        ms_initialized; /* are subplans started? */
    bool        ms_noopscan;
    struct xk_pg_parser_PartitionPruneState *ms_prune_state;
    xk_pg_parser_Bitmapset  *ms_valid_subplans;
} xk_pg_parser_MergeAppendState;

typedef struct xk_pg_parser_PartitionKeyData
{
    char        strategy;        /* partitioning strategy */
