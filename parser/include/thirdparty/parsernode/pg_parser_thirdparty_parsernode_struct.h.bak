    bool                     fsSystemCol;      /* true if any "system column" is needed */
} xk_pg_parser_ForeignScan;

struct xk_pg_parser_CustomScanMethods;

typedef struct xk_pg_parser_CustomScan
{
    xk_pg_parser_Scan        scan;
