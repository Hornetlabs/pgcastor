}xk_pg_parser_AppendState;

typedef int32_t (*xk_pg_parser_binaryheap_comparator) (xk_pg_parser_Datum a, xk_pg_parser_Datum b, void *arg);

typedef struct xk_pg_parser_binaryheap
{
    int32_t            bh_size;
    int32_t            bh_space;
