#define XK_PG_PARSER_MAX_FORKNUM 3

typedef struct xk_pg_parser_MdfdVec
{
    int32_t                  mdfd_vfd;        /* fd number in fd.c's pool */
    xk_pg_parser_BlockNumber mdfd_segno;      /* segment number, from 0 */
} xk_pg_parser_MdfdVec;

typedef struct xk_pg_parser_dlist_node xk_pg_parser_dlist_node;
struct xk_pg_parser_dlist_node
{
    xk_pg_parser_dlist_node *prev;
    xk_pg_parser_dlist_node *next;
};

typedef struct xk_pg_parser_SMgrRelationData
{
    /* rnode is the hashtable lookup key, so it must be first! */
    xk_pg_parser_RelFileNodeBackend smgr_rnode;    /* relation physical identifier */

    /* pointer to owning pointer, or NULL if none */
    struct xk_pg_parser_SMgrRelationData **smgr_owner;

    /*
     * These next three fields are not actually used or manipulated by smgr,
     * except that they are reset to InvalidBlockNumber upon a cache flush
     * event (in particular, upon truncation of the relation).  Higher levels
     * store cached state here so that it will be reset when truncation
     * happens.  In all three cases, InvalidBlockNumber means "unknown".
     */
    xk_pg_parser_BlockNumber smgr_targblock; /* current insertion target block */
    xk_pg_parser_BlockNumber smgr_fsm_nblocks;    /* last known size of fsm fork */
    xk_pg_parser_BlockNumber smgr_vm_nblocks;    /* last known size of vm fork */

    /* additional public fields may someday exist here */

    /*
     * Fields below here are intended to be private to smgr.c and its
     * submodules.  Do not touch them from elsewhere.
     */
    int32_t            smgr_which;        /* storage manager selector */

    /*
     * for md.c; per-fork arrays of the number of open segments
     * (md_num_open_segs) and the segments themselves (md_seg_fds).
     */
    int32_t            md_num_open_segs[XK_PG_PARSER_MAX_FORKNUM + 1];
    struct xk_pg_parser_MdfdVec *md_seg_fds[XK_PG_PARSER_MAX_FORKNUM + 1];

    /* if unowned, list link in list of all unowned SMgrRelations */
    xk_pg_parser_dlist_node    node;
} xk_pg_parser_SMgrRelationData;


