    xk_pg_parser_List       *fdw_private;      /* private data for FDW */
    xk_pg_parser_List       *fdw_scan_tlist;   /* optional tlist describing scan tuple */
    xk_pg_parser_List       *fdw_recheck_quals;/* original quals not in scan.plan.qual */
