typedef struct xk_pg_parser_varlena xk_pg_parser_bytea;

typedef struct xk_pg_parser_TupleTableSlotOps xk_pg_parser_TupleTableSlotOps;

typedef struct xk_pg_parser_TupleTableSlot
{
    xk_pg_parser_NodeTag        type;
#define FIELDNO_TUPLETABLESLOT_FLAGS 1
    uint16_t        tts_flags;        /* Boolean states */
#define FIELDNO_TUPLETABLESLOT_NVALID 2
    xk_pg_parser_AttrNumber    tts_nvalid;        /* # of valid values in tts_values */
    const xk_pg_parser_TupleTableSlotOps *const tts_ops; /* implementation of slot */
#define FIELDNO_TUPLETABLESLOT_TUPLEDESCRIPTOR 4
    xk_pg_parser_TupleDesc    tts_tupleDescriptor;    /* slot's tuple descriptor */
#define FIELDNO_TUPLETABLESLOT_VALUES 5
    xk_pg_parser_Datum       *tts_values;        /* current per-attribute values */
#define FIELDNO_TUPLETABLESLOT_ISNULL 6
    bool       *tts_isnull;        /* current per-attribute isnull flags */
    xk_pg_parser_MemoryContext tts_mcxt;        /* slot itself is in this context */
    xk_pg_parser_ItemPointerData tts_tid;    /* stored tuple's tid */
    uint32_t            tts_tableOid;    /* table oid of tuple */
} xk_pg_parser_TupleTableSlot;

typedef struct xk_pg_parser_TupleTableSlotOps
{
    /* Minimum size of the slot */
    size_t        base_slot_size;

    /* Initialization. */
    void        (*init) (xk_pg_parser_TupleTableSlot *slot);

    /* Destruction. */
    void        (*release) (xk_pg_parser_TupleTableSlot *slot);

    /*
     * Clear the contents of the slot. Only the contents are expected to be
     * cleared and not the tuple descriptor. Typically an implementation of
     * this callback should free the memory allocated for the tuple contained
     * in the slot.
     */
    void        (*clear) (xk_pg_parser_TupleTableSlot *slot);

    /*
     * Fill up first natts entries of tts_values and tts_isnull arrays with
     * values from the tuple contained in the slot. The function may be called
     * with natts more than the number of attributes available in the tuple,
     * in which case it should set tts_nvalid to the number of returned
     * columns.
     */
    void        (*getsomeattrs) (xk_pg_parser_TupleTableSlot *slot, int32_t natts);

    /*
     * Returns value of the given system attribute as a datum and sets isnull
     * to false, if it's not NULL. Throws an error if the slot type does not
     * support system attributes.
     */
    xk_pg_parser_Datum        (*getsysattr) (xk_pg_parser_TupleTableSlot *slot, int32_t attnum, bool *isnull);

    /*
     * Make the contents of the slot solely depend on the slot, and not on
     * underlying resources (like another memory context, buffers, etc).
     */
    void        (*materialize) (xk_pg_parser_TupleTableSlot *slot);

    /*
     * Copy the contents of the source slot into the destination slot's own
     * context. Invoked using callback of the destination slot.
     */
    void        (*copyslot) (xk_pg_parser_TupleTableSlot *dstslot, xk_pg_parser_TupleTableSlot *srcslot);

    /*
     * Return a heap tuple "owned" by the slot. It is slot's responsibility to
     * free the memory consumed by the heap tuple. If the slot can not "own" a
     * heap tuple, it should not implement this callback and should set it as
     * NULL.
     */
    xk_pg_parser_HeapTuple    (*xk_pg_parser_get_heap_tuple) (xk_pg_parser_TupleTableSlot *slot);

    /*
     * Return a minimal tuple "owned" by the slot. It is slot's responsibility
     * to free the memory consumed by the minimal tuple. If the slot can not
     * "own" a minimal tuple, it should not implement this callback and should
     * set it as NULL.
     */
    xk_pg_parser_MinimalTuple (*get_minimal_tuple) (xk_pg_parser_TupleTableSlot *slot);

    /*
     * Return a copy of heap tuple representing the contents of the slot. The
     * copy needs to be palloc'd in the current memory context. The slot
     * itself is expected to remain unaffected. It is *not* expected to have
     * meaningful "system columns" in the copy. The copy is not be "owned" by
     * the slot i.e. the caller has to take responsibility to free memory
     * consumed by the slot.
     */
    xk_pg_parser_HeapTuple    (*copy_heap_tuple) (xk_pg_parser_TupleTableSlot *slot);

    /*
     * Return a copy of minimal tuple representing the contents of the slot.
     * The copy needs to be palloc'd in the current memory context. The slot
     * itself is expected to remain unaffected. It is *not* expected to have
     * meaningful "system columns" in the copy. The copy is not be "owned" by
     * the slot i.e. the caller has to take responsibility to free memory
     * consumed by the slot.
     */
    xk_pg_parser_MinimalTuple (*copy_minimal_tuple) (xk_pg_parser_TupleTableSlot *slot);
}xk_pg_parser_TupleTableSlotOps;

