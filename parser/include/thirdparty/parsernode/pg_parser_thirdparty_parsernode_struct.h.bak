typedef void (*xk_pg_parser_MemoryContextCallbackFunction) (void *arg);

typedef struct xk_pg_parser_MemoryContextCallback
{
    xk_pg_parser_MemoryContextCallbackFunction func; /* function to call */
    void       *arg;                                 /* argument to pass it */
    struct xk_pg_parser_MemoryContextCallback *next; /* next in list of callbacks */
} xk_pg_parser_MemoryContextCallback;

typedef struct xk_pg_parser_MemoryContextData *xk_pg_parser_MemoryContext;

typedef void (*xk_pg_parser_MemoryStatsPrintFunc) (xk_pg_parser_MemoryContext context, void *passthru,
                                      const char *stats_string);

typedef struct xk_pg_parser_MemoryContextCounters
{
    size_t        nblocks;        /* Total number of malloc blocks */
    size_t        freechunks;        /* Total number of free chunks */
    size_t        totalspace;        /* Total bytes requested from malloc */
    size_t        freespace;        /* The unused portion of totalspace */
} xk_pg_parser_MemoryContextCounters;

typedef struct xk_pg_parser_MemoryContextMethods
{
    void       *(*alloc) (xk_pg_parser_MemoryContext context, size_t size);
    /* call this free_p in case someone #define's free() */
    void        (*free_p) (xk_pg_parser_MemoryContext context, void *pointer);
    void       *(*realloc) (xk_pg_parser_MemoryContext context, void *pointer, size_t size);
    void        (*reset) (xk_pg_parser_MemoryContext context);
    void        (*delete_context) (xk_pg_parser_MemoryContext context);
    size_t        (*get_chunk_space) (xk_pg_parser_MemoryContext context, void *pointer);
    bool        (*is_empty) (xk_pg_parser_MemoryContext context);
    void        (*stats) (xk_pg_parser_MemoryContext context,
                          xk_pg_parser_MemoryStatsPrintFunc printfunc, void *passthru,
                          xk_pg_parser_MemoryContextCounters *totals);
} xk_pg_parser_MemoryContextMethods;

typedef struct xk_pg_parser_MemoryContextData
{
    xk_pg_parser_NodeTag        type;            /* identifies exact kind of context */
    /* these two fields are placed here to minimize alignment wastage: */
    bool        isReset;        /* T = no space alloced since last reset */
    bool        allowInCritSection; /* allow palloc in critical section */
    const xk_pg_parser_MemoryContextMethods *methods;    /* virtual function table */
    xk_pg_parser_MemoryContext parent;        /* NULL if no parent (toplevel context) */
    xk_pg_parser_MemoryContext firstchild;    /* head of linked list of children */
    xk_pg_parser_MemoryContext prevchild;    /* previous child of same parent */
    xk_pg_parser_MemoryContext nextchild;    /* next child of same parent */
    const char *name;            /* context name (just for debugging) */
    const char *ident;            /* context ID if any (just for debugging) */
    xk_pg_parser_MemoryContextCallback *reset_cbs;    /* list of reset/delete callbacks */
} xk_pg_parser_MemoryContextData;

typedef struct xk_pg_parser_Trigger
{
    uint32_t            tgoid;            /* OID of trigger (pg_trigger row) */
    /* Remaining fields are copied from pg_trigger, see pg_trigger.h */
    char               *tgname;
    uint32_t            tgfoid;
    int16_t             tgtype;
    char                tgenabled;
    bool                tgisinternal;
    uint32_t            tgconstrrelid;
    uint32_t            tgconstrindid;
    uint32_t            tgconstraint;
    bool                tgdeferrable;
    bool                tginitdeferred;
    int16_t             tgnargs;
    int16_t             tgnattr;
    int16_t            *tgattr;
    char              **tgargs;
    char               *tgqual;
    char               *tgoldtable;
    char               *tgnewtable;
} xk_pg_parser_Trigger;

typedef struct xk_pg_parser_TriggerDesc
{
    xk_pg_parser_Trigger    *triggers;        /* array of Trigger structs */
    int32_t         numtriggers;    /* number of array entries */

    /*
     * These flags indicate whether the array contains at least one of each
     * type of trigger.  We use these to skip searching the array if not.
     */
    bool        trig_insert_before_row;
    bool        trig_insert_after_row;
    bool        trig_insert_instead_row;
    bool        trig_insert_before_statement;
    bool        trig_insert_after_statement;
    bool        trig_update_before_row;
    bool        trig_update_after_row;
    bool        trig_update_instead_row;
    bool        trig_update_before_statement;
    bool        trig_update_after_statement;
    bool        trig_delete_before_row;
    bool        trig_delete_after_row;
    bool        trig_delete_instead_row;
    bool        trig_delete_before_statement;
    bool        trig_delete_after_statement;
    /* there are no row-level truncate triggers */
    bool        trig_truncate_before_statement;
    bool        trig_truncate_after_statement;
    /* Is there at least one trigger specifying each transition relation? */
    bool        trig_insert_new_table;
    bool        trig_update_old_table;
    bool        trig_update_new_table;
    bool        trig_delete_old_table;
} xk_pg_parser_TriggerDesc;

