    bool        isnull;            /* is it NULL? */
    uint16_t        pflags;            /* flag bits, see above */
    uint32_t            ptype;            /* parameter's datatype, or 0 */
} xk_pg_parser_ParamExternData;

typedef struct xk_pg_parser_ParamListInfoData *xk_pg_parser_ParamListInfo;

typedef xk_pg_parser_ParamExternData *(*xk_pg_parser_ParamFetchHook) (xk_pg_parser_ParamListInfo params,
                                            int32_t paramid, bool speculative,
                                            xk_pg_parser_ParamExternData *workspace);

typedef struct xk_pg_parser_ExprState xk_pg_parser_ExprState;

typedef void (*xk_pg_parser_ParamCompileHook) (xk_pg_parser_ParamListInfo params, struct xk_pg_parser_Param *param,
                                  struct xk_pg_parser_ExprState *state,
                                  xk_pg_parser_Datum *resv, bool *resnull);

typedef struct xk_pg_parser_QueryEnvironment
{
    xk_pg_parser_List       *namedRelList;
}xk_pg_parser_QueryEnvironment;

typedef struct xk_pg_parser_ParamRef
{
    xk_pg_parser_NodeTag        type;
    int32_t            number;            /* the number of the parameter */
    int32_t            location;        /* token location, or -1 if unknown */
} xk_pg_parser_ParamRef;

typedef struct xk_pg_parser_ColumnRef
{
    xk_pg_parser_NodeTag        type;
    xk_pg_parser_List       *fields;            /* field names (Value strings) or A_Star */
    int32_t            location;        /* token location, or -1 if unknown */
} xk_pg_parser_ColumnRef;

typedef struct xk_pg_parser_ParseState xk_pg_parser_ParseState;

typedef xk_pg_parser_Node *(*xk_pg_parser_PreParseColumnRefHook) (xk_pg_parser_ParseState *pstate,
                                                                  xk_pg_parser_ColumnRef *cref);
typedef xk_pg_parser_Node *(*xk_pg_parser_PostParseColumnRefHook) (xk_pg_parser_ParseState *pstate,
                                                                   xk_pg_parser_ColumnRef *cref,
                                                                   xk_pg_parser_Node *var);
typedef xk_pg_parser_Node *(*xk_pg_parser_ParseParamRefHook) (xk_pg_parser_ParseState *pstate, xk_pg_parser_ParamRef *pref);
typedef xk_pg_parser_Node *(*xk_pg_parser_CoerceParamHook) (xk_pg_parser_ParseState *pstate, xk_pg_parser_Param *param,
                                  uint32_t targetTypeId, int32_t targetTypeMod,
                                  int32_t location);

typedef struct xk_pg_parser_ParseState
{
    struct xk_pg_parser_ParseState *parentParseState;    /* stack link */
    const char *p_sourcetext;    /* source text, or NULL if not available */
    xk_pg_parser_List       *p_rtable;        /* range table so far */
    xk_pg_parser_List       *p_joinexprs;    /* JoinExprs for RTE_JOIN p_rtable entries */
    xk_pg_parser_List       *p_joinlist;        /* join items so far (will become FromExpr
                                 * node's fromlist) */
    xk_pg_parser_List       *p_namespace;    /* currently-referenceable RTEs (List of
                                 * ParseNamespaceItem) */
    bool        p_lateral_active;    /* p_lateral_only items visible? */
    xk_pg_parser_List       *p_ctenamespace; /* current namespace for common table exprs */
    xk_pg_parser_List       *p_future_ctes;    /* common table exprs not yet in namespace */
    xk_pg_parser_CommonTableExpr *p_parent_cte;    /* this query's containing CTE */
    xk_pg_parser_Relation    p_target_relation;    /* INSERT/UPDATE/DELETE target rel */
    xk_pg_parser_RangeTblEntry *p_target_rangetblentry;    /* target rel's RTE */
    bool        p_is_insert;    /* process assignment like INSERT not UPDATE */
    xk_pg_parser_List       *p_windowdefs;    /* raw representations of window clauses */
    xk_pg_parser_ParseExprKind p_expr_kind;    /* what kind of expression we're parsing */
    int32_t            p_next_resno;    /* next targetlist resno to assign */
    xk_pg_parser_List       *p_multiassign_exprs;    /* junk tlist entries for multiassign */
    xk_pg_parser_List       *p_locking_clause;    /* raw FOR UPDATE/FOR SHARE info */
    bool        p_locked_from_parent;    /* parent has marked this subquery
                                         * with FOR UPDATE/FOR SHARE */
    bool        p_resolve_unknowns; /* resolve unknown-type SELECT outputs as
                                     * type text */

    xk_pg_parser_QueryEnvironment *p_queryEnv;    /* curr env, incl refs to enclosing env */

    /* Flags telling about things found in the query: */
    bool        p_hasAggs;
    bool        p_hasWindowFuncs;
    bool        p_hasTargetSRFs;
    bool        p_hasSubLinks;
    bool        p_hasModifyingCTE;

    xk_pg_parser_Node       *p_last_srf;        /* most recent set-returning func/op found */

    /*
     * Optional hook functions for parser callbacks.  These are null unless
     * set up by the caller of make_parsestate.
     */
    xk_pg_parser_PreParseColumnRefHook p_pre_columnref_hook;
    xk_pg_parser_PostParseColumnRefHook p_post_columnref_hook;
    xk_pg_parser_ParseParamRefHook p_paramref_hook;
    xk_pg_parser_CoerceParamHook p_coerce_param_hook;
    void       *p_ref_hook_state;    /* common passthrough link for above */
}xk_pg_parser_ParseState;


typedef void (*xk_pg_parser_ParserSetupHook) (struct xk_pg_parser_ParseState *pstate, void *arg);

typedef struct xk_pg_parser_ParamListInfoData
{
    xk_pg_parser_ParamFetchHook paramFetch;    /* parameter fetch hook */
    void       *paramFetchArg;
    xk_pg_parser_ParamCompileHook paramCompile;    /* parameter compile hook */
    void       *paramCompileArg;
    xk_pg_parser_ParserSetupHook parserSetup;    /* parser setup hook */
    void       *parserSetupArg;
    int32_t            numParams;        /* nominal/maximum # of Params represented */

    /*
     * params[] may be of length zero if paramFetch is supplied; otherwise it
     * must be of length numParams.
     */
    xk_pg_parser_ParamExternData params[FLEXIBLE_ARRAY_MEMBER];
}xk_pg_parser_ParamListInfoData;

typedef void (*xk_pg_parser_ExprContextCallbackFunction) (xk_pg_parser_Datum arg);

typedef struct xk_pg_parser_ExprContext_CB
{
    struct ExprContext_CB *next;
    xk_pg_parser_ExprContextCallbackFunction function;
    xk_pg_parser_Datum        arg;
} xk_pg_parser_ExprContext_CB;

typedef struct xk_pg_parser_EState xk_pg_parser_EState;

typedef struct xk_pg_parser_ExprContext
{
    xk_pg_parser_NodeTag        type;

    /* Tuples that Var nodes in expression may refer to */
#define FIELDNO_EXPRCONTEXT_SCANTUPLE 1
    xk_pg_parser_TupleTableSlot *ecxt_scantuple;
#define FIELDNO_EXPRCONTEXT_INNERTUPLE 2
    xk_pg_parser_TupleTableSlot *ecxt_innertuple;
#define FIELDNO_EXPRCONTEXT_OUTERTUPLE 3
    xk_pg_parser_TupleTableSlot *ecxt_outertuple;

    /* Memory contexts for expression evaluation --- see notes above */
    xk_pg_parser_MemoryContext ecxt_per_query_memory;
    xk_pg_parser_MemoryContext ecxt_per_tuple_memory;

    /* Values to substitute for Param nodes in expression */
    xk_pg_parser_ParamExecData *ecxt_param_exec_vals;    /* for PARAM_EXEC params */
    xk_pg_parser_ParamListInfo ecxt_param_list_info; /* for other param types */

    /*
     * Values to substitute for Aggref nodes in the expressions of an Agg
     * node, or for WindowFunc nodes within a WindowAgg node.
     */
#define FIELDNO_EXPRCONTEXT_AGGVALUES 8
    xk_pg_parser_Datum       *ecxt_aggvalues; /* precomputed values for aggs/windowfuncs */
#define FIELDNO_EXPRCONTEXT_AGGNULLS 9
    bool       *ecxt_aggnulls;    /* null flags for aggs/windowfuncs */

    /* Value to substitute for CaseTestExpr nodes in expression */
#define FIELDNO_EXPRCONTEXT_CASEDATUM 10
    xk_pg_parser_Datum        caseValue_datum;
#define FIELDNO_EXPRCONTEXT_CASENULL 11
    bool        caseValue_isNull;

    /* Value to substitute for CoerceToDomainValue nodes in expression */
#define FIELDNO_EXPRCONTEXT_DOMAINDATUM 12
    xk_pg_parser_Datum        domainValue_datum;
#define FIELDNO_EXPRCONTEXT_DOMAINNULL 13
    bool        domainValue_isNull;

    /* Link to containing EState (NULL if a standalone ExprContext) */
    struct xk_pg_parser_EState *ecxt_estate;

    /* Functions to call back when ExprContext is shut down or rescanned */
    xk_pg_parser_ExprContext_CB *ecxt_callbacks;
} xk_pg_parser_ExprContext;

typedef void (*xk_pg_parser_ExecEvalSubroutine) (xk_pg_parser_ExprState *state,
                                    struct xk_pg_parser_ExprEvalStep *op,
                                    xk_pg_parser_ExprContext *econtext);

typedef struct xk_pg_parser_ArrayMetaState
{
    uint32_t            element_type;
    int16_t             typlen;
    bool                typbyval;
    char                typalign;
    char                typdelim;
    uint32_t            typioparam;
    uint32_t            typiofunc;
    xk_pg_parser_FmgrInfo    proc;
} xk_pg_parser_ArrayMetaState;

typedef struct xk_pg_parser_ArrayMapState
{
    xk_pg_parser_ArrayMetaState inp_extra;
    xk_pg_parser_ArrayMetaState ret_extra;
} xk_pg_parser_ArrayMapState;

#define MAXDIM 6

typedef struct xk_pg_parser_SubscriptingRefState
{
    bool        isassignment;    /* is it assignment, or just fetch? */

    uint32_t            refelemtype;    /* OID of the container element type */
    int16_t        refattrlength;    /* typlen of container type */
    int16_t        refelemlength;    /* typlen of the container element type */
    bool        refelembyval;    /* is the element type pass-by-value? */
    char        refelemalign;    /* typalign of the element type */

    /* numupper and upperprovided[] are filled at compile time */
    /* at runtime, extracted subscript datums get stored in upperindex[] */
    int32_t            numupper;
    bool        upperprovided[MAXDIM];
    int32_t            upperindex[MAXDIM];

    /* similarly for lower indexes, if any */
    int32_t            numlower;
    bool        lowerprovided[MAXDIM];
    int32_t            lowerindex[MAXDIM];

    /* subscript expressions get evaluated into here */
    xk_pg_parser_Datum        subscriptvalue;
    bool        subscriptnull;

    /* for assignment, new value to assign is evaluated into here */
    xk_pg_parser_Datum        replacevalue;
    bool        replacenull;

    /* if we have a nested assignment, SBSREF_OLD puts old value here */
    xk_pg_parser_Datum        prevvalue;
    bool        prevnull;
} xk_pg_parser_SubscriptingRefState;

typedef struct xk_pg_parser_TupleConversionMap
{
    xk_pg_parser_TupleDesc    indesc;            /* tupdesc for source rowtype */
    xk_pg_parser_TupleDesc    outdesc;        /* tupdesc for result rowtype */
    xk_pg_parser_AttrNumber  *attrMap;        /* indexes of input fields, or 0 for null */
    xk_pg_parser_Datum       *invalues;        /* workspace for deconstructing source */
    bool                     *inisnull;
    xk_pg_parser_Datum       *outvalues;        /* workspace for constructing result */
    bool       *outisnull;
} xk_pg_parser_TupleConversionMap;

typedef struct xk_pg_parser_AggrefExprState
{
    xk_pg_parser_NodeTag        type;
    xk_pg_parser_Aggref       *aggref;            /* expression plan node */
    int32_t            aggno;            /* ID number for agg within its plan node */
} xk_pg_parser_AggrefExprState;

typedef struct xk_pg_parser_AggStatePerPhaseData
{
    xk_pg_parser_AggStrategy aggstrategy;    /* strategy for this phase */
    int32_t            numsets;        /* number of grouping sets (or 0) */
    int32_t           *gset_lengths;    /* lengths of grouping sets */
    xk_pg_parser_Bitmapset **grouped_cols;    /* column groupings for rollup */
    xk_pg_parser_ExprState **eqfunctions;    /* expression returning equality, indexed by
                                 * nr of cols to compare */
    xk_pg_parser_Agg           *aggnode;        /* Agg node for phase data */
    xk_pg_parser_Sort       *sortnode;        /* Sort node for input ordering for phase */

    xk_pg_parser_ExprState  *evaltrans;        /* evaluation of transition functions  */
}xk_pg_parser_AggStatePerPhaseData;

typedef struct xk_pg_parser_AggStatePerPhaseData *xk_pg_parser_AggStatePerPhase;

typedef struct xk_pg_parser_AggStatePerAggData
{
    /*
     * Link to an Aggref expr this state value is for.
     *
     * There can be multiple identical Aggref's sharing the same per-agg. This
     * points to the first one of them.
     */
    xk_pg_parser_Aggref       *aggref;

    /* index to the state value which this agg should use */
    int32_t            transno;

    /* Optional Oid of final function (may be InvalidOid) */
    uint32_t            finalfn_oid;

    /*
     * fmgr lookup data for final function --- only valid when finalfn_oid is
     * not InvalidOid.
     */
    xk_pg_parser_FmgrInfo    finalfn;

    /*
     * Number of arguments to pass to the finalfn.  This is always at least 1
     * (the transition state value) plus any ordered-set direct args. If the
     * finalfn wants extra args then we pass nulls corresponding to the
     * aggregated input columns.
     */
    int32_t            numFinalArgs;

    /* ExprStates for any direct-argument expressions */
    xk_pg_parser_List       *aggdirectargs;

    /*
     * We need the len and byval info for the agg's result data type in order
     * to know how to copy/delete values.
     */
    int16_t        resulttypeLen;
    bool        resulttypeByVal;

    /*
     * "shareable" is false if this agg cannot share state values with other
     * aggregates because the final function is read-write.
     */
    bool        shareable;
}xk_pg_parser_AggStatePerAggData;

typedef struct xk_pg_parser_AggStatePerAggData *xk_pg_parser_AggStatePerAgg;

typedef enum
{
    TSS_INITIAL,                /* Loading tuples; still within memory limit */
    TSS_BOUNDED,                /* Loading tuples into bounded-size heap */
    TSS_BUILDRUNS,                /* Loading tuples; writing to tape */
    TSS_SORTEDINMEM,            /* Sort completed entirely in memory */
    TSS_SORTEDONTAPE,            /* Sort completed, final run is on tape */
    TSS_FINALMERGE                /* Performing final merge on-the-fly */
} xk_pg_parser_TupSortStatus;

typedef unsigned char xk_pg_parser_slock_t;

typedef struct xk_pg_parser_SharedFileSet
{
    pid_t        creator_pid;    /* PID of the creating process */
    uint32_t        number;            /* per-PID identifier */
    xk_pg_parser_slock_t        mutex;            /* mutex protecting the reference count */
    int32_t            refcnt;            /* number of attached backends */
    int32_t            ntablespaces;    /* number of tablespaces to use */
    uint32_t            tablespaces[8]; /* OIDs of tablespaces to use. Assumes that
                                 * it's rare that there more than temp
                                 * tablespaces. */
} xk_pg_parser_SharedFileSet;

typedef struct xk_pg_parser_ResourceOwnerData *xk_pg_parser_ResourceOwner;

typedef struct xk_pg_parser_ResourceArray
{
    xk_pg_parser_Datum       *itemsarr;        /* buffer for storing values */
    xk_pg_parser_Datum        invalidval;        /* value that is considered invalid */
    uint32_t        capacity;        /* allocated length of itemsarr[] */
    uint32_t        nitems;            /* how many items are stored in items array */
    uint32_t        maxitems;        /* current limit on nitems before enlarging */
    uint32_t        lastidx;        /* index of last item returned by GetAny */
} xk_pg_parser_ResourceArray;

typedef struct xk_pg_parser_LOCKTAG
{
    uint32_t        locktag_field1; /* a 32-bit ID field */
    uint32_t        locktag_field2; /* a 32-bit ID field */
    uint32_t        locktag_field3; /* a 32-bit ID field */
    uint16_t        locktag_field4; /* a 16-bit ID field */
    uint8_t        locktag_type;    /* see enum LockTagType */
    uint8_t        locktag_lockmethodid;    /* lockmethod indicator */
} xk_pg_parser_LOCKTAG;

typedef int32_t xk_pg_parser_LOCKMODE;

typedef struct xk_pg_parser_LOCALLOCKTAG
{
    xk_pg_parser_LOCKTAG        lock;            /* identifies the lockable object */
    xk_pg_parser_LOCKMODE    mode;            /* lock mode for this table entry */
} xk_pg_parser_LOCALLOCKTAG;

typedef int32_t xk_pg_parser_LOCKMASK;

typedef struct xk_pg_parser_SHM_QUEUE
{
    struct xk_pg_parser_SHM_QUEUE *prev;
    struct xk_pg_parser_SHM_QUEUE *next;
} xk_pg_parser_SHM_QUEUE;

typedef struct xk_pg_parser_PROC_QUEUE
{
    xk_pg_parser_SHM_QUEUE    links;            /* head of list of PGPROC objects */
    int32_t            size;            /* number of entries in list */
} xk_pg_parser_PROC_QUEUE;

#define XK_PG_PARSER_MAX_LOCKMODES 10

typedef struct xk_pg_parser_LOCK
{
    /* hash key */
    xk_pg_parser_LOCKTAG        tag;            /* unique identifier of lockable object */

    /* data */
    xk_pg_parser_LOCKMASK    grantMask;        /* bitmask for lock types already granted */
    xk_pg_parser_LOCKMASK    waitMask;        /* bitmask for lock types awaited */
    xk_pg_parser_SHM_QUEUE    procLocks;        /* list of PROCLOCK objects assoc. with lock */
    xk_pg_parser_PROC_QUEUE    waitProcs;        /* list of PGPROC objects waiting on lock */
    int32_t            requested[XK_PG_PARSER_MAX_LOCKMODES];    /* counts of requested locks */
    int32_t            nRequested;        /* total of requested[] array */
    int32_t            granted[XK_PG_PARSER_MAX_LOCKMODES]; /* counts of granted locks */
    int32_t            nGranted;        /* total of granted[] array */
} xk_pg_parser_LOCK;

typedef struct xk_pg_parser_PGPROC xk_pg_parser_PGPROC;

typedef struct xk_pg_parser_PGSemaphoreData
{
    int32_t            semId;            /* semaphore set identifier */
    int32_t            semNum;            /* semaphore number within set */
} xk_pg_parser_PGSemaphoreData;

typedef struct xk_pg_parser_PGSemaphoreData *xk_pg_parser_PGSemaphore;

typedef struct xk_pg_parser_Latch
{
    sig_atomic_t is_set;
    bool        is_shared;
    int32_t            owner_pid;
} xk_pg_parser_Latch;

typedef uint32_t xk_pg_parser_LocalTransactionId;
typedef int32_t xk_pg_parser_BackendId;

typedef struct xk_pg_parser_proclist_node
{
    int32_t            next;            /* pgprocno of the next PGPROC */
    int32_t            prev;            /* pgprocno of the prev PGPROC */
} xk_pg_parser_proclist_node;

#define XK_PG_PARSER_LOG2_NUM_LOCK_PARTITIONS  4
#define XK_PG_PARSER_NUM_LOCK_PARTITIONS  (1 << XK_PG_PARSER_LOG2_NUM_LOCK_PARTITIONS)

#define XK_PG_PARSER_PGPROC_MAX_CACHED_SUBXIDS 64    /* XXX guessed-at value */

struct xk_pg_parser_XidCache
{
    xk_pg_parser_TransactionId xids[XK_PG_PARSER_PGPROC_MAX_CACHED_SUBXIDS];
};

typedef int32_t xk_pg_parser_XidStatus;

typedef struct xk_pg_parser_proclist_head
{
    int32_t            head;            /* pgprocno of the head PGPROC */
    int32_t            tail;            /* pgprocno of the tail PGPROC */
} xk_pg_parser_proclist_head;


typedef struct xk_pg_parser_LWLock
{
    uint16_t        tranche;        /* tranche ID */
    uint32_t state;        /* state of exclusive/nonexclusive lockers */
    xk_pg_parser_proclist_head waiters;        /* list of waiting PGPROCs */
} xk_pg_parser_LWLock;

#define        XK_PG_PARSER_FP_LOCK_SLOTS_PER_BACKEND 16

typedef struct xk_pg_parser_dlist_head
{
    /*
     * head.next either points to the first element of the list; to &head if
     * it's a circular empty list; or to NULL if empty and not circular.
     *
     * head.prev either points to the last element of the list; to &head if
     * it's a circular empty list; or to NULL if empty and not circular.
     */
    xk_pg_parser_dlist_node    head;
} xk_pg_parser_dlist_head;

typedef struct xk_pg_parser_PROCLOCK xk_pg_parser_PROCLOCK;

typedef struct xk_pg_parser_PROCLOCKTAG
{
    /* NB: we assume this struct contains no padding! */
    xk_pg_parser_LOCK       *myLock;            /* link to per-lockable-object information */
    xk_pg_parser_PGPROC       *myProc;            /* link to PGPROC of owning backend */
} xk_pg_parser_PROCLOCKTAG;

typedef struct xk_pg_parser_PROCLOCK
{
    /* tag */
    xk_pg_parser_PROCLOCKTAG tag;            /* unique identifier of proclock object */

    /* data */
    xk_pg_parser_PGPROC       *groupLeader;    /* proc's lock group leader, or proc itself */
    xk_pg_parser_LOCKMASK    holdMask;        /* bitmask for lock types currently held */
    xk_pg_parser_LOCKMASK    releaseMask;    /* bitmask for lock types to be released */
    xk_pg_parser_SHM_QUEUE    lockLink;        /* list link in LOCK's list of proclocks */
    xk_pg_parser_SHM_QUEUE    procLink;        /* list link in PGPROC's list of proclocks */
} xk_pg_parser_PROCLOCK;

struct xk_pg_parser_PGPROC
{
    /* proc->links MUST BE FIRST IN STRUCT (see ProcSleep,ProcWakeup,etc) */
    xk_pg_parser_SHM_QUEUE    links;            /* list link if process is in a list */
    xk_pg_parser_PGPROC      **procgloballist; /* procglobal list that owns this PGPROC */

    xk_pg_parser_PGSemaphore sem;            /* ONE semaphore to sleep on */
    int32_t            waitStatus;        /* STATUS_WAITING, STATUS_OK or STATUS_ERROR */

    xk_pg_parser_Latch        procLatch;        /* generic latch for process */

    xk_pg_parser_LocalTransactionId lxid;    /* local id of top-level transaction currently
                                 * being executed by this proc, if running;
                                 * else InvalidLocalTransactionId */
    int32_t            pid;            /* Backend's process ID; 0 if prepared xact */
    int32_t            pgprocno;

    /* These fields are zero while a backend is still starting up: */
    xk_pg_parser_BackendId    backendId;        /* This backend's backend ID (if assigned) */
    uint32_t            databaseId;        /* OID of database this backend is using */
    uint32_t            roleId;            /* OID of role using this backend */

    uint32_t            tempNamespaceId;    /* OID of temp schema this backend is
                                     * using */

    bool        isBackgroundWorker; /* true if background worker. */

    /*
     * While in hot standby mode, shows that a conflict signal has been sent
     * for the current transaction. Set/cleared while holding ProcArrayLock,
     * though not required. Accessed without lock, if needed.
     */
    bool        recoveryConflictPending;

    /* Info about LWLock the process is currently waiting for, if any. */
    bool        lwWaiting;        /* true if waiting for an LW lock */
    uint8_t        lwWaitMode;        /* lwlock mode being waited for */
    xk_pg_parser_proclist_node lwWaitLink;    /* position in LW lock wait list */

    /* Support for condition variables. */
    xk_pg_parser_proclist_node cvWaitLink;    /* position in CV wait list */

    /* Info about lock the process is currently waiting for, if any. */
    /* waitLock and waitProcLock are NULL if not currently waiting. */
    xk_pg_parser_LOCK       *waitLock;        /* Lock object we're sleeping on ... */
    xk_pg_parser_PROCLOCK   *waitProcLock;    /* Per-holder info for awaited lock */
    xk_pg_parser_LOCKMODE    waitLockMode;    /* type of lock we're waiting for */
    xk_pg_parser_LOCKMASK    heldLocks;        /* bitmask for lock types already held on this
                                 * lock object by this backend */

    /*
     * Info to allow us to wait for synchronous replication, if needed.
     * waitLSN is InvalidXLogRecPtr if not waiting; set only by user backend.
     * syncRepState must not be touched except by owning process or WALSender.
     * syncRepLinks used only while holding SyncRepLock.
     */
    xk_pg_parser_XLogRecPtr    waitLSN;        /* waiting for this LSN or higher */
    int32_t            syncRepState;    /* wait state for sync rep */
    xk_pg_parser_SHM_QUEUE    syncRepLinks;    /* list link if process is in syncrep queue */

    /*
     * All PROCLOCK objects for locks held or awaited by this backend are
     * linked into one of these lists, according to the partition number of
     * their lock.
     */
    xk_pg_parser_SHM_QUEUE    myProcLocks[XK_PG_PARSER_NUM_LOCK_PARTITIONS];

    struct xk_pg_parser_XidCache subxids;    /* cache for subtransaction XIDs */

    /* Support for group XID clearing. */
    /* true, if member of ProcArray group waiting for XID clear */
    bool        procArrayGroupMember;
    /* next ProcArray group member waiting for XID clear */
    uint32_t procArrayGroupNext;

    /*
     * latest transaction id among the transaction's main XID and
     * subtransactions
     */
    xk_pg_parser_TransactionId procArrayGroupMemberXid;

    uint32_t        wait_event_info;    /* proc's wait information */

    /* Support for group transaction status update. */
    bool        clogGroupMember;    /* true, if member of clog group */
    uint32_t clogGroupNext; /* next clog group member */
    xk_pg_parser_TransactionId clogGroupMemberXid;    /* transaction id of clog group member */
    xk_pg_parser_XidStatus    clogGroupMemberXidStatus;    /* transaction status of clog
                                             * group member */
    int32_t            clogGroupMemberPage;    /* clog page corresponding to
                                         * transaction id of clog group member */
    xk_pg_parser_XLogRecPtr    clogGroupMemberLsn; /* WAL location of commit record for clog
                                     * group member */

    /* Per-backend LWLock.  Protects fields below (but not group fields). */
    xk_pg_parser_LWLock        backendLock;

    /* Lock manager data, recording fast-path locks taken by this backend. */
    uint64_t        fpLockBits;        /* lock modes held for each fast-path slot */
    uint32_t            fpRelId[XK_PG_PARSER_FP_LOCK_SLOTS_PER_BACKEND]; /* slots for rel oids */
    bool        fpVXIDLock;        /* are we holding a fast-path VXID lock? */
    xk_pg_parser_LocalTransactionId fpLocalTransactionId;    /* lxid for fast-path VXID
                                                 * lock */

    /*
     * Support for lock groups.  Use LockHashPartitionLockByProc on the group
     * leader to get the LWLock protecting these fields.
     */
    xk_pg_parser_PGPROC       *lockGroupLeader;    /* lock group leader, if I'm a member */
    xk_pg_parser_dlist_head    lockGroupMembers;    /* list of members, if I'm a leader */
    xk_pg_parser_dlist_node    lockGroupLink;    /* my member link, if I'm a member */
};

typedef struct xk_pg_parser_ResourceOwnerData xk_pg_parser_ResourceOwnerData;
typedef struct xk_pg_parser_LOCALLOCKOWNER
{
    /*
     * Note: if owner is NULL then the lock is held on behalf of the session;
     * otherwise it is held on behalf of my current transaction.
     *
     * Must use a forward struct reference to avoid circularity.
     */
    struct xk_pg_parser_ResourceOwnerData *owner;
    int64_t        nLocks;            /* # of times held by this owner */
} xk_pg_parser_LOCALLOCKOWNER;

typedef struct xk_pg_parser_LOCALLOCK
{
    /* tag */
    xk_pg_parser_LOCALLOCKTAG tag;            /* unique identifier of locallock entry */

    /* data */
    uint32_t        hashcode;        /* copy of LOCKTAG's hash value */
    xk_pg_parser_LOCK       *lock;            /* associated LOCK object, if any */
    xk_pg_parser_PROCLOCK   *proclock;        /* associated PROCLOCK object, if any */
    int64_t        nLocks;            /* total number of times lock is held */
    int32_t            numLockOwners;    /* # of relevant ResourceOwners */
    int32_t            maxLockOwners;    /* allocated size of array */
    xk_pg_parser_LOCALLOCKOWNER *lockOwners; /* dynamically resizable array */
    bool        holdsStrongLockCount;    /* bumped FastPathStrongRelationLocks */
    bool        lockCleared;    /* we read all sinval msgs for lock */
} xk_pg_parser_LOCALLOCK;

#define XK_PG_PARSER_MAX_RESOWNER_LOCKS 15

typedef struct xk_pg_parser_ResourceOwnerData
{
    xk_pg_parser_ResourceOwner parent;        /* NULL if no parent (toplevel owner) */
    xk_pg_parser_ResourceOwner firstchild;    /* head of linked list of children */
    xk_pg_parser_ResourceOwner nextchild;    /* next child of same parent */
    const char *name;            /* name (just for debugging) */

    /* We have built-in support for remembering: */
    xk_pg_parser_ResourceArray bufferarr;    /* owned buffers */
    xk_pg_parser_ResourceArray catrefarr;    /* catcache references */
    xk_pg_parser_ResourceArray catlistrefarr;    /* catcache-list pins */
    xk_pg_parser_ResourceArray relrefarr;    /* relcache references */
    xk_pg_parser_ResourceArray planrefarr;    /* plancache references */
    xk_pg_parser_ResourceArray tupdescarr;    /* tupdesc references */
    xk_pg_parser_ResourceArray snapshotarr;    /* snapshot references */
    xk_pg_parser_ResourceArray filearr;        /* open temporary files */
    xk_pg_parser_ResourceArray dsmarr;        /* dynamic shmem segments */
    xk_pg_parser_ResourceArray jitarr;        /* JIT contexts */

    /* We can remember up to MAX_RESOWNER_LOCKS references to local locks. */
    int32_t            nlocks;            /* number of owned locks */
    xk_pg_parser_LOCALLOCK  *locks[XK_PG_PARSER_MAX_RESOWNER_LOCKS];    /* list of owned locks */
}xk_pg_parser_ResourceOwnerData;

// todo warning 这里直接用8192代替, 可能会导致一些问题, 不过应该不会遇到
typedef union xk_pg_parser_PGAlignedBlock
{
    char        data[8192];
    double        force_align_d;
    int64_t        force_align_i64;
} xk_pg_parser_PGAlignedBlock;

typedef struct xk_pg_parser_BufFile
{
    int32_t            numFiles;        /* number of physical files in set */
    /* all files except the last have length exactly MAX_PHYSICAL_FILESIZE */
    xk_pg_parser_File       *files;            /* palloc'd array with numFiles entries */

    bool        isInterXact;    /* keep open over transactions? */
    bool        dirty;            /* does buffer need to be written? */
    bool        readOnly;        /* has the file been set to read only? */

    xk_pg_parser_SharedFileSet *fileset;        /* space for segment files if shared */
    const char *name;            /* name of this BufFile if shared */

    /*
     * resowner is the ResourceOwner to use for underlying temp files.  (We
     * don't need to remember the memory context we're using explicitly,
     * because after creation we only repalloc our arrays larger.)
     */
    xk_pg_parser_ResourceOwner resowner;

    /*
     * "current pos" is position of start of buffer within the logical file.
     * Position as seen by user of BufFile is (curFile, curOffset + pos).
     */
    int32_t            curFile;        /* file index (0..n) part of current pos */
    off_t        curOffset;        /* offset part of current pos */
    int32_t            pos;            /* next read/write position in buffer */
    int32_t            nbytes;            /* total # of valid bytes in buffer */
    xk_pg_parser_PGAlignedBlock buffer;
}xk_pg_parser_BufFile;

typedef struct xk_pg_parser_LogicalTape
{
    bool        writing;        /* T while in write phase */
    bool        frozen;            /* T if blocks should not be freed when read */
    bool        dirty;            /* does buffer need to be written? */

    /*
     * Block numbers of the first, current, and next block of the tape.
     *
     * The "current" block number is only valid when writing, or reading from
     * a frozen tape.  (When reading from an unfrozen tape, we use a larger
     * read buffer that holds multiple blocks, so the "current" block is
     * ambiguous.)
     *
     * When concatenation of worker tape BufFiles is performed, an offset to
     * the first block in the unified BufFile space is applied during reads.
     */
    int64_t        firstBlockNumber;
    int64_t        curBlockNumber;
    int64_t        nextBlockNumber;
    int64_t        offsetBlockNumber;

    /*
     * Buffer for current data block(s).
     */
    char       *buffer;            /* physical buffer (separately palloc'd) */
    int32_t            buffer_size;    /* allocated size of the buffer */
    int32_t            max_size;        /* highest useful, safe buffer_size */
    int32_t            pos;            /* next read/write position in buffer */
    int32_t            nbytes;            /* total # of valid bytes in buffer */
} xk_pg_parser_LogicalTape;

typedef struct xk_pg_parser_LogicalTapeSet
{
    xk_pg_parser_BufFile    *pfile;            /* underlying file for whole tape set */

    /*
     * File size tracking.  nBlocksWritten is the size of the underlying file,
     * in BLCKSZ blocks.  nBlocksAllocated is the number of blocks allocated
     * by ltsGetFreeBlock(), and it is always greater than or equal to
     * nBlocksWritten.  Blocks between nBlocksAllocated and nBlocksWritten are
     * blocks that have been allocated for a tape, but have not been written
     * to the underlying file yet.  nHoleBlocks tracks the total number of
     * blocks that are in unused holes between worker spaces following BufFile
     * concatenation.
     */
    int64_t        nBlocksAllocated;    /* # of blocks allocated */
    int64_t        nBlocksWritten; /* # of blocks used in underlying file */
    int64_t        nHoleBlocks;    /* # of "hole" blocks left */

    /*
     * We store the numbers of recycled-and-available blocks in freeBlocks[].
     * When there are no such blocks, we extend the underlying file.
     *
     * If forgetFreeSpace is true then any freed blocks are simply forgotten
     * rather than being remembered in freeBlocks[].  See notes for
     * LogicalTapeSetForgetFreeSpace().
     *
     * If blocksSorted is true then the block numbers in freeBlocks are in
     * *decreasing* order, so that removing the last entry gives us the lowest
     * free block.  We re-sort the blocks whenever a block is demanded; this
     * should be reasonably efficient given the expected usage pattern.
     */
    bool        forgetFreeSpace;    /* are we remembering free blocks? */
    bool        blocksSorted;    /* is freeBlocks[] currently in order? */
    int64_t       *freeBlocks;        /* resizable array */
    int32_t            nFreeBlocks;    /* # of currently free blocks */
    int32_t            freeBlocksLen;    /* current allocated length of freeBlocks[] */

    /* The array of logical tapes. */
    int32_t            nTapes;            /* # of logical tapes in set */
    xk_pg_parser_LogicalTape tapes[FLEXIBLE_ARRAY_MEMBER];    /* has nTapes nentries */
}xk_pg_parser_LogicalTapeSet;

typedef struct xk_pg_parser_SortTuple
{
    void       *tuple;            /* the tuple itself */
    xk_pg_parser_Datum        datum1;            /* value of first key column */
    bool        isnull1;        /* is first key column NULL? */
    int32_t            tupindex;        /* see notes above */
} xk_pg_parser_SortTuple;

#define XK_PG_PARSER_SLAB_SLOT_SIZE 1024

typedef union xk_pg_parser_SlabSlot
{
    union xk_pg_parser_SlabSlot *nextfree;
    char        buffer[XK_PG_PARSER_SLAB_SLOT_SIZE];
} xk_pg_parser_SlabSlot;

typedef unsigned char xk_pg_parser_slock_t;

typedef struct xk_pg_parser_TapeShare
{
    /*
     * Currently, all the leader process needs is the location of the
     * materialized tape's first block.
     */
    int64_t        firstblocknumber;
} xk_pg_parser_TapeShare;

typedef struct xk_pg_parser_Sharedsort
{
    /* mutex protects all fields prior to tapes */
    xk_pg_parser_slock_t        mutex;

    /*
     * currentWorker generates ordinal identifier numbers for parallel sort
     * workers.  These start from 0, and are always gapless.
     *
     * Workers increment workersFinished to indicate having finished.  If this
     * is equal to state.nParticipants within the leader, leader is ready to
     * merge worker runs.
     */
    int32_t            currentWorker;
    int32_t            workersFinished;

    /* Temporary file space */
    xk_pg_parser_SharedFileSet fileset;

    /* Size of tapes flexible array */
    int32_t            nTapes;

    /*
     * Tapes array used by workers to report back information needed by the
     * leader to concatenate all worker tapes into one for merging
     */
    xk_pg_parser_TapeShare    tapes[FLEXIBLE_ARRAY_MEMBER];
}xk_pg_parser_Sharedsort;

typedef struct xk_pg_parser_SortSupportData *xk_pg_parser_SortSupport;

typedef struct xk_pg_parser_SortSupportData
{
    /*
     * These fields are initialized before calling the BTSORTSUPPORT function
     * and should not be changed later.
     */
    xk_pg_parser_MemoryContext ssup_cxt;        /* Context containing sort info */
    uint32_t            ssup_collation; /* Collation to use, or InvalidOid */

    /*
     * Additional sorting parameters; but unlike ssup_collation, these can be
     * changed after BTSORTSUPPORT is called, so don't use them in selecting
     * sort support functions.
     */
    bool        ssup_reverse;    /* descending-order sort? */
    bool        ssup_nulls_first;    /* sort nulls first? */

    /*
     * These fields are workspace for callers, and should not be touched by
     * opclass-specific functions.
     */
    xk_pg_parser_AttrNumber    ssup_attno;        /* column number to sort */

    /*
     * ssup_extra is zeroed before calling the BTSORTSUPPORT function, and is
     * not touched subsequently by callers.
     */
    void       *ssup_extra;        /* Workspace for opclass functions */

    /*
     * Function pointers are zeroed before calling the BTSORTSUPPORT function,
     * and must be set by it for any acceleration methods it wants to supply.
     * The comparator pointer must be set, others are optional.
     */

    /*
     * Comparator function has the same API as the traditional btree
     * comparison function, ie, return <0, 0, or >0 according as x is less
     * than, equal to, or greater than y.  Note that x and y are guaranteed
     * not null, and there is no way to return null either.
     *
     * This may be either the authoritative comparator, or the abbreviated
     * comparator.  Core code may switch this over the initial preference of
     * an opclass support function despite originally indicating abbreviation
     * was applicable, by assigning the authoritative comparator back.
     */
    int32_t            (*comparator) (xk_pg_parser_Datum x, xk_pg_parser_Datum y, xk_pg_parser_SortSupport ssup);

    /*
     * "Abbreviated key" infrastructure follows.
     *
     * All callbacks must be set by sortsupport opclasses that make use of
     * this optional additional infrastructure (unless for whatever reasons
     * the opclass doesn't proceed with abbreviation, in which case
     * abbrev_converter must not be set).
     *
     * This allows opclass authors to supply a conversion routine, used to
     * create an alternative representation of the underlying type (an
     * "abbreviated key").  This representation must be pass-by-value and
     * typically will use some ad-hoc format that only the opclass has
     * knowledge of.  An alternative comparator, used only with this
     * alternative representation must also be provided (which is assigned to
     * "comparator").  This representation is a simple approximation of the
     * original Datum.  It must be possible to compare datums of this
     * representation with each other using the supplied alternative
     * comparator, and have any non-zero return value be a reliable proxy for
     * what a proper comparison would indicate. Returning zero from the
     * alternative comparator does not indicate equality, as with a
     * conventional support routine 1, though -- it indicates that it wasn't
     * possible to determine how the two abbreviated values compared.  A
     * proper comparison, using "abbrev_full_comparator"/
     * ApplySortAbbrevFullComparator() is therefore required.  In many cases
     * this results in most or all comparisons only using the cheap
     * alternative comparison func, which is typically implemented as code
     * that compiles to just a few CPU instructions.  CPU cache miss penalties
     * are expensive; to get good overall performance, sort infrastructure
     * must heavily weigh cache performance.
     *
     * Opclass authors must consider the final cardinality of abbreviated keys
     * when devising an encoding scheme.  It's possible for a strategy to work
     * better than an alternative strategy with one usage pattern, while the
     * reverse might be true for another usage pattern.  All of these factors
     * must be considered.
     */

    /*
     * "abbreviate" concerns whether or not the abbreviated key optimization
     * is applicable in principle (that is, the sortsupport routine needs to
     * know if its dealing with a key where an abbreviated representation can
     * usefully be packed together.  Conventionally, this is the leading
     * attribute key).  Note, however, that in order to determine that
     * abbreviation is not in play, the core code always checks whether or not
     * the opclass has set abbrev_converter.  This is a one way, one time
     * message to the opclass.
     */
    bool        abbreviate;

    /*
     * Converter to abbreviated format, from original representation.  Core
     * code uses this callback to convert from a pass-by-reference "original"
     * Datum to a pass-by-value abbreviated key Datum.  Note that original is
     * guaranteed NOT NULL, because it doesn't make sense to factor NULLness
     * into ad-hoc cost model.
     *
     * abbrev_converter is tested to see if abbreviation is in play.  Core
     * code may set it to NULL to indicate abbreviation should not be used
     * (which is something sortsupport routines need not concern themselves
     * with). However, sortsupport routines must not set it when it is
     * immediately established that abbreviation should not proceed (e.g., for
     * !abbreviate calls, or due to platform-specific impediments to using
     * abbreviation).
     */
    xk_pg_parser_Datum        (*abbrev_converter) (xk_pg_parser_Datum original, xk_pg_parser_SortSupport ssup);

    /*
     * abbrev_abort callback allows clients to verify that the current
     * strategy is working out, using a sortsupport routine defined ad-hoc
     * cost model. If there is a lot of duplicate abbreviated keys in
     * practice, it's useful to be able to abandon the strategy before paying
     * too high a cost in conversion (perhaps certain opclass-specific
     * adaptations are useful too).
     */
    bool        (*abbrev_abort) (int32_t memtupcount, xk_pg_parser_SortSupport ssup);

    /*
     * Full, authoritative comparator for key that an abbreviated   
     * representation was generated for, used when an abbreviated comparison
     * was inconclusive (by calling ApplySortAbbrevFullComparator()), or used
     * to replace "comparator" when core system ultimately decides against
     * abbreviation.
     */
    int32_t            (*abbrev_full_comparator) (xk_pg_parser_Datum x, xk_pg_parser_Datum y, xk_pg_parser_SortSupport ssup);
} xk_pg_parser_SortSupportData;

typedef struct xk_pg_parser_Tuplesortstate xk_pg_parser_Tuplesortstate;

typedef int32_t (*xk_pg_parser_SortTupleComparator) (const xk_pg_parser_SortTuple *a,
                                                 const xk_pg_parser_SortTuple *b,
                                                 xk_pg_parser_Tuplesortstate *state);

typedef struct xk_pg_parser_Tuplesortstate
{
    xk_pg_parser_TupSortStatus status;        /* enumerated value as shown above */
    int32_t            nKeys;            /* number of columns in sort key */
    bool        randomAccess;    /* did caller request random access? */
    bool        bounded;        /* did caller specify a maximum number of
                                 * tuples to return? */
    bool        boundUsed;        /* true if we made use of a bounded heap */
    int32_t            bound;            /* if bounded, the maximum number of tuples */
    bool        tuples;            /* Can SortTuple.tuple ever be set? */
    int64_t        availMem;        /* remaining memory available, in bytes */
    int64_t        allowedMem;        /* total memory allowed, in bytes */
    int32_t            maxTapes;        /* number of tapes (Knuth's T) */
    int32_t            tapeRange;        /* maxTapes-1 (Knuth's P) */
    xk_pg_parser_MemoryContext sortcontext;    /* memory context holding most sort data */
    xk_pg_parser_MemoryContext tuplecontext; /* sub-context of sortcontext for tuple data */
    xk_pg_parser_LogicalTapeSet *tapeset;    /* logtape.c object for tapes in a temp file */

    /*
     * These function pointers decouple the routines that must know what kind
     * of tuple we are sorting from the routines that don't need to know it.
     * They are set up by the tuplesort_begin_xxx routines.
     *
     * Function to compare two tuples; result is per qsort() convention, ie:
     * <0, 0, >0 according as a<b, a=b, a>b.  The API must match
     * qsort_arg_comparator.
     */
    xk_pg_parser_SortTupleComparator comparetup;

    /*
     * Function to copy a supplied input tuple into palloc'd space and set up
     * its SortTuple representation (ie, set tuple/datum1/isnull1).  Also,
     * state->availMem must be decreased by the amount of space used for the
     * tuple copy (note the SortTuple struct itself is not counted).
     */
    void        (*copytup) (xk_pg_parser_Tuplesortstate *state, xk_pg_parser_SortTuple *stup, void *tup);

    /*
     * Function to write a stored tuple onto tape.  The representation of the
     * tuple on tape need not be the same as it is in memory; requirements on
     * the tape representation are given below.  Unless the slab allocator is
     * used, after writing the tuple, pfree() the out-of-line data (not the
     * SortTuple struct!), and increase state->availMem by the amount of
     * memory space thereby released.
     */
    void        (*writetup) (xk_pg_parser_Tuplesortstate *state, int32_t tapenum,
                             xk_pg_parser_SortTuple *stup);

    /*
     * Function to read a stored tuple from tape back into memory. 'len' is
     * the already-read length of the stored tuple.  The tuple is allocated
     * from the slab memory arena, or is palloc'd, see readtup_alloc().
     */
    void        (*readtup) (xk_pg_parser_Tuplesortstate *state, xk_pg_parser_SortTuple *stup,
                            int32_t tapenum, uint32_t len);

    /*
     * This array holds the tuples now in sort memory.  If we are in state
     * INITIAL, the tuples are in no particular order; if we are in state
     * SORTEDINMEM, the tuples are in final sorted order; in states BUILDRUNS
     * and FINALMERGE, the tuples are organized in "heap" order per Algorithm
     * H.  In state SORTEDONTAPE, the array is not used.
     */
    xk_pg_parser_SortTuple  *memtuples;        /* array of SortTuple structs */
    int32_t            memtupcount;    /* number of tuples currently present */
    int32_t            memtupsize;        /* allocated length of memtuples array */
    bool        growmemtuples;    /* memtuples' growth still underway? */

    /*
     * Memory for tuples is sometimes allocated using a simple slab allocator,
     * rather than with palloc().  Currently, we switch to slab allocation
     * when we start merging.  Merging only needs to keep a small, fixed
     * number of tuples in memory at any time, so we can avoid the
     * palloc/pfree overhead by recycling a fixed number of fixed-size slots
     * to hold the tuples.
     *
     * For the slab, we use one large allocation, divided into SLAB_SLOT_SIZE
     * slots.  The allocation is sized to have one slot per tape, plus one
     * additional slot.  We need that many slots to hold all the tuples kept
     * in the heap during merge, plus the one we have last returned from the
     * sort, with tuplesort_gettuple.
     *
     * Initially, all the slots are kept in a linked list of free slots.  When
     * a tuple is read from a tape, it is put to the next available slot, if
     * it fits.  If the tuple is larger than SLAB_SLOT_SIZE, it is palloc'd
     * instead.
     *
     * When we're done processing a tuple, we return the slot back to the free
     * list, or pfree() if it was palloc'd.  We know that a tuple was
     * allocated from the slab, if its pointer value is between
     * slabMemoryBegin and -End.
     *
     * When the slab allocator is used, the USEMEM/LACKMEM mechanism of
     * tracking memory usage is not used.
     */
    bool        slabAllocatorUsed;

    char       *slabMemoryBegin;    /* beginning of slab memory arena */
    char       *slabMemoryEnd;    /* end of slab memory arena */
    xk_pg_parser_SlabSlot   *slabFreeHead;    /* head of free list */

    /* Buffer size to use for reading input tapes, during merge. */
    size_t        read_buffer_size;

    /*
     * When we return a tuple to the caller in tuplesort_gettuple_XXX, that
     * came from a tape (that is, in TSS_SORTEDONTAPE or TSS_FINALMERGE
     * modes), we remember the tuple in 'lastReturnedTuple', so that we can
     * recycle the memory on next gettuple call.
     */
    void       *lastReturnedTuple;

    /*
     * While building initial runs, this is the current output run number.
     * Afterwards, it is the number of initial runs we made.
     */
    int32_t            currentRun;

    /*
     * Unless otherwise noted, all pointer variables below are pointers to
     * arrays of length maxTapes, holding per-tape data.
     */

    /*
     * This variable is only used during merge passes.  mergeactive[i] is true
     * if we are reading an input run from (actual) tape number i and have not
     * yet exhausted that run.
     */
    bool       *mergeactive;    /* active input run source? */

    /*
     * Variables for Algorithm D.  Note that destTape is a "logical" tape
     * number, ie, an index into the tp_xxx[] arrays.  Be careful to keep
     * "logical" and "actual" tape numbers straight!
     */
    int32_t            Level;            /* Knuth's l */
    int32_t            destTape;        /* current output tape (Knuth's j, less 1) */
    int32_t           *tp_fib;            /* Target Fibonacci run counts (A[]) */
    int32_t           *tp_runs;        /* # of real runs on each tape */
    int32_t           *tp_dummy;        /* # of dummy runs for each tape (D[]) */
    int32_t           *tp_tapenum;        /* Actual tape numbers (TAPE[]) */
    int32_t            activeTapes;    /* # of active input tapes in merge pass */

    /*
     * These variables are used after completion of sorting to keep track of
     * the next tuple to return.  (In the tape case, the tape's current read
     * position is also critical state.)
     */
    int32_t            result_tape;    /* actual tape number of finished output */
    int32_t            current;        /* array index (only used if SORTEDINMEM) */
    bool        eof_reached;    /* reached EOF (needed for cursors) */

    /* markpos_xxx holds marked position for mark and restore */
    int64_t        markpos_block;    /* tape block# (only used if SORTEDONTAPE) */
    int32_t            markpos_offset; /* saved "current", or offset in tape block */
    bool        markpos_eof;    /* saved "eof_reached" */

    /*
     * These variables are used during parallel sorting.
     *
     * worker is our worker identifier.  Follows the general convention that
     * -1 value relates to a leader tuplesort, and values >= 0 worker
     * tuplesorts. (-1 can also be a serial tuplesort.)
     *
     * shared is mutable shared memory state, which is used to coordinate
     * parallel sorts.
     *
     * nParticipants is the number of worker Tuplesortstates known by the
     * leader to have actually been launched, which implies that they must
     * finish a run leader can merge.  Typically includes a worker state held
     * by the leader process itself.  Set in the leader Tuplesortstate only.
     */
    int32_t            worker;
    xk_pg_parser_Sharedsort *shared;
    int32_t            nParticipants;

    /*
     * The sortKeys variable is used by every case other than the hash index
     * case; it is set by tuplesort_begin_xxx.  tupDesc is only used by the
     * MinimalTuple and CLUSTER routines, though.
     */
    xk_pg_parser_TupleDesc    tupDesc;
    xk_pg_parser_SortSupport sortKeys;        /* array of length nKeys */

    /*
     * This variable is shared by the single-key MinimalTuple case and the
     * Datum case (which both use qsort_ssup()).  Otherwise it's NULL.
     */
    xk_pg_parser_SortSupport onlyKey;

    /*
     * Additional state for managing "abbreviated key" sortsupport routines
     * (which currently may be used by all cases except the hash index case).
     * Tracks the intervals at which the optimization's effectiveness is
     * tested.
     */
    int64_t        abbrevNext;        /* Tuple # at which to next check
                                 * applicability */

    /*
     * These variables are specific to the CLUSTER case; they are set by
     * tuplesort_begin_cluster.
     */
    struct xk_pg_parser_IndexInfo  *indexInfo;        /* info about index being used for reference */
    xk_pg_parser_EState       *estate;            /* for evaluating index expressions */

    /*
     * These variables are specific to the IndexTuple case; they are set by
     * tuplesort_begin_index_xxx and used only by the IndexTuple routines.
     */
    xk_pg_parser_Relation    heapRel;        /* table the index is being built on */
    xk_pg_parser_Relation    indexRel;        /* index being built */

    /* These are specific to the index_btree subcase: */
    bool        enforceUnique;    /* complain if we find duplicate tuples */

    /* These are specific to the index_hash subcase: */
    uint32_t        high_mask;        /* masks for sortable part of hash code */
    uint32_t        low_mask;
    uint32_t        max_buckets;

    /*
     * These variables are specific to the Datum case; they are set by
     * tuplesort_begin_datum and used only by the DatumTuple routines.
     */
    uint32_t            datumType;
    /* we need typelen in order to know how to copy the Datums. */
    int32_t            datumTypeLen;

    /*
     * Resource snapshot for time of sort start.
     */
}xk_pg_parser_Tuplesortstate;

typedef struct xk_pg_parser_AggStatePerTransData
{
    /*
     * These values are set up during ExecInitAgg() and do not change
     * thereafter:
     */

    /*
     * Link to an Aggref expr this state value is for.
     *
     * There can be multiple Aggref's sharing the same state value, so int64_t as
     * the inputs and transition functions are identical and the final
     * functions are not read-write.  This points to the first one of them.
     */
    xk_pg_parser_Aggref       *aggref;

    /*
     * Is this state value actually being shared by more than one Aggref?
     */
    bool        aggshared;

    /*
     * Number of aggregated input columns.  This includes ORDER BY expressions
     * in both the plain-agg and ordered-set cases.  Ordered-set direct args
     * are not counted, though.
     */
    int32_t            numInputs;

    /*
     * Number of aggregated input columns to pass to the transfn.  This
     * includes the ORDER BY columns for ordered-set aggs, but not for plain
     * aggs.  (This doesn't count the transition state value!)
     */
    int32_t            numTransInputs;

    /* Oid of the state transition or combine function */
    uint32_t            transfn_oid;

    /* Oid of the serialization function or InvalidOid */
    uint32_t            serialfn_oid;

    /* Oid of the deserialization function or InvalidOid */
    uint32_t            deserialfn_oid;

    /* Oid of state value's datatype */
    uint32_t            aggtranstype;

    /*
     * fmgr lookup data for transition function or combine function.  Note in
     * particular that the fn_strict flag is kept here.
     */
    xk_pg_parser_FmgrInfo    transfn;

    /* fmgr lookup data for serialization function */
    xk_pg_parser_FmgrInfo    serialfn;

    /* fmgr lookup data for deserialization function */
    xk_pg_parser_FmgrInfo    deserialfn;

    /* Input collation derived for aggregate */
    uint32_t            aggCollation;

    /* number of sorting columns */
    int32_t            numSortCols;

    /* number of sorting columns to consider in DISTINCT comparisons */
    /* (this is either zero or the same as numSortCols) */
    int32_t            numDistinctCols;

    /* deconstructed sorting information (arrays of length numSortCols) */
    xk_pg_parser_AttrNumber *sortColIdx;
    uint32_t           *sortOperators;
    uint32_t           *sortCollations;
    bool       *sortNullsFirst;

    /*
     * Comparators for input columns --- only set/used when aggregate has
     * DISTINCT flag. equalfnOne version is used for single-column
     * comparisons, equalfnMulti for the case of multiple columns.
     */
    xk_pg_parser_FmgrInfo    equalfnOne;
    xk_pg_parser_ExprState  *equalfnMulti;

    /*
     * initial value from pg_aggregate entry
     */
    xk_pg_parser_Datum        initValue;
    bool        initValueIsNull;

    /*
     * We need the len and byval info for the agg's input and transition data
     * types in order to know how to copy/delete values.
     *
     * Note that the info for the input type is used only when handling
     * DISTINCT aggs with just one argument, so there is only one input type.
     */
    int16_t        inputtypeLen,
                transtypeLen;
    bool        inputtypeByVal,
                transtypeByVal;

    /*
     * Slots for holding the evaluated input arguments.  These are set up
     * during ExecInitAgg() and then used for each input row requiring either
     * FILTER or ORDER BY/DISTINCT processing.
     */
    xk_pg_parser_TupleTableSlot *sortslot;    /* current input tuple */
    xk_pg_parser_TupleTableSlot *uniqslot;    /* used for multi-column DISTINCT */
    xk_pg_parser_TupleDesc    sortdesc;        /* descriptor of input tuples */

    /*
     * These values are working state that is initialized at the start of an
     * input tuple group and updated for each input tuple.
     *
     * For a simple (non DISTINCT/ORDER BY) aggregate, we just feed the input
     * values straight to the transition function.  If it's DISTINCT or
     * requires ORDER BY, we pass the input values into a Tuplesort object;
     * then at completion of the input tuple group, we scan the sorted values,
     * eliminate duplicates if needed, and run the transition function on the
     * rest.
     *
     * We need a separate tuplesort for each grouping set.
     */

    xk_pg_parser_Tuplesortstate **sortstates;    /* sort objects, if DISTINCT or ORDER BY */

    /*
     * This field is a pre-initialized FunctionCallInfo struct used for
     * calling this aggregate's transfn.  We save a few cycles per row by not
     * re-initializing the unchanging fields; which isn't much, but it seems
     * worth the extra space consumption.
     */
    xk_pg_parser_FunctionCallInfo transfn_fcinfo;

    /* Likewise for serialization and deserialization functions */
    xk_pg_parser_FunctionCallInfo serialfn_fcinfo;

    xk_pg_parser_FunctionCallInfo deserialfn_fcinfo;
}xk_pg_parser_AggStatePerTransData;

typedef struct xk_pg_parser_AggStatePerTransData *xk_pg_parser_AggStatePerTrans;

typedef struct xk_pg_parser_AggStatePerGroupData
{
#define FIELDNO_AGGSTATEPERGROUPDATA_TRANSVALUE 0
    xk_pg_parser_Datum        transValue;        /* current transition value */
#define FIELDNO_AGGSTATEPERGROUPDATA_TRANSVALUEISNULL 1
    bool        transValueIsNull;

#define FIELDNO_AGGSTATEPERGROUPDATA_NOTRANSVALUE 2
    bool        noTransValue;    /* true if transValue not set yet */

    /*
     * Note: noTransValue initially has the same value as transValueIsNull,
     * and if true both are cleared to false at the same time.  They are not
     * the same though: if transfn later returns a NULL, we want to keep that
     * NULL and not auto-replace it with a later input value. Only the first
     * non-NULL input will be auto-substituted.
     */
}xk_pg_parser_AggStatePerGroupData;

typedef struct xk_pg_parser_AggStatePerGroupData *xk_pg_parser_AggStatePerGroup;

typedef struct xk_pg_parser_TupleHashEntryData
{
    xk_pg_parser_MinimalTuple firstTuple;    /* copy of first tuple in this group */
    void       *additional;        /* user data */
    uint32_t        status;            /* hash status */
    uint32_t        hash;            /* hash value (cached) */
} xk_pg_parser_TupleHashEntryData;

typedef struct xk_pg_parser_tuplehash_hash
{
    /*
     * Size of data / bucket array, 64 bits to handle UINT32_MAX sized hash
     * tables.  Note that the maximum number of elements is lower
     * (SH_MAX_FILLFACTOR)
     */
    uint64_t        size;

    /* how many elements have valid contents */
    uint32_t        members;

    /* mask for bucket and size calculations, based on size */
    uint32_t        sizemask;

    /* boundary after which to grow hashtable */
    uint32_t        grow_threshold;

    /* hash buckets */
    xk_pg_parser_TupleHashEntryData *data;

    /* memory context to use for allocations */
    xk_pg_parser_MemoryContext ctx;

    /* user defined data, useful for callbacks */
    void       *private_data;
}xk_pg_parser_tuplehash_hash;

typedef struct xk_pg_parser_TupleHashTableData
{
    xk_pg_parser_tuplehash_hash *hashtab;    /* underlying hash table */
    int32_t            numCols;        /* number of columns in lookup key */
    xk_pg_parser_AttrNumber *keyColIdx;        /* attr numbers of key columns */
    xk_pg_parser_FmgrInfo   *tab_hash_funcs; /* hash functions for table datatype(s) */
    xk_pg_parser_ExprState  *tab_eq_func;    /* comparator for table datatype(s) */
    uint32_t           *tab_collations; /* collations for hash and comparison */
    xk_pg_parser_MemoryContext tablecxt;        /* memory context containing table */
    xk_pg_parser_MemoryContext tempcxt;        /* context for function evaluations */
    size_t        entrysize;        /* actual size to make each hash entry */
    xk_pg_parser_TupleTableSlot *tableslot;    /* slot for referencing table entries */
    /* The following fields are set transiently for each table search: */
    xk_pg_parser_TupleTableSlot *inputslot;    /* current input tuple's slot */
    xk_pg_parser_FmgrInfo   *in_hash_funcs;    /* hash functions for input datatype(s) */
    xk_pg_parser_ExprState  *cur_eq_func;    /* comparator for input vs. table */
    uint32_t        hash_iv;        /* hash-function IV */
    xk_pg_parser_ExprContext *exprcontext;    /* expression context */
}xk_pg_parser_TupleHashTableData;

typedef struct xk_pg_parser_TupleHashTableData *xk_pg_parser_TupleHashTable;

typedef struct xk_pg_parser_tuplehash_iterator
{
    uint32_t        cur;            /* current element */
    uint32_t        end;
    bool        done;            /* iterator exhausted? */
}xk_pg_parser_tuplehash_iterator;

typedef xk_pg_parser_tuplehash_iterator xk_pg_parser_TupleHashIterator;

typedef struct xk_pg_parser_AggStatePerHashData
{
    xk_pg_parser_TupleHashTable hashtable;    /* hash table with one entry per group */
    xk_pg_parser_TupleHashIterator hashiter; /* for iterating through hash table */
    xk_pg_parser_TupleTableSlot *hashslot;    /* slot for loading hash table */
    xk_pg_parser_FmgrInfo   *hashfunctions;    /* per-grouping-field hash fns */
    uint32_t           *eqfuncoids;        /* per-grouping-field equality fns */
    int32_t            numCols;        /* number of hash key columns */
    int32_t            numhashGrpCols; /* number of columns in hash table */
    int32_t            largestGrpColIdx;    /* largest col required for hashing */
    xk_pg_parser_AttrNumber *hashGrpColIdxInput; /* hash col indices in input slot */
    xk_pg_parser_AttrNumber *hashGrpColIdxHash;    /* indices in hashtbl tuples */
    xk_pg_parser_Agg           *aggnode;        /* original Agg node, for numGroups etc. */
} xk_pg_parser_AggStatePerHashData;

typedef struct xk_pg_parser_AggStatePerHashData *xk_pg_parser_AggStatePerHash;

typedef struct xk_pg_parser_ProjectionInfo
{
    xk_pg_parser_NodeTag        type;
    /* instructions to evaluate projection */
    xk_pg_parser_ExprState    pi_state;
    /* expression context in which to evaluate expression */
    xk_pg_parser_ExprContext *pi_exprContext;
} xk_pg_parser_ProjectionInfo;

typedef struct xk_pg_parser_PlanState xk_pg_parser_PlanState;

typedef struct xk_pg_parser_ScanState
{
    struct xk_pg_parser_PlanState    ps;                /* its first field is NodeTag */
    xk_pg_parser_Relation    ss_currentRelation;
    struct TableScanDescData *ss_currentScanDesc;
    xk_pg_parser_TupleTableSlot *ss_ScanTupleSlot;
} xk_pg_parser_ScanState;

typedef struct xk_pg_parser_AggState
{
    xk_pg_parser_ScanState    ss;                /* its first field is NodeTag */
    xk_pg_parser_List       *aggs;            /* all Aggref nodes in targetlist & quals */
    int32_t            numaggs;        /* length of list (could be zero!) */
    int32_t            numtrans;        /* number of pertrans items */
    xk_pg_parser_AggStrategy aggstrategy;    /* strategy mode */
    xk_pg_parser_AggSplit    aggsplit;        /* agg-splitting mode, see nodes.h */
    xk_pg_parser_AggStatePerPhase phase;        /* pointer to current phase data */
    int32_t            numphases;        /* number of phases (including phase 0) */
    int32_t            current_phase;    /* current phase number */
    xk_pg_parser_AggStatePerAgg peragg;        /* per-Aggref information */
    xk_pg_parser_AggStatePerTrans pertrans;    /* per-Trans state information */
    xk_pg_parser_ExprContext *hashcontext;    /* econtexts for int64_t-lived data (hashtable) */
    xk_pg_parser_ExprContext **aggcontexts;    /* econtexts for int64_t-lived data (per GS) */
    xk_pg_parser_ExprContext *tmpcontext;    /* econtext for input expressions */
#define FIELDNO_AGGSTATE_CURAGGCONTEXT 14
    xk_pg_parser_ExprContext *curaggcontext; /* currently active aggcontext */
    xk_pg_parser_AggStatePerAgg curperagg;    /* currently active aggregate, if any */
#define FIELDNO_AGGSTATE_CURPERTRANS 16
    xk_pg_parser_AggStatePerTrans curpertrans;    /* currently active trans state, if any */
    bool        input_done;        /* indicates end of input */
    bool        agg_done;        /* indicates completion of Agg scan */
    int32_t            projected_set;    /* The last projected grouping set */
#define FIELDNO_AGGSTATE_CURRENT_SET 20
    int32_t            current_set;    /* The current grouping set being evaluated */
    xk_pg_parser_Bitmapset  *grouped_cols;    /* grouped cols in current projection */
    xk_pg_parser_List       *all_grouped_cols;    /* list of all grouped cols in DESC order */
    /* These fields are for grouping set phase data */
    int32_t            maxsets;        /* The max number of sets in any phase */
    xk_pg_parser_AggStatePerPhase phases;    /* array of all phases */
    xk_pg_parser_Tuplesortstate *sort_in;    /* sorted input to phases > 1 */
    xk_pg_parser_Tuplesortstate *sort_out;    /* input is copied here for next phase */
    xk_pg_parser_TupleTableSlot *sort_slot;    /* slot for sort results */
    /* these fields are used in AGG_PLAIN and AGG_SORTED modes: */
    xk_pg_parser_AggStatePerGroup *pergroups;    /* grouping set indexed array of per-group
                                     * pointers */
    xk_pg_parser_HeapTuple    grp_firstTuple; /* copy of first tuple of current group */
    /* these fields are used in AGG_HASHED and AGG_MIXED modes: */
    bool        table_filled;    /* hash table filled yet? */
    int32_t            num_hashes;
    xk_pg_parser_AggStatePerHash perhash;    /* array of per-hashtable data */
    xk_pg_parser_AggStatePerGroup *hash_pergroup;    /* grouping set indexed array of
                                         * per-group pointers */

    /* support for evaluation of agg input expressions: */
#define FIELDNO_AGGSTATE_ALL_PERGROUPS 34
    xk_pg_parser_AggStatePerGroup *all_pergroups;    /* array of first ->pergroups, than
                                         * ->hash_pergroup */
    xk_pg_parser_ProjectionInfo *combinedproj;    /* projection machinery */
} xk_pg_parser_AggState;

typedef struct xk_pg_parser_WindowFuncExprState
{
    xk_pg_parser_NodeTag        type;
    xk_pg_parser_WindowFunc *wfunc;            /* expression plan node */
    xk_pg_parser_List       *args;            /* ExprStates for argument expressions */
    xk_pg_parser_ExprState  *aggfilter;        /* FILTER expression */
    int32_t            wfuncno;        /* ID number for wfunc within its plan node */
} xk_pg_parser_WindowFuncExprState;

typedef struct xk_pg_parser_SubPlanState
{
    xk_pg_parser_NodeTag        type;
    xk_pg_parser_SubPlan    *subplan;        /* expression plan node */
    struct xk_pg_parser_PlanState *planstate;    /* subselect plan's state tree */
    struct xk_pg_parser_PlanState *parent;    /* parent plan node's state tree */
    xk_pg_parser_ExprState  *testexpr;        /* state of combining expression */
    xk_pg_parser_List       *args;            /* states of argument expression(s) */
    xk_pg_parser_HeapTuple    curTuple;        /* copy of most recent tuple from subplan */
    xk_pg_parser_Datum        curArray;        /* most recent array from ARRAY() subplan */
    /* these are used when hashing the subselect's output: */
    xk_pg_parser_TupleDesc    descRight;        /* subselect desc after projection */
    xk_pg_parser_ProjectionInfo *projLeft;    /* for projecting lefthand exprs */
    xk_pg_parser_ProjectionInfo *projRight;    /* for projecting subselect output */
    xk_pg_parser_TupleHashTable hashtable;    /* hash table for no-nulls subselect rows */
    xk_pg_parser_TupleHashTable hashnulls;    /* hash table for rows with null(s) */
    bool        havehashrows;    /* true if hashtable is not empty */
    bool        havenullrows;    /* true if hashnulls is not empty */
    xk_pg_parser_MemoryContext hashtablecxt; /* memory context containing hash tables */
    xk_pg_parser_MemoryContext hashtempcxt;    /* temp memory context for hash tables */
    xk_pg_parser_ExprContext *innerecontext; /* econtext for computing inner tuples */
    /* each of the following fields is an array of length numCols: */
    xk_pg_parser_AttrNumber *keyColIdx;        /* control data for hash tables */
    uint32_t           *tab_eq_funcoids;    /* equality func oids for table
                                     * datatype(s) */
    uint32_t           *tab_collations; /* collations for hash and comparison */
    xk_pg_parser_FmgrInfo   *tab_hash_funcs; /* hash functions for table datatype(s) */
    xk_pg_parser_FmgrInfo   *tab_eq_funcs;    /* equality functions for table datatype(s) */
    xk_pg_parser_FmgrInfo   *lhs_hash_funcs; /* hash functions for lefthand datatype(s) */
    xk_pg_parser_FmgrInfo   *cur_eq_funcs;    /* equality functions for LHS vs. table */
    xk_pg_parser_ExprState  *cur_eq_comp;    /* equality comparator for LHS vs. table */
    int32_t            numCols;        /* number of columns being hashed */
} xk_pg_parser_SubPlanState;

typedef struct xk_pg_parser_AlternativeSubPlanState
{
    xk_pg_parser_NodeTag        type;
    xk_pg_parser_AlternativeSubPlan *subplan;    /* expression plan node */
    xk_pg_parser_List       *subplans;        /* SubPlanStates of alternative subplans */
    int32_t            active;            /* list index of the one we're using */
} xk_pg_parser_AlternativeSubPlanState;


typedef struct xk_pg_parser_ExprEvalStep
{
    /*
     * Instruction to be executed.  During instruction preparation this is an
     * enum ExprEvalOp, but later it can be changed to some other type, e.g. a
     * pointer for computed goto (that's why it's an intptr_t).
     */
    intptr_t    opcode;

    /* where to store the result of this step */
    xk_pg_parser_Datum       *resvalue;
    bool       *resnull;

    /*
     * Inline data for the operation.  Inline data is faster to access, but
     * also bloats the size of all instructions.  The union should be kept to
     * no more than 40 bytes on 64-bit systems (so that the entire struct is
     * no more than 64 bytes, a single cacheline on common systems).
     */
    union
    {
        /* for EEOP_INNER/OUTER/SCAN_FETCHSOME */
        struct
        {
            /* attribute number up to which to fetch (inclusive) */
            int32_t            last_var;
            /* will the type of slot be the same for every invocation */
            bool        fixed;
            /* tuple descriptor, if known */
            xk_pg_parser_TupleDesc    known_desc;
            /* type of slot, can only be relied upon if fixed is set */
            const xk_pg_parser_TupleTableSlotOps *kind;
        }            fetch;

        /* for EEOP_INNER/OUTER/SCAN_[SYS]VAR[_FIRST] */
        struct
        {
            /* attnum is attr number - 1 for regular VAR ... */
            /* but it's just the normal (negative) attr number for SYSVAR */
            int32_t            attnum;
            uint32_t            vartype;    /* type OID of variable */
        }            var;

        /* for EEOP_WHOLEROW */
        struct
        {
            xk_pg_parser_Var           *var;    /* original Var node in plan tree */
            bool        first;    /* first time through, need to initialize? */
            bool        slow;    /* need runtime check for nulls? */
            xk_pg_parser_TupleDesc    tupdesc;    /* descriptor for resulting tuples */
            xk_pg_parser_JunkFilter *junkFilter; /* xk_pg_parser_JunkFilter to remove resjunk cols */
        }            wholerow;

        /* for EEOP_ASSIGN_*_VAR */
        struct
        {
            /* target index in ExprState->resultslot->tts_values/nulls */
            int32_t            resultnum;
            /* source attribute number - 1 */
            int32_t            attnum;
        }            assign_var;

        /* for EEOP_ASSIGN_TMP[_MAKE_RO] */
        struct
        {
            /* target index in ExprState->resultslot->tts_values/nulls */
            int32_t            resultnum;
        }            assign_tmp;

        /* for EEOP_CONST */
        struct
        {
            /* constant's value */
            xk_pg_parser_Datum        value;
            bool        isnull;
        }            constval;

        /* for EEOP_FUNCEXPR_* / NULLIF / DISTINCT */
        struct
        {
            xk_pg_parser_FmgrInfo   *finfo;    /* function's lookup data */
            xk_pg_parser_FunctionCallInfo fcinfo_data;    /* arguments etc */
            /* faster to access without additional indirection: */
            xk_pg_parser_PGFunction    fn_addr;    /* actual call address */
            int32_t            nargs;    /* number of arguments */
        }            func;

        /* for EEOP_BOOL_*_STEP */
        struct
        {
            bool       *anynull;    /* track if any input was NULL */
            int32_t            jumpdone;    /* jump here if result determined */
        }            boolexpr;

        /* for EEOP_QUAL */
        struct
        {
            int32_t            jumpdone;    /* jump here on false or null */
        }            qualexpr;

        /* for EEOP_JUMP[_CONDITION] */
        struct
        {
            int32_t            jumpdone;    /* target instruction's index */
        }            jump;

        /* for EEOP_NULLTEST_ROWIS[NOT]NULL */
        struct
        {
            /* cached descriptor for composite type - filled at runtime */
            xk_pg_parser_ExprEvalRowtypeCache rowcache;
        }            nulltest_row;

        /* for EEOP_PARAM_EXEC/EXTERN */
        struct
        {
            int32_t            paramid;    /* numeric ID for parameter */
            uint32_t            paramtype;    /* OID of parameter's datatype */
        }            param;

        /* for EEOP_PARAM_CALLBACK */
        struct
        {
            xk_pg_parser_ExecEvalSubroutine paramfunc;    /* add-on evaluation subroutine */
            void       *paramarg;    /* private data for same */
            int32_t            paramid;    /* numeric ID for parameter */
            uint32_t            paramtype;    /* OID of parameter's datatype */
        }            cparam;

        /* for EEOP_CASE_TESTVAL/DOMAIN_TESTVAL */
        struct
        {
            xk_pg_parser_Datum       *value;    /* value to return */
            bool       *isnull;
        }            casetest;

        /* for EEOP_MAKE_READONLY */
        struct
        {
            xk_pg_parser_Datum       *value;    /* value to coerce to read-only */
            bool       *isnull;
        }            make_readonly;

        /* for EEOP_IOCOERCE */
        struct
        {
            /* lookup and call info for source type's output function */
            xk_pg_parser_FmgrInfo   *finfo_out;
            xk_pg_parser_FunctionCallInfo fcinfo_data_out;
            /* lookup and call info for result type's input function */
            xk_pg_parser_FmgrInfo   *finfo_in;
            xk_pg_parser_FunctionCallInfo fcinfo_data_in;
        }            iocoerce;

        /* for EEOP_SQLVALUEFUNCTION */
        struct
        {
            xk_pg_parser_SQLValueFunction *svf;
        }            sqlvaluefunction;

        /* for EEOP_NEXTVALUEEXPR */
        struct
        {
            uint32_t            seqid;
            uint32_t            seqtypid;
        }            nextvalueexpr;

        /* for EEOP_ARRAYEXPR */
        struct
        {
            xk_pg_parser_Datum       *elemvalues; /* element values get stored here */
            bool       *elemnulls;
            int32_t            nelems; /* length of the above arrays */
            uint32_t            elemtype;    /* array element type */
            int16_t        elemlength; /* typlen of the array element type */
            bool        elembyval;    /* is the element type pass-by-value? */
            char        elemalign;    /* typalign of the element type */
            bool        multidims;    /* is array expression multi-D? */
        }            arrayexpr;

        /* for EEOP_ARRAYCOERCE */
        struct
        {
            xk_pg_parser_ExprState  *elemexprstate;    /* null if no per-element work */
            uint32_t            resultelemtype; /* element type of result array */
            struct xk_pg_parser_ArrayMapState *amstate;    /* workspace for array_map */
        }            arraycoerce;

        /* for EEOP_ROW */
        struct
        {
            xk_pg_parser_TupleDesc    tupdesc;    /* descriptor for result tuples */
            /* workspace for the values constituting the row: */
            xk_pg_parser_Datum       *elemvalues;
            bool       *elemnulls;
        }            row;

        /* for EEOP_ROWCOMPARE_STEP */
        struct
        {
            /* lookup and call data for column comparison function */
            xk_pg_parser_FmgrInfo   *finfo;
            xk_pg_parser_FunctionCallInfo fcinfo_data;
            xk_pg_parser_PGFunction    fn_addr;
            /* target for comparison resulting in NULL */
            int32_t            jumpnull;
            /* target for comparison yielding inequality */
            int32_t            jumpdone;
        }            rowcompare_step;

        /* for EEOP_ROWCOMPARE_FINAL */
        struct
        {
            xk_pg_parser_RowCompareType rctype;
        }            rowcompare_final;

        /* for EEOP_MINMAX */
        struct
        {
            /* workspace for argument values */
            xk_pg_parser_Datum       *values;
            bool       *nulls;
            int32_t            nelems;
            /* is it GREATEST or LEAST? */
            xk_pg_parser_MinMaxOp    op;
            /* lookup and call data for comparison function */
            xk_pg_parser_FmgrInfo   *finfo;
            xk_pg_parser_FunctionCallInfo fcinfo_data;
        }            minmax;

        /* for EEOP_FIELDSELECT */
        struct
        {
            xk_pg_parser_AttrNumber    fieldnum;    /* field number to extract */
            uint32_t            resulttype; /* field's type */
            /* cached descriptor for composite type - filled at runtime */
            xk_pg_parser_ExprEvalRowtypeCache rowcache;
        }            fieldselect;

        /* for EEOP_FIELDSTORE_DEFORM / FIELDSTORE_FORM */
        struct
        {
            /* original expression node */
            xk_pg_parser_FieldStore *fstore;

            /* cached descriptor for composite type - filled at runtime */
            /* note that a DEFORM and FORM pair share the same cache */
            xk_pg_parser_ExprEvalRowtypeCache *rowcache;

            /* workspace for column values */
            xk_pg_parser_Datum       *values;
            bool       *nulls;
            int32_t            ncolumns;
        }            fieldstore;

        /* for EEOP_SBSREF_SUBSCRIPT */
        struct
        {
            /* too big to have inline */
            struct xk_pg_parser_SubscriptingRefState *state;
            int32_t            off;    /* 0-based index of this subscript */
            bool        isupper;    /* is it upper or lower subscript? */
            int32_t            jumpdone;    /* jump here on null */
        }            sbsref_subscript;

        /* for EEOP_SBSREF_OLD / ASSIGN / FETCH */
        struct
        {
            /* too big to have inline */
            struct xk_pg_parser_SubscriptingRefState *state;
        }            sbsref;

        /* for EEOP_DOMAIN_NOTNULL / DOMAIN_CHECK */
        struct
        {
            /* name of constraint */
            char       *constraintname;
            /* where the result of a CHECK constraint will be stored */
            xk_pg_parser_Datum       *checkvalue;
            bool       *checknull;
            /* OID of domain type */
            uint32_t            resulttype;
        }            domaincheck;

        /* for EEOP_CONVERT_ROWTYPE */
        struct
        {
            uint32_t            inputtype;    /* input composite type */
            uint32_t            outputtype; /* output composite type */
            /* these three fields are filled at runtime: */
            xk_pg_parser_ExprEvalRowtypeCache *incache;    /* cache for input type */
            xk_pg_parser_ExprEvalRowtypeCache *outcache; /* cache for output type */
            xk_pg_parser_TupleConversionMap *map;    /* column mapping */
        }            convert_rowtype;

        /* for EEOP_SCALARARRAYOP */
        struct
        {
            /* element_type/typlen/typbyval/typalign are filled at runtime */
            uint32_t            element_type;    /* InvalidOid if not yet filled */
            bool        useOr;    /* use OR or AND semantics? */
            int16_t        typlen; /* array element type storage info */
            bool        typbyval;
            char        typalign;
            xk_pg_parser_FmgrInfo   *finfo;    /* function's lookup data */
            xk_pg_parser_FunctionCallInfo fcinfo_data;    /* arguments etc */
            /* faster to access without additional indirection: */
            xk_pg_parser_PGFunction    fn_addr;    /* actual call address */
        }            scalararrayop;

        /* for EEOP_XMLEXPR */
        struct
        {
            xk_pg_parser_XmlExpr    *xexpr;    /* original expression node */
            /* workspace for evaluating named args, if any */
            xk_pg_parser_Datum       *named_argvalue;
            bool       *named_argnull;
            /* workspace for evaluating unnamed args, if any */
            xk_pg_parser_Datum       *argvalue;
            bool       *argnull;
        }            xmlexpr;

        /* for EEOP_AGGREF */
        struct
        {
            /* out-of-line state, modified by nodeAgg.c */
            xk_pg_parser_AggrefExprState *astate;
        }            aggref;

        /* for EEOP_GROUPING_FUNC */
        struct
        {
            xk_pg_parser_AggState   *parent; /* parent Agg */
            xk_pg_parser_List       *clauses;    /* integer list of column numbers */
        }            grouping_func;

        /* for EEOP_WINDOW_FUNC */
        struct
        {
            /* out-of-line state, modified by nodeWindowFunc.c */
            xk_pg_parser_WindowFuncExprState *wfstate;
        }            window_func;

        /* for EEOP_SUBPLAN */
        struct
        {
            /* out-of-line state, created by nodeSubplan.c */
            xk_pg_parser_SubPlanState *sstate;
        }            subplan;

        /* for EEOP_ALTERNATIVE_SUBPLAN */
        struct
        {
            /* out-of-line state, created by nodeSubplan.c */
            xk_pg_parser_AlternativeSubPlanState *asstate;
        }            alternative_subplan;

        /* for EEOP_AGG_*DESERIALIZE */
        struct
        {
            xk_pg_parser_AggState   *aggstate;
            xk_pg_parser_FunctionCallInfo fcinfo_data;
            int32_t            jumpnull;
        }            agg_deserialize;

        /* for EEOP_AGG_STRICT_INPUT_CHECK_NULLS / STRICT_INPUT_CHECK_ARGS */
        struct
        {
            /*
             * For EEOP_AGG_STRICT_INPUT_CHECK_ARGS args contains pointers to
             * the NullableDatums that need to be checked for NULLs.
             *
             * For EEOP_AGG_STRICT_INPUT_CHECK_NULLS nulls contains pointers
             * to booleans that need to be checked for NULLs.
             *
             * Both cases currently need to exist because sometimes the
             * to-be-checked nulls are in TupleTableSlot.isnull array, and
             * sometimes in FunctionCallInfoBaseData.args[i].isnull.
             */
            xk_pg_parser_NullableDatum *args;
            bool       *nulls;
            int32_t            nargs;
            int32_t            jumpnull;
        }            agg_strict_input_check;

        /* for EEOP_AGG_INIT_TRANS */
        struct
        {
            xk_pg_parser_AggState   *aggstate;
            xk_pg_parser_AggStatePerTrans pertrans;
            xk_pg_parser_ExprContext *aggcontext;
            int32_t            setno;
            int32_t            transno;
            int32_t            setoff;
            int32_t            jumpnull;
        }            agg_init_trans;

        /* for EEOP_AGG_STRICT_TRANS_CHECK */
        struct
        {
            xk_pg_parser_AggState   *aggstate;
            int32_t            setno;
            int32_t            transno;
            int32_t            setoff;
            int32_t            jumpnull;
        }            agg_strict_trans_check;

        /* for EEOP_AGG_{PLAIN,ORDERED}_TRANS* */
        struct
        {
            xk_pg_parser_AggState   *aggstate;
            xk_pg_parser_AggStatePerTrans pertrans;
            xk_pg_parser_ExprContext *aggcontext;
            int32_t            setno;
            int32_t            transno;
            int32_t            setoff;
        }            agg_trans;
    }            d;
} xk_pg_parser_ExprEvalStep;

typedef xk_pg_parser_Datum (*xk_pg_parser_ExprStateEvalFunc) (struct xk_pg_parser_ExprState *expression,
                                    struct xk_pg_parser_ExprContext *econtext,
                                    bool *isNull);

typedef struct xk_pg_parser_ExprState
{
    xk_pg_parser_Node        tag;

    uint8_t        flags;            /* bitmask of EEO_FLAG_* bits, see above */

    /*
     * Storage for result value of a scalar expression, or for individual
     * column results within expressions built by ExecBuildProjectionInfo().
     */
#define FIELDNO_EXPRSTATE_RESNULL 2
    bool        resnull;
#define FIELDNO_EXPRSTATE_RESVALUE 3
    xk_pg_parser_Datum        resvalue;

    /*
     * If projecting a tuple result, this slot holds the result; else NULL.
     */
#define FIELDNO_EXPRSTATE_RESULTSLOT 4
    xk_pg_parser_TupleTableSlot *resultslot;

    /*
     * Instructions to compute expression's return value.
     */
    struct ExprEvalStep *steps;

    /*
     * Function that actually evaluates the expression.  This can be set to
     * different values depending on the complexity of the expression.
     */
    xk_pg_parser_ExprStateEvalFunc evalfunc;

    /* original expression tree, for debugging only */
    xk_pg_parser_Expr       *expr;

    /* private state for an evalfunc */
    void       *evalfunc_private;

    /*
     * XXX: following fields only needed during "compilation" (ExecInitExpr);
     * could be thrown away afterwards.
     */

    int32_t            steps_len;        /* number of steps currently */
    int32_t            steps_alloc;    /* allocated length of steps array */

    struct PlanState *parent;    /* parent PlanState node, if any */
    xk_pg_parser_ParamListInfo ext_params;    /* for compiling PARAM_EXTERN nodes */

    xk_pg_parser_Datum       *innermost_caseval;
    bool       *innermost_casenull;

    xk_pg_parser_Datum       *innermost_domainval;
    bool       *innermost_domainnull;
} xk_pg_parser_ExprState;

typedef struct xk_pg_parser_IndexInfo
{
    xk_pg_parser_NodeTag        type;
    int32_t            ii_NumIndexAttrs;    /* total number of columns in index */
    int32_t            ii_NumIndexKeyAttrs;    /* number of key columns in index */
    xk_pg_parser_AttrNumber    ii_IndexAttrNumbers[32];
    xk_pg_parser_List       *ii_Expressions; /* list of Expr */
    xk_pg_parser_List       *ii_ExpressionsState;    /* list of ExprState */
    xk_pg_parser_List       *ii_Predicate;    /* list of Expr */
    xk_pg_parser_ExprState  *ii_PredicateState;
    uint32_t           *ii_ExclusionOps;    /* array with one entry per column */
    uint32_t           *ii_ExclusionProcs;    /* array with one entry per column */
    uint16_t       *ii_ExclusionStrats; /* array with one entry per column */
    uint32_t           *ii_UniqueOps;    /* array with one entry per column */
    uint32_t           *ii_UniqueProcs; /* array with one entry per column */
    uint16_t       *ii_UniqueStrats;    /* array with one entry per column */
    bool        ii_Unique;
    bool        ii_ReadyForInserts;
    bool        ii_Concurrent;
    bool        ii_BrokenHotChain;
    int32_t            ii_ParallelWorkers;
    uint32_t            ii_Am;
    void       *ii_AmCache;
    xk_pg_parser_MemoryContext ii_Context;
} xk_pg_parser_IndexInfo;

typedef void (*xk_pg_parser_IndexBuildCallback) (xk_pg_parser_Relation index,
                                    xk_pg_parser_HeapTuple htup,
                                    xk_pg_parser_Datum *values,
                                    bool *isnull,
                                    bool tupleIsAlive,
                                    void *state);

typedef struct xk_pg_parser_ValidateIndexState
{
    xk_pg_parser_Tuplesortstate *tuplesort;    /* for sorting the index TIDs */
    /* statistics (for debug purposes only): */
    double        htups,
                itups,
                tups_inserted;
} xk_pg_parser_ValidateIndexState;

typedef enum xk_pg_parser_ForkNumber
{
    InvalidForkNumber = -1,
    MAIN_FORKNUM = 0,
    FSM_FORKNUM,
    VISIBILITYMAP_FORKNUM,
    INIT_FORKNUM

    /*
     * NOTE: if you add a new fork, change MAX_FORKNUM and possibly
     * FORKNAMECHARS below, and update the forkNames array in
     * src/common/relpath.c
     */
} xk_pg_parser_ForkNumber;

typedef struct xk_pg_parser_TBMIterateResult
{
    xk_pg_parser_BlockNumber blockno;        /* page number containing tuples */
    int32_t         ntuples;        /* -1 indicates lossy result */
    bool        recheck;        /* should the tuples be rechecked? */
    /* Note: recheck is always true if ntuples < 0 */
    xk_pg_parser_OffsetNumber offsets[FLEXIBLE_ARRAY_MEMBER];
} xk_pg_parser_TBMIterateResult;

typedef struct xk_pg_parser_SampleScanState
{
    xk_pg_parser_ScanState    ss;
    xk_pg_parser_List       *args;            /* expr states for TABLESAMPLE params */
    xk_pg_parser_ExprState  *repeatable;        /* expr state for REPEATABLE expr */
    /* use struct pointer to avoid including tsmapi.h here */
    struct TsmRoutine *tsmroutine;    /* descriptor for tablesample method */
    void       *tsm_state;        /* tablesample method can keep state here */
    bool        use_bulkread;    /* use bulkread buffer access strategy? */
    bool        use_pagemode;    /* use page-at-a-time visibility checking? */
    bool        begun;            /* false means need to call BeginSampleScan */
    uint32_t        seed;            /* random seed */
    int64_t        donetuples;        /* number of tuples already returned */
    bool        haveblock;        /* has a block for sampling been determined */
    bool        done;            /* exhausted all tuples? */
} xk_pg_parser_SampleScanState;

typedef struct xk_pg_parser_TableAmRoutine
{
    /* this must be set to T_TableAmRoutine */
    xk_pg_parser_NodeTag        type;


    /* ------------------------------------------------------------------------
     * Slot related callbacks.
     * ------------------------------------------------------------------------
     */

    /*
     * Return slot implementation suitable for storing a tuple of this AM.
     */
    const xk_pg_parser_TupleTableSlotOps *(*slot_callbacks) (xk_pg_parser_Relation rel);


    /* ------------------------------------------------------------------------
     * Table scan callbacks.
     * ------------------------------------------------------------------------
     */

    /*
     * Start a scan of `rel`.  The callback has to return a TableScanDesc,
     * which will typically be embedded in a larger, AM specific, struct.
     *
     * If nkeys != 0, the results need to be filtered by those scan keys.
     *
     * pscan, if not NULL, will have already been initialized with
     * parallelscan_initialize(), and has to be for the same relation. Will
     * only be set coming from table_beginscan_parallel().
     *
     * `flags` is a bitmask indicating the type of scan (ScanOptions's
     * SO_TYPE_*, currently only one may be specified), options controlling
     * the scan's behaviour (ScanOptions's SO_ALLOW_*, several may be
     * specified, an AM may ignore unsupported ones) and whether the snapshot
     * needs to be deallocated at scan_end (ScanOptions's SO_TEMP_SNAPSHOT).
     */
    xk_pg_parser_TableScanDesc (*scan_begin) (xk_pg_parser_Relation rel,
                                 xk_pg_parser_Snapshot snapshot,
                                 int32_t nkeys, struct xk_pg_parser_ScanKeyData *key,
                                 xk_pg_parser_ParallelTableScanDesc pscan,
                                 uint32_t flags);

    /*
     * Release resources and deallocate scan. If TableScanDesc.temp_snap,
     * TableScanDesc.rs_snapshot needs to be unregistered.
     */
    void        (*scan_end) (xk_pg_parser_TableScanDesc scan);

    /*
     * Restart relation scan.  If set_params is set to true, allow_{strat,
     * sync, pagemode} (see scan_begin) changes should be taken into account.
     */
    void        (*scan_rescan) (xk_pg_parser_TableScanDesc scan, struct xk_pg_parser_ScanKeyData *key,
                                bool set_params, bool allow_strat,
                                bool allow_sync, bool allow_pagemode);

    /*
     * Return next tuple from `scan`, store in slot.
     */
    bool        (*scan_getnextslot) (xk_pg_parser_TableScanDesc scan,
                                     xk_pg_parser_ScanDirection direction,
                                     xk_pg_parser_TupleTableSlot *slot);


    /* ------------------------------------------------------------------------
     * Parallel table scan related functions.
     * ------------------------------------------------------------------------
     */

    /*
     * Estimate the size of shared memory needed for a parallel scan of this
     * relation. The snapshot does not need to be accounted for.
     */
    size_t        (*parallelscan_estimate) (xk_pg_parser_Relation rel);

    /*
     * Initialize ParallelTableScanDesc for a parallel scan of this relation.
     * `pscan` will be sized according to parallelscan_estimate() for the same
     * relation.
     */
    size_t        (*parallelscan_initialize) (xk_pg_parser_Relation rel,
                                            xk_pg_parser_ParallelTableScanDesc pscan);

    /*
     * Reinitialize `pscan` for a new scan. `rel` will be the same relation as
     * when `pscan` was initialized by parallelscan_initialize.
     */
    void        (*parallelscan_reinitialize) (xk_pg_parser_Relation rel,
                                              xk_pg_parser_ParallelTableScanDesc pscan);


    /* ------------------------------------------------------------------------
     * Index Scan Callbacks
     * ------------------------------------------------------------------------
     */

    /*
     * Prepare to fetch tuples from the relation, as needed when fetching
     * tuples for an index scan.  The callback has to return an
     * IndexFetchTableData, which the AM will typically embed in a larger
     * structure with additional information.
     *
     * Tuples for an index scan can then be fetched via index_fetch_tuple.
     */
    struct xk_pg_parser_IndexFetchTableData *(*index_fetch_begin) (xk_pg_parser_Relation rel);

    /*
     * Reset index fetch. Typically this will release cross index fetch
     * resources held in IndexFetchTableData.
     */
    void        (*index_fetch_reset) (struct xk_pg_parser_IndexFetchTableData *data);

    /*
     * Release resources and deallocate index fetch.
     */
    void        (*index_fetch_end) (struct xk_pg_parser_IndexFetchTableData *data);

    /*
     * Fetch tuple at `tid` into `slot`, after doing a visibility test
     * according to `snapshot`. If a tuple was found and passed the visibility
     * test, return true, false otherwise.
     *
     * Note that AMs that do not necessarily update indexes when indexed
     * columns do not change, need to return the current/correct version of
     * the tuple that is visible to the snapshot, even if the tid points to an
     * older version of the tuple.
     *
     * *call_again is false on the first call to index_fetch_tuple for a tid.
     * If there potentially is another tuple matching the tid, *call_again
     * needs be set to true by index_fetch_tuple, signalling to the caller
     * that index_fetch_tuple should be called again for the same tid.
     *
     * *all_dead, if all_dead is not NULL, should be set to true by
     * index_fetch_tuple iff it is guaranteed that no backend needs to see
     * that tuple. Index AMs can use that to avoid returning that tid in
     * future searches.
     */
    bool        (*index_fetch_tuple) (struct xk_pg_parser_IndexFetchTableData *scan,
                                      xk_pg_parser_ItemPointer tid,
                                      xk_pg_parser_Snapshot snapshot,
                                      xk_pg_parser_TupleTableSlot *slot,
                                      bool *call_again, bool *all_dead);


    /* ------------------------------------------------------------------------
     * Callbacks for non-modifying operations on individual tuples
     * ------------------------------------------------------------------------
     */

    /*
     * Fetch tuple at `tid` into `slot`, after doing a visibility test
     * according to `snapshot`. If a tuple was found and passed the visibility
     * test, returns true, false otherwise.
     */
    bool        (*tuple_fetch_row_version) (xk_pg_parser_Relation rel,
                                            xk_pg_parser_ItemPointer tid,
                                            xk_pg_parser_Snapshot snapshot,
                                            xk_pg_parser_TupleTableSlot *slot);

    /*
     * Is tid valid for a scan of this relation.
     */
    bool        (*tuple_tid_valid) (xk_pg_parser_TableScanDesc scan,
                                    xk_pg_parser_ItemPointer tid);

    /*
     * Return the latest version of the tuple at `tid`, by updating `tid` to
     * point at the newest version.
     */
    void        (*tuple_get_latest_tid) (xk_pg_parser_TableScanDesc scan,
                                         xk_pg_parser_ItemPointer tid);

    /*
     * Does the tuple in `slot` satisfy `snapshot`?  The slot needs to be of
     * the appropriate type for the AM.
     */
    bool        (*tuple_satisfies_snapshot) (xk_pg_parser_Relation rel,
                                             xk_pg_parser_TupleTableSlot *slot,
                                             xk_pg_parser_Snapshot snapshot);

    /* see table_compute_xid_horizon_for_tuples() */
    xk_pg_parser_TransactionId (*compute_xid_horizon_for_tuples) (xk_pg_parser_Relation rel,
                                                     xk_pg_parser_ItemPointerData *items,
                                                     int32_t nitems);


    /* ------------------------------------------------------------------------
     * Manipulations of physical tuples.
     * ------------------------------------------------------------------------
     */

    /* see table_tuple_insert() for reference about parameters */
    void        (*tuple_insert) (xk_pg_parser_Relation rel, xk_pg_parser_TupleTableSlot *slot,
                                 xk_pg_parser_CommandId cid, int32_t options,
                                 struct xk_pg_parser_BulkInsertStateData *bistate);

    /* see table_tuple_insert_speculative() for reference about parameters */
    void        (*tuple_insert_speculative) (xk_pg_parser_Relation rel,
                                             xk_pg_parser_TupleTableSlot *slot,
                                             xk_pg_parser_CommandId cid,
                                             int32_t options,
                                             struct xk_pg_parser_BulkInsertStateData *bistate,
                                             uint32_t specToken);

    /* see table_tuple_complete_speculative() for reference about parameters */
    void        (*tuple_complete_speculative) (xk_pg_parser_Relation rel,
                                               xk_pg_parser_TupleTableSlot *slot,
                                               uint32_t specToken,
                                               bool succeeded);

    /* see table_multi_insert() for reference about parameters */
    void        (*multi_insert) (xk_pg_parser_Relation rel, xk_pg_parser_TupleTableSlot **slots, int32_t nslots,
                                 xk_pg_parser_CommandId cid, int32_t options, struct xk_pg_parser_BulkInsertStateData *bistate);

    /* see table_tuple_delete() for reference about parameters */
    xk_pg_parser_TM_Result    (*tuple_delete) (xk_pg_parser_Relation rel,
                                 xk_pg_parser_ItemPointer tid,
                                 xk_pg_parser_CommandId cid,
                                 xk_pg_parser_Snapshot snapshot,
                                 xk_pg_parser_Snapshot crosscheck,
                                 bool wait,
                                 xk_pg_parser_TM_FailureData *tmfd,
                                 bool changingPart);

    /* see table_tuple_update() for reference about parameters */
    xk_pg_parser_TM_Result    (*tuple_update) (xk_pg_parser_Relation rel,
                                 xk_pg_parser_ItemPointer otid,
                                 xk_pg_parser_TupleTableSlot *slot,
                                 xk_pg_parser_CommandId cid,
                                 xk_pg_parser_Snapshot snapshot,
                                 xk_pg_parser_Snapshot crosscheck,
                                 bool wait,
                                 xk_pg_parser_TM_FailureData *tmfd,
                                 xk_pg_parser_LockTupleMode *lockmode,
                                 bool *update_indexes);

    /* see table_tuple_lock() for reference about parameters */
    xk_pg_parser_TM_Result    (*tuple_lock) (xk_pg_parser_Relation rel,
                               xk_pg_parser_ItemPointer tid,
                               xk_pg_parser_Snapshot snapshot,
                               xk_pg_parser_TupleTableSlot *slot,
                               xk_pg_parser_CommandId cid,
                               xk_pg_parser_LockTupleMode mode,
                               xk_pg_parser_LockWaitPolicy wait_policy,
                               uint8_t flags,
                               xk_pg_parser_TM_FailureData *tmfd);

    /*
     * Perform operations necessary to complete insertions made via
     * tuple_insert and multi_insert with a BulkInsertState specified. This
     * may for example be used to flush the relation, when the
     * TABLE_INSERT_SKIP_WAL option was used.
     *
     * Typically callers of tuple_insert and multi_insert will just pass all
     * the flags that apply to them, and each AM has to decide which of them
     * make sense for it, and then only take actions in finish_bulk_insert for
     * those flags, and ignore others.
     *
     * Optional callback.
     */
    void        (*finish_bulk_insert) (xk_pg_parser_Relation rel, int32_t options);


    /* ------------------------------------------------------------------------
     * DDL related functionality.
     * ------------------------------------------------------------------------
     */

    /*
     * This callback needs to create a new relation filenode for `rel`, with
     * appropriate durability behaviour for `persistence`.
     *
     * Note that only the subset of the relcache filled by
     * RelationBuildLocalRelation() can be relied upon and that the relation's
     * catalog entries will either not yet exist (new relation), or will still
     * reference the old relfilenode.
     *
     * As output *freezeXid, *minmulti must be set to the values appropriate
     * for pg_class.{relfrozenxid, relminmxid}. For AMs that don't need those
     * fields to be filled they can be set to InvalidTransactionId and
     * InvalidMultiXactId, respectively.
     *
     * See also table_relation_set_new_filenode().
     */
    void        (*relation_set_new_filenode) (xk_pg_parser_Relation rel,
                                              const xk_pg_parser_RelFileNode *newrnode,
                                              char persistence,
                                              xk_pg_parser_TransactionId *freezeXid,
                                              xk_pg_parser_MultiXactId *minmulti);

    /*
     * This callback needs to remove all contents from `rel`'s current
     * relfilenode. No provisions for transactional behaviour need to be made.
     * Often this can be implemented by truncating the underlying storage to
     * its minimal size.
     *
     * See also table_relation_nontransactional_truncate().
     */
    void        (*relation_nontransactional_truncate) (xk_pg_parser_Relation rel);

    /*
     * See table_relation_copy_data().
     *
     * This can typically be implemented by directly copying the underlying
     * storage, unless it contains references to the tablespace internally.
     */
    void        (*relation_copy_data) (xk_pg_parser_Relation rel,
                                       const xk_pg_parser_RelFileNode *newrnode);

    /* See table_relation_copy_for_cluster() */
    void        (*relation_copy_for_cluster) (xk_pg_parser_Relation NewTable,
                                              xk_pg_parser_Relation OldTable,
                                              xk_pg_parser_Relation OldIndex,
                                              bool use_sort,
                                              xk_pg_parser_TransactionId OldestXmin,
                                              xk_pg_parser_TransactionId *xid_cutoff,
                                              xk_pg_parser_MultiXactId *multi_cutoff,
                                              double *num_tuples,
                                              double *tups_vacuumed,
                                              double *tups_recently_dead);

    /*
     * React to VACUUM command on the relation. The VACUUM can be
     * triggered by a user or by autovacuum. The specific actions
     * performed by the AM will depend heavily on the individual AM.
     *
     * On entry a transaction is already established, and the relation is
     * locked with a ShareUpdateExclusive lock.
     *
     * Note that neither VACUUM FULL (and CLUSTER), nor ANALYZE go through
     * this routine, even if (for ANALYZE) it is part of the same VACUUM
     * command.
     *
     * There probably, in the future, needs to be a separate callback to
     * integrate with autovacuum's scheduling.
     */
    void        (*relation_vacuum) (xk_pg_parser_Relation onerel,
                                    struct VacuumParams *params,
                                    xk_pg_parser_BufferAccessStrategy bstrategy);

    /*
     * Prepare to analyze block `blockno` of `scan`. The scan has been started
     * with table_beginscan_analyze().  See also
     * table_scan_analyze_next_block().
     *
     * The callback may acquire resources like locks that are held until
     * table_scan_analyze_next_tuple() returns false. It e.g. can make sense
     * to hold a lock until all tuples on a block have been analyzed by
     * scan_analyze_next_tuple.
     *
     * The callback can return false if the block is not suitable for
     * sampling, e.g. because it's a metapage that could never contain tuples.
     *
     * XXX: This obviously is primarily suited for block-based AMs. It's not
     * clear what a good interface for non block based AMs would be, so there
     * isn't one yet.
     */
    bool        (*scan_analyze_next_block) (xk_pg_parser_TableScanDesc scan,
                                            xk_pg_parser_BlockNumber blockno,
                                            xk_pg_parser_BufferAccessStrategy bstrategy);

    /*
     * See table_scan_analyze_next_tuple().
     *
     * Not every AM might have a meaningful concept of dead rows, in which
     * case it's OK to not increment *deadrows - but note that that may
     * influence autovacuum scheduling (see comment for relation_vacuum
     * callback).
     */
    bool        (*scan_analyze_next_tuple) (xk_pg_parser_TableScanDesc scan,
                                            xk_pg_parser_TransactionId OldestXmin,
                                            double *liverows,
                                            double *deadrows,
                                            xk_pg_parser_TupleTableSlot *slot);

    /* see table_index_build_range_scan for reference about parameters */
    double        (*index_build_range_scan) (xk_pg_parser_Relation table_rel,
                                           xk_pg_parser_Relation index_rel,
                                           struct xk_pg_parser_IndexInfo *index_info,
                                           bool allow_sync,
                                           bool anyvisible,
                                           bool progress,
                                           xk_pg_parser_BlockNumber start_blockno,
                                           xk_pg_parser_BlockNumber numblocks,
                                           xk_pg_parser_IndexBuildCallback callback,
                                           void *callback_state,
                                           xk_pg_parser_TableScanDesc scan);

    /* see table_index_validate_scan for reference about parameters */
    void        (*index_validate_scan) (xk_pg_parser_Relation table_rel,
                                        xk_pg_parser_Relation index_rel,
                                        struct xk_pg_parser_IndexInfo *index_info,
                                        xk_pg_parser_Snapshot snapshot,
                                        struct xk_pg_parser_ValidateIndexState *state);


    /* ------------------------------------------------------------------------
     * Miscellaneous functions.
     * ------------------------------------------------------------------------
     */

    /*
     * See table_relation_size().
     *
     * Note that currently a few callers use the MAIN_FORKNUM size to figure
     * out the range of potentially interesting blocks (brin, analyze). It's
     * probable that we'll need to revise the interface for those at some
     * point.
     */
    uint64_t        (*relation_size) (xk_pg_parser_Relation rel, xk_pg_parser_ForkNumber forkNumber);


    /*
     * This callback should return true if the relation requires a TOAST table
     * and false if it does not.  It may wish to examine the relation's tuple
     * descriptor before making a decision, but if it uses some other method
     * of storing large values (or if it does not support them) it can simply
     * return false.
     */
    bool        (*relation_needs_toast_table) (xk_pg_parser_Relation rel);


    /* ------------------------------------------------------------------------
     * Planner related functions.
     * ------------------------------------------------------------------------
     */

    /*
     * See table_relation_estimate_size().
     *
     * While block oriented, it shouldn't be too hard for an AM that doesn't
     * internally use blocks to convert into a usable representation.
     *
     * This differs from the relation_size callback by returning size
     * estimates (both relation size and tuple count) for planning purposes,
     * rather than returning a currently correct estimate.
     */
    void        (*relation_estimate_size) (xk_pg_parser_Relation rel, int32_t *attr_widths,
                                           xk_pg_parser_BlockNumber *pages, double *tuples,
                                           double *allvisfrac);


    /* ------------------------------------------------------------------------
     * Executor related functions.
     * ------------------------------------------------------------------------
     */

    /*
     * Prepare to fetch / check / return tuples from `tbmres->blockno` as part
     * of a bitmap table scan. `scan` was started via table_beginscan_bm().
     * Return false if there are no tuples to be found on the page, true
     * otherwise.
     *
     * This will typically read and pin the target block, and do the necessary
     * work to allow scan_bitmap_next_tuple() to return tuples (e.g. it might
     * make sense to perform tuple visibility checks at this time). For some
     * AMs it will make more sense to do all the work referencing `tbmres`
     * contents here, for others it might be better to defer more work to
     * scan_bitmap_next_tuple.
     *
     * If `tbmres->blockno` is -1, this is a lossy scan and all visible tuples
     * on the page have to be returned, otherwise the tuples at offsets in
     * `tbmres->offsets` need to be returned.
     *
     * XXX: Currently this may only be implemented if the AM uses md.c as its
     * storage manager, and uses ItemPointer->ip_blkid in a manner that maps
     * blockids directly to the underlying storage. nodeBitmapHeapscan.c
     * performs prefetching directly using that interface.  This probably
     * needs to be rectified at a later point.
     *
     * XXX: Currently this may only be implemented if the AM uses the
     * visibilitymap, as nodeBitmapHeapscan.c unconditionally accesses it to
     * perform prefetching.  This probably needs to be rectified at a later
     * point.
     *
     * Optional callback, but either both scan_bitmap_next_block and
     * scan_bitmap_next_tuple need to exist, or neither.
     */
    bool        (*scan_bitmap_next_block) (xk_pg_parser_TableScanDesc scan,
                                           struct xk_pg_parser_TBMIterateResult *tbmres);

    /*
     * Fetch the next tuple of a bitmap table scan into `slot` and return true
     * if a visible tuple was found, false otherwise.
     *
     * For some AMs it will make more sense to do all the work referencing
     * `tbmres` contents in scan_bitmap_next_block, for others it might be
     * better to defer more work to this callback.
     *
     * Optional callback, but either both scan_bitmap_next_block and
     * scan_bitmap_next_tuple need to exist, or neither.
     */
    bool        (*scan_bitmap_next_tuple) (xk_pg_parser_TableScanDesc scan,
                                           struct xk_pg_parser_TBMIterateResult *tbmres,
                                           xk_pg_parser_TupleTableSlot *slot);

    /*
     * Prepare to fetch tuples from the next block in a sample scan. Return
     * false if the sample scan is finished, true otherwise. `scan` was
     * started via table_beginscan_sampling().
     *
     * Typically this will first determine the target block by calling the
     * TsmRoutine's NextSampleBlock() callback if not NULL, or alternatively
     * perform a sequential scan over all blocks.  The determined block is
     * then typically read and pinned.
     *
     * As the TsmRoutine interface is block based, a block needs to be passed
     * to NextSampleBlock(). If that's not appropriate for an AM, it
     * internally needs to perform mapping between the internal and a block
     * based representation.
     *
     * Note that it's not acceptable to hold deadlock prone resources such as
     * lwlocks until scan_sample_next_tuple() has exhausted the tuples on the
     * block - the tuple is likely to be returned to an upper query node, and
     * the next call could be off a int64_t while. Holding buffer pins and such
     * is obviously OK.
     *
     * Currently it is required to implement this interface, as there's no
     * alternative way (contrary e.g. to bitmap scans) to implement sample
     * scans. If infeasible to implement, the AM may raise an error.
     */
    bool        (*scan_sample_next_block) (xk_pg_parser_TableScanDesc scan,
                                           struct xk_pg_parser_SampleScanState *scanstate);

    /*
     * This callback, only called after scan_sample_next_block has returned
     * true, should determine the next tuple to be returned from the selected
     * block using the TsmRoutine's NextSampleTuple() callback.
     *
     * The callback needs to perform visibility checks, and only return
     * visible tuples. That obviously can mean calling NextSampleTuple()
     * multiple times.
     *
     * The TsmRoutine interface assumes that there's a maximum offset on a
     * given page, so if that doesn't apply to an AM, it needs to emulate that
     * assumption somehow.
     */
    bool        (*scan_sample_next_tuple) (xk_pg_parser_TableScanDesc scan,
                                           struct xk_pg_parser_SampleScanState *scanstate,
                                           xk_pg_parser_TupleTableSlot *slot);

} xk_pg_parser_TableAmRoutine;

typedef int64_t xk_pg_parser_PgStat_Counter;

typedef struct xk_pg_parser_PgStat_TableCounts
{
    xk_pg_parser_PgStat_Counter t_numscans;

    xk_pg_parser_PgStat_Counter t_tuples_returned;
    xk_pg_parser_PgStat_Counter t_tuples_fetched;

    xk_pg_parser_PgStat_Counter t_tuples_inserted;
    xk_pg_parser_PgStat_Counter t_tuples_updated;
    xk_pg_parser_PgStat_Counter t_tuples_deleted;
    xk_pg_parser_PgStat_Counter t_tuples_hot_updated;
    bool        t_truncated;

    xk_pg_parser_PgStat_Counter t_delta_live_tuples;
    xk_pg_parser_PgStat_Counter t_delta_dead_tuples;
    xk_pg_parser_PgStat_Counter t_changed_tuples;

    xk_pg_parser_PgStat_Counter t_blocks_fetched;
    xk_pg_parser_PgStat_Counter t_blocks_hit;
} xk_pg_parser_PgStat_TableCounts;


typedef struct xk_pg_parser_PgStat_TableStatus
{
    uint32_t            t_id;            /* table's OID */
    bool        t_shared;        /* is it a shared catalog? */
    struct PgStat_TableXactStatus *trans;    /* lowest subxact's counts */
    xk_pg_parser_PgStat_TableCounts t_counts;    /* event counts to be sent */
} xk_pg_parser_PgStat_TableStatus;

typedef uint32_t xk_pg_parser_uint32_tedure;

