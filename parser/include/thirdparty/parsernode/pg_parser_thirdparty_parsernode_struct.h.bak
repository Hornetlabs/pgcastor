typedef struct xk_pg_parser_AppendState
{
    xk_pg_parser_PlanState    ps;                /* its first field is NodeTag */
    xk_pg_parser_PlanState **appendplans;    /* array of PlanStates for my inputs */
    int32_t            as_nplans;
